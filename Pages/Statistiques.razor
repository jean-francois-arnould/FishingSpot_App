@page "/statistiques"
@page "/FishingSpot_App/statistiques"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@inject ISupabaseService SupabaseService
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Statistiques</PageTitle>

<AuthorizeView>
    <div class="page-content stats-page">
        @if (isLoading)
        {
            <div class="empty-state">
                <div class="spinner"></div>
                <p class="mt-3">Chargement des statistiques...</p>
            </div>
        }
        else if (allCatches == null || !allCatches.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">📊</div>
                <h3>Aucune statistique disponible</h3>
                <p class="text-muted">Commencez par enregistrer vos prises pour voir vos statistiques !</p>
            </div>
        }
        else
        {
            <!-- Cards de statistiques -->
            <div class="stats-cards-container">
                <!-- Total de prises -->
                <div class="stat-card stat-card-primary" @onclick="ShowTotalInfo">
                    <div class="stat-icon">🎣</div>
                    <div class="stat-content">
                        <div class="stat-value">@totalCatches</div>
                        <div class="stat-label">Prises totales</div>
                    </div>
                </div>

                <!-- Plus gros poisson (longueur) -->
                <div class="stat-card stat-card-success" @onclick="ShowBiggestInfo">
                    <div class="stat-icon">📏</div>
                    <div class="stat-content">
                        <div class="stat-value">@(biggestFish?.Length.ToString("0")) cm</div>
                        <div class="stat-label">Plus gros poisson</div>
                        @if (biggestFish != null)
                        {
                            <div class="stat-detail">@biggestFish.FishName</div>
                        }
                    </div>
                </div>

                <!-- Plus lourd poisson -->
                <div class="stat-card stat-card-warning" @onclick="ShowHeaviestInfo">
                    <div class="stat-icon">⚖️</div>
                    <div class="stat-content">
                        <div class="stat-value">@(((heaviestFish?.Weight ?? 0) / 1000.0).ToString("0.00")) kg</div>
                        <div class="stat-label">Plus lourd</div>
                        @if (heaviestFish != null)
                        {
                            <div class="stat-detail">@heaviestFish.FishName</div>
                        }
                    </div>
                </div>

                <!-- Poids total -->
                <div class="stat-card stat-card-info" @onclick="ShowTotalWeightInfo">
                    <div class="stat-icon">🏆</div>
                    <div class="stat-content">
                        <div class="stat-value">@((totalWeight / 1000.0).ToString("0.00")) kg</div>
                        <div class="stat-label">Poids total capturé</div>
                    </div>
                </div>
            </div>

            <!-- Statistiques météo -->
            @if (catchesWithWeather != null && catchesWithWeather.Any())
            {
                <div class="stats-section">
                    <h2 class="stats-section-title">🌤️ Statistiques météo</h2>

                    <div class="stats-cards-container weather-stats-container">
                        <!-- Température moyenne -->
                        <div class="stat-card stat-card-weather" @onclick="ShowTemperatureInfo">
                            <div class="stat-icon">🌡️</div>
                            <div class="stat-content">
                                <div class="stat-value">@averageTemperature.ToString("F1")°C</div>
                                <div class="stat-label">Température moyenne</div>
                            </div>
                        </div>

                        <!-- Condition la plus fréquente -->
                        <div class="stat-card stat-card-weather stat-card-weather-condition" @onclick="ShowWeatherInfo">
                            <div class="stat-icon weather-icon-large">@mostFrequentWeatherEmoji</div>
                            <div class="stat-content">
                                <div class="stat-value">@mostFrequentWeatherCount</div>
                                <div class="stat-label">@mostFrequentWeatherCondition</div>
                                <div class="stat-detail">Condition la plus fréquente</div>
                            </div>
                        </div>

                        <!-- Vent moyen -->
                        <div class="stat-card stat-card-weather" @onclick="ShowWindInfo">
                            <div class="stat-icon">💨</div>
                            <div class="stat-content">
                                <div class="stat-value">@averageWindSpeed.ToString("F1") km/h</div>
                                <div class="stat-label">Vent moyen</div>
                            </div>
                        </div>

                        <!-- Humidité moyenne -->
                        <div class="stat-card stat-card-weather" @onclick="ShowHumidityInfo">
                            <div class="stat-icon">💧</div>
                            <div class="stat-content">
                                <div class="stat-value">@averageHumidity.ToString("F0")%</div>
                                <div class="stat-label">Humidité moyenne</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Meilleures conditions par espèce -->
                @if (topSpeciesStats.Any())
                {
                    <div class="stats-section">
                        <h2 class="stats-section-title">🎯 Meilleures conditions par espèce</h2>

                        <div class="species-weather-cards">
                            @foreach (var stat in topSpeciesStats)
                            {
                                <div class="species-weather-card">
                                    <div class="species-weather-header">
                                        <h4>@stat.FishName</h4>
                                        <span class="species-catch-count">@stat.CatchCount prises</span>
                                    </div>
                                    <div class="species-weather-details">
                                        <div class="weather-detail-row">
                                            <span class="weather-detail-label">@stat.WeatherEmoji @stat.MostCommonCondition</span>
                                            <span class="weather-detail-value">@stat.ConditionCount fois</span>
                                        </div>
                                        <div class="weather-detail-row">
                                            <span class="weather-detail-label">🌡️ Température moyenne</span>
                                            <span class="weather-detail-value">@stat.AverageTemp.ToString("F1")°C</span>
                                        </div>
                                        <div class="weather-detail-row">
                                            <span class="weather-detail-label">💨 Vent moyen</span>
                                            <span class="weather-detail-value">@stat.AverageWind.ToString("F1") km/h</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }

            <!-- Calendrier -->
            <div class="calendar-section">
                <div class="calendar-header">
                    <button class="calendar-nav-btn" @onclick="PreviousMonth">‹</button>
                    <h3 class="calendar-title">@currentMonth.ToString("MMMM yyyy")</h3>
                    <button class="calendar-nav-btn" @onclick="NextMonth">›</button>
                </div>

                <div class="calendar-grid">
                    <!-- Jours de la semaine -->
                    <div class="calendar-day-name">Lun</div>
                    <div class="calendar-day-name">Mar</div>
                    <div class="calendar-day-name">Mer</div>
                    <div class="calendar-day-name">Jeu</div>
                    <div class="calendar-day-name">Ven</div>
                    <div class="calendar-day-name">Sam</div>
                    <div class="calendar-day-name">Dim</div>

                    <!-- Jours vides avant le début du mois -->
                    @for (int i = 0; i < firstDayOfMonth; i++)
                    {
                        <div class="calendar-day calendar-day-empty"></div>
                    }

                    <!-- Jours du mois -->
                    @for (int day = 1; day <= daysInMonth; day++)
                    {
                        var currentDate = new DateTime(currentMonth.Year, currentMonth.Month, day);
                        var catchesOnDate = GetCatchesForDate(currentDate);
                        var hasCache = catchesOnDate.Any();
                        var isToday = currentDate.Date == DateTime.Today;

                        <div class="calendar-day @(hasCache ? "has-catch" : "") @(isToday ? "is-today" : "")"
                             @onclick="() => ShowCatchesForDate(currentDate, catchesOnDate)">
                            <span class="calendar-day-number">@day</span>
                            @if (hasCache)
                            {
                                <span class="calendar-day-badge">@catchesOnDate.Count</span>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</AuthorizeView>

<!-- Modal pour afficher l'explication d'une statistique -->
@if (showStatInfoModal)
{
    <div class="modal-overlay" @onclick="CloseStatInfoModal">
        <div class="modal-content stat-info-modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>@statInfoTitle</h3>
                <button class="modal-close-btn" @onclick="CloseStatInfoModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="stat-info-content">
                    <div class="stat-info-icon">@statInfoEmoji</div>
                    <p>@statInfoDescription</p>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal pour afficher les prises d'une date -->
@if (showCatchesModal && selectedDateCatches != null && selectedDateCatches.Any())
{
    <div class="modal-overlay" @onclick="CloseCatchesModal">
        <div class="modal-content catches-modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>🐟 Prises du @selectedDate.ToString("dd/MM/yyyy")</h3>
                <button class="modal-close-btn" @onclick="CloseCatchesModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="catches-modal-list">
                    @foreach (var fishCatch in selectedDateCatches)
                    {
                        <div class="catch-modal-item" @onclick="() => NavigateToCatchDetail(fishCatch.Id)">
                            @if (!string.IsNullOrEmpty(fishCatch.PhotoUrl))
                            {
                                <img src="@fishCatch.PhotoUrl" alt="@fishCatch.FishName" class="catch-modal-img" />
                            }
                            else
                            {
                                <div class="catch-modal-icon">🐟</div>
                            }
                            <div class="catch-modal-content">
                                <div class="catch-modal-name">@fishCatch.FishName</div>
                                <div class="catch-modal-location">📍 @fishCatch.LocationName</div>
                                <div class="catch-modal-stats">
                                    <span class="badge badge-info">@fishCatch.Length cm</span>
                                    <span class="badge badge-info">@(fishCatch.Weight / 1000).ToString("0.00") kg</span>
                                    @if (fishCatch.CatchTime.HasValue)
                                    {
                                        <span class="badge badge-secondary">⏰ @fishCatch.CatchTime.Value.ToString(@"hh\:mm")</span>
                                    }
                                    @if (fishCatch.WeatherTemperature.HasValue)
                                    {
                                        <span class="badge badge-weather">@GetWeatherEmoji(fishCatch.WeatherCode ?? 0) @fishCatch.WeatherTemperature.Value.ToString("F1")°C</span>
                                    }
                                </div>
                            </div>
                            <div class="catch-modal-arrow">›</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<FishCatch>? allCatches;
    private bool isLoading = true;

    // Statistiques
    private int totalCatches => allCatches?.Count ?? 0;
    private FishCatch? biggestFish;
    private FishCatch? heaviestFish;
    private double totalWeight => allCatches?.Sum(c => c.Weight) ?? 0;

    // Statistiques météo
    private List<FishCatch>? catchesWithWeather => allCatches?.Where(c => c.WeatherTemperature.HasValue).ToList();
    private double averageTemperature => catchesWithWeather?.Average(c => c.WeatherTemperature ?? 0) ?? 0;
    private double averageWindSpeed => catchesWithWeather?.Where(c => c.WindSpeed.HasValue).Average(c => c.WindSpeed ?? 0) ?? 0;
    private double averageHumidity => catchesWithWeather?.Where(c => c.Humidity.HasValue).Average(c => c.Humidity ?? 0) ?? 0;

    private string mostFrequentWeatherCondition = "";
    private int mostFrequentWeatherCount = 0;
    private string mostFrequentWeatherEmoji = "🌤️";

    private List<SpeciesWeatherStats> topSpeciesStats = new List<SpeciesWeatherStats>();

    // Calendrier
    private DateTime currentMonth = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
    private int daysInMonth => DateTime.DaysInMonth(currentMonth.Year, currentMonth.Month);
    private int firstDayOfMonth
    {
        get
        {
            var firstDay = new DateTime(currentMonth.Year, currentMonth.Month, 1);
            var dayOfWeek = (int)firstDay.DayOfWeek;
            return dayOfWeek == 0 ? 6 : dayOfWeek - 1; // Lundi = 0
        }
    }

    // Modal
    private bool showCatchesModal = false;
    private DateTime selectedDate;
    private List<FishCatch>? selectedDateCatches;

    // Modal info statistiques
    private bool showStatInfoModal = false;
    private string statInfoTitle = "";
    private string statInfoDescription = "";
    private string statInfoEmoji = "ℹ️";

    // Classe helper pour les statistiques par espèce
    private class SpeciesWeatherStats
    {
        public string FishName { get; set; } = "";
        public int CatchCount { get; set; }
        public string MostCommonCondition { get; set; } = "";
        public int ConditionCount { get; set; }
        public string WeatherEmoji { get; set; } = "🌤️";
        public double AverageTemp { get; set; }
        public double AverageWind { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            allCatches = await SupabaseService.GetAllCatchesAsync();

            if (allCatches != null && allCatches.Any())
            {
                // Plus gros poisson (longueur)
                biggestFish = allCatches.OrderByDescending(c => c.Length).FirstOrDefault();

                // Plus lourd poisson
                heaviestFish = allCatches.OrderByDescending(c => c.Weight).FirstOrDefault();

                // Calculer les statistiques météo
                CalculateWeatherStats();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Erreur lors du chargement des statistiques : {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CalculateWeatherStats()
    {
        if (catchesWithWeather == null || !catchesWithWeather.Any())
            return;

        // Condition météo la plus fréquente
        var weatherGroups = catchesWithWeather
            .Where(c => !string.IsNullOrEmpty(c.WeatherCondition))
            .GroupBy(c => new { c.WeatherCondition, c.WeatherCode })
            .OrderByDescending(g => g.Count())
            .FirstOrDefault();

        if (weatherGroups != null)
        {
            mostFrequentWeatherCondition = weatherGroups.Key.WeatherCondition ?? "Inconnu";
            mostFrequentWeatherCount = weatherGroups.Count();
            mostFrequentWeatherEmoji = GetWeatherEmoji(weatherGroups.Key.WeatherCode ?? 0);
        }

        // Statistiques par espèce (top 5 espèces avec le plus de prises)
        var speciesGroups = catchesWithWeather
            .GroupBy(c => c.FishName)
            .OrderByDescending(g => g.Count())
            .Take(5);

        topSpeciesStats = speciesGroups.Select(group =>
        {
            var catches = group.ToList();
            var weatherConditionGroup = catches
                .Where(c => !string.IsNullOrEmpty(c.WeatherCondition))
                .GroupBy(c => new { c.WeatherCondition, c.WeatherCode })
                .OrderByDescending(g => g.Count())
                .FirstOrDefault();

            return new SpeciesWeatherStats
            {
                FishName = group.Key,
                CatchCount = group.Count(),
                MostCommonCondition = weatherConditionGroup?.Key.WeatherCondition ?? "Inconnu",
                ConditionCount = weatherConditionGroup?.Count() ?? 0,
                WeatherEmoji = GetWeatherEmoji(weatherConditionGroup?.Key.WeatherCode ?? 0),
                AverageTemp = catches.Where(c => c.WeatherTemperature.HasValue).Average(c => c.WeatherTemperature ?? 0),
                AverageWind = catches.Where(c => c.WindSpeed.HasValue).Average(c => c.WindSpeed ?? 0)
            };
        }).ToList();
    }

    private List<FishCatch> GetCatchesForDate(DateTime date)
    {
        if (allCatches == null) return new List<FishCatch>();

        return allCatches
            .Where(c => c.CatchDate.Date == date.Date)
            .OrderBy(c => c.CatchTime ?? TimeSpan.Zero)
            .ToList();
    }

    private void PreviousMonth()
    {
        currentMonth = currentMonth.AddMonths(-1);
    }

    private void NextMonth()
    {
        currentMonth = currentMonth.AddMonths(1);
    }

    private void ShowCatchesForDate(DateTime date, List<FishCatch> catches)
    {
        if (!catches.Any()) return;

        selectedDate = date;
        selectedDateCatches = catches;
        showCatchesModal = true;
    }

    private void CloseCatchesModal()
    {
        showCatchesModal = false;
        selectedDateCatches = null;
    }

    private void NavigateToCatchDetail(int catchId)
    {
        Navigation.NavigateTo($"/FishingSpot_App/catch/{catchId}");
    }

    private string GetWeatherEmoji(int code)
    {
        return code switch
        {
            0 => "☀️",
            1 => "🌤️",
            2 => "⛅",
            3 => "☁️",
            45 or 48 => "🌫️",
            51 or 53 or 55 => "🌦️",
            61 or 63 or 65 => "🌧️",
            71 or 73 or 75 => "🌨️",
            77 => "🌨️",
            80 or 81 or 82 => "🌧️",
            85 or 86 => "🌨️",
            95 => "⛈️",
            96 or 99 => "⛈️",
            _ => "🌡️"
        };
    }

    private void ShowTotalInfo()
    {
        statInfoTitle = "🎣 Prises totales";
        statInfoEmoji = "🎣";
        statInfoDescription = "Le nombre total de poissons que vous avez capturés et enregistrés dans l'application. Continuez ainsi pour améliorer vos statistiques !";
        showStatInfoModal = true;
    }

    private void ShowBiggestInfo()
    {
        statInfoTitle = "📏 Plus gros poisson";
        statInfoEmoji = "📏";
        statInfoDescription = "Le poisson le plus long que vous avez capturé, mesuré en centimètres. C'est un record à battre lors de vos prochaines sessions !";
        showStatInfoModal = true;
    }

    private void ShowHeaviestInfo()
    {
        statInfoTitle = "⚖️ Plus lourd";
        statInfoEmoji = "⚖️";
        statInfoDescription = "Le poisson le plus lourd que vous avez attrapé, mesuré en kilogrammes. Un vrai trophée de pêcheur !";
        showStatInfoModal = true;
    }

    private void ShowTotalWeightInfo()
    {
        statInfoTitle = "🏆 Poids total capturé";
        statInfoEmoji = "🏆";
        statInfoDescription = "La somme du poids de tous les poissons que vous avez capturés. Une belle mesure de votre succès de pêche au fil du temps !";
        showStatInfoModal = true;
    }

    private void ShowTemperatureInfo()
    {
        statInfoTitle = "🌡️ Température moyenne";
        statInfoEmoji = "🌡️";
        statInfoDescription = "La température moyenne lors de vos sessions de pêche réussies. Cette information vous aide à identifier les conditions idéales pour pêcher.";
        showStatInfoModal = true;
    }

    private void ShowWeatherInfo()
    {
        statInfoTitle = "☁️ Condition météo la plus fréquente";
        statInfoEmoji = mostFrequentWeatherEmoji;
        statInfoDescription = $"La condition météo la plus courante lors de vos sorties de pêche. Vous avez pêché {mostFrequentWeatherCount} fois par temps {mostFrequentWeatherCondition.ToLower()}.";
        showStatInfoModal = true;
    }

    private void ShowWindInfo()
    {
        statInfoTitle = "💨 Vent moyen";
        statInfoEmoji = "💨";
        statInfoDescription = "La vitesse moyenne du vent lors de vos sessions de pêche. Le vent peut influencer le comportement des poissons et votre technique de pêche.";
        showStatInfoModal = true;
    }

    private void ShowHumidityInfo()
    {
        statInfoTitle = "💧 Humidité moyenne";
        statInfoEmoji = "💧";
        statInfoDescription = "Le niveau d'humidité moyen pendant vos sorties. L'humidité peut affecter l'activité des poissons et votre confort de pêche.";
        showStatInfoModal = true;
    }

    private void CloseStatInfoModal()
    {
        showStatInfoModal = false;
    }
}
