@page "/montages/ajouter"
@page "/FishingSpot_App/montages/ajouter"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@inject ISupabaseService SupabaseService
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Créer un Montage</PageTitle>

<div class="page-content">
    <a href="/FishingSpot_App/montages" class="btn btn-outline-secondary btn-sm mb-3">
        ← Retour aux montages
    </a>

    <h3 class="mb-4">🎣 Créer un Montage</h3>

    <EditForm Model="@newSetup" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="card mb-3">
            <div class="card-header">
                <strong>🎣 Canne</strong>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="rodBrand" class="form-label">Marque</label>
                        <InputText id="rodBrand" class="form-control" @bind-Value="newSetup.RodBrand" 
                                   placeholder="Ex: Shimano" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="rodModel" class="form-label">Modèle</label>
                        <InputText id="rodModel" class="form-control" @bind-Value="newSetup.RodModel" 
                                   placeholder="Ex: Zodias" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="rodLength" class="form-label">Longueur (m)</label>
                        <InputNumber id="rodLength" class="form-control" @bind-Value="newSetup.RodLength" 
                                     step="0.1" placeholder="Ex: 2.4" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="rodPower" class="form-label">Puissance</label>
                        <InputText id="rodPower" class="form-control" @bind-Value="newSetup.RodPower" 
                                   placeholder="Ex: M, MH, H" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <strong>🎡 Moulinet</strong>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label for="reelBrand" class="form-label">Marque</label>
                        <InputText id="reelBrand" class="form-control" @bind-Value="newSetup.ReelBrand" 
                                   placeholder="Ex: Daiwa" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label for="reelModel" class="form-label">Modèle</label>
                        <InputText id="reelModel" class="form-control" @bind-Value="newSetup.ReelModel" 
                                   placeholder="Ex: Tatula" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label for="reelType" class="form-label">Type</label>
                        <InputText id="reelType" class="form-control" @bind-Value="newSetup.ReelType" 
                                   placeholder="Ex: Spinning, Casting" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <strong>🧵 Ligne</strong>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label for="lineType" class="form-label">Type</label>
                        <InputText id="lineType" class="form-control" @bind-Value="newSetup.LineType" 
                                   placeholder="Ex: Tresse, Nylon, Fluorocarbone" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label for="lineDiameter" class="form-label">Diamètre (mm)</label>
                        <InputNumber id="lineDiameter" class="form-control" @bind-Value="newSetup.LineDiameter" 
                                     step="0.01" placeholder="Ex: 0.28" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label for="lineStrength" class="form-label">Résistance (kg)</label>
                        <InputNumber id="lineStrength" class="form-control" @bind-Value="newSetup.LineBreakingStrength" 
                                     step="0.1" placeholder="Ex: 10" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <strong>🪝 Hameçon & Appât</strong>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="hookSize" class="form-label">Taille hameçon</label>
                        <InputText id="hookSize" class="form-control" @bind-Value="newSetup.HookSize" 
                                   placeholder="Ex: #2, #4, #6" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="baitType" class="form-label">Type d'appât</label>
                        <InputText id="baitType" class="form-control" @bind-Value="newSetup.BaitType" 
                                   placeholder="Ex: Ver de terre, Leurre souple" />
                    </div>
                </div>
            </div>
        </div>

        <div class="mb-3">
            <label for="description" class="form-label">📝 Description</label>
            <InputTextArea id="description" class="form-control" @bind-Value="newSetup.Description" 
                           rows="3" placeholder="Description du montage (optionnel)" />
        </div>

        <div class="mb-3 form-check">
            <InputCheckbox id="isFavorite" class="form-check-input" @bind-Value="newSetup.IsFavorite" />
            <label class="form-check-label" for="isFavorite">
                ⭐ Marquer comme favori
            </label>
        </div>

        <div class="mb-3 form-check">
            <InputCheckbox id="isCurrent" class="form-check-input" @bind-Value="setAsCurrent" />
            <label class="form-check-label" for="isCurrent">
                🎯 Définir comme montage actuel
            </label>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(warningMessage))
        {
            <div class="alert alert-warning">@warningMessage</div>
        }

        <div class="mt-4">
            <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                ✅ Enregistrer
            </button>
            <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">
                Annuler
            </button>
        </div>
    </EditForm>
</div>

@code {
    private FishingSetup newSetup = new();
    private bool setAsCurrent = false;
    private bool isSubmitting = false;
    private string? errorMessage;
    private string? warningMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        await Task.CompletedTask;
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        warningMessage = null;

        try
        {
            // Vérifier qu'au moins un champ est renseigné
            if (string.IsNullOrWhiteSpace(newSetup.RodBrand) && 
                string.IsNullOrWhiteSpace(newSetup.ReelBrand) && 
                string.IsNullOrWhiteSpace(newSetup.LineType) &&
                string.IsNullOrWhiteSpace(newSetup.HookSize) &&
                string.IsNullOrWhiteSpace(newSetup.BaitType) &&
                string.IsNullOrWhiteSpace(newSetup.Description))
            {
                errorMessage = "Veuillez renseigner au moins un champ.";
                return;
            }

            Console.WriteLine($"📤 Creating setup...");

            // Créer le montage
            var createdSetupId = await SupabaseService.AddSetupAsync(newSetup);

            if (createdSetupId > 0)
            {
                Console.WriteLine($"✅ Setup created with ID: {createdSetupId}");

                // Si "Définir comme actuel" est coché
                if (setAsCurrent)
                {
                    await SupabaseService.SetCurrentSetupAsync(createdSetupId);
                }

                Navigation.NavigateTo("/FishingSpot_App/montages");
            }
            else
            {
                errorMessage = "Erreur lors de la création du montage.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
            Console.WriteLine($"❌ Error creating setup: {ex.Message}");
            Console.WriteLine($"Stack: {ex.StackTrace}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/FishingSpot_App/montages");
    }
}
