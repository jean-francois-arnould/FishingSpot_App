@page "/montages/modifier/{SetupId:int}"
@page "/FishingSpot_App/montages/modifier/{SetupId:int}"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@inject ISupabaseService SupabaseService
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Modifier le Montage</PageTitle>

<div class="page-content">
    <a href="/FishingSpot_App/montages" class="btn btn-outline-secondary btn-sm mb-3">
        ← Retour aux montages
    </a>

    <h3 class="mb-4">🎣 Modifier le Montage</h3>

    @if (isLoading)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement...</p>
        </div>
    }
    else if (setup == null)
    {
        <div class="alert alert-danger">
            Montage non trouvé.
        </div>
    }
    else
    {
        <EditForm Model="@setup" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="card mb-3">
                <div class="card-header">
                    <strong>🎣 Canne</strong>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="rodBrand" class="form-label">Marque</label>
                            <InputText id="rodBrand" class="form-control" @bind-Value="setup.RodBrand" 
                                       placeholder="Ex: Shimano" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="rodModel" class="form-label">Modèle</label>
                            <InputText id="rodModel" class="form-control" @bind-Value="setup.RodModel" 
                                       placeholder="Ex: Zodias" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="rodLength" class="form-label">Longueur (m)</label>
                            <InputNumber id="rodLength" class="form-control" @bind-Value="setup.RodLength" 
                                         step="0.1" placeholder="Ex: 2.4" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="rodPower" class="form-label">Puissance</label>
                            <InputText id="rodPower" class="form-control" @bind-Value="setup.RodPower" 
                                       placeholder="Ex: M, MH, H" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">
                    <strong>🎡 Moulinet</strong>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="reelBrand" class="form-label">Marque</label>
                            <InputText id="reelBrand" class="form-control" @bind-Value="setup.ReelBrand" 
                                       placeholder="Ex: Daiwa" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="reelModel" class="form-label">Modèle</label>
                            <InputText id="reelModel" class="form-control" @bind-Value="setup.ReelModel" 
                                       placeholder="Ex: Tatula" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="reelType" class="form-label">Type</label>
                            <InputText id="reelType" class="form-control" @bind-Value="setup.ReelType" 
                                       placeholder="Ex: Spinning, Casting" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">
                    <strong>🧵 Ligne</strong>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="lineType" class="form-label">Type</label>
                            <InputText id="lineType" class="form-control" @bind-Value="setup.LineType" 
                                       placeholder="Ex: Tresse, Nylon, Fluorocarbone" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="lineDiameter" class="form-label">Diamètre (mm)</label>
                            <InputNumber id="lineDiameter" class="form-control" @bind-Value="setup.LineDiameter" 
                                         step="0.01" placeholder="Ex: 0.28" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="lineStrength" class="form-label">Résistance (kg)</label>
                            <InputNumber id="lineStrength" class="form-control" @bind-Value="setup.LineBreakingStrength" 
                                         step="0.1" placeholder="Ex: 10" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">
                    <strong>🪝 Hameçon & Appât</strong>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="hookSize" class="form-label">Taille hameçon</label>
                            <InputText id="hookSize" class="form-control" @bind-Value="setup.HookSize" 
                                       placeholder="Ex: #2, #4, #6" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="baitType" class="form-label">Type d'appât</label>
                            <InputText id="baitType" class="form-control" @bind-Value="setup.BaitType" 
                                       placeholder="Ex: Ver de terre, Leurre souple" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">📝 Description</label>
                <InputTextArea id="description" class="form-control" @bind-Value="setup.Description" 
                               rows="3" placeholder="Description du montage (optionnel)" />
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox id="isFavorite" class="form-check-input" @bind-Value="setup.IsFavorite" />
                <label class="form-check-label" for="isFavorite">
                    ⭐ Marquer comme favori
                </label>
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox id="isCurrent" class="form-check-input" @bind-Value="setup.IsCurrent" 
                               disabled="@setup.IsCurrent" />
                <label class="form-check-label" for="isCurrent">
                    🎯 Montage actuel @(setup.IsCurrent ? "(déjà actif)" : "")
                </label>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <div class="mt-4">
                <button type="submit" class="btn btn-success" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    ✅ Enregistrer
                </button>
                <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">
                    Annuler
                </button>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public int SetupId { get; set; }

    private FishingSetup? setup;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            setup = await SupabaseService.GetSetupByIdAsync(SetupId);

            if (setup != null)
            {
                Console.WriteLine($"✅ Loaded setup: ID {setup.Id}");
            }
            else
            {
                errorMessage = "Montage introuvable.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement: {ex.Message}";
            Console.WriteLine($"❌ Error loading: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        if (setup == null)
        {
            errorMessage = "Montage non trouvé.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            // Vérifier qu'au moins un champ est renseigné
            if (string.IsNullOrWhiteSpace(setup.RodBrand) && 
                string.IsNullOrWhiteSpace(setup.ReelBrand) && 
                string.IsNullOrWhiteSpace(setup.LineType) &&
                string.IsNullOrWhiteSpace(setup.HookSize) &&
                string.IsNullOrWhiteSpace(setup.BaitType) &&
                string.IsNullOrWhiteSpace(setup.Description))
            {
                errorMessage = "Veuillez renseigner au moins un champ.";
                return;
            }

            Console.WriteLine($"📤 Updating setup ID: {setup.Id}");

            var success = await SupabaseService.UpdateSetupAsync(setup);

            if (success)
            {
                Console.WriteLine($"✅ Setup updated successfully");
                Navigation.NavigateTo("/FishingSpot_App/montages");
            }
            else
            {
                errorMessage = "Erreur lors de la modification du montage.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
            Console.WriteLine($"❌ Error updating setup: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/FishingSpot_App/montages");
    }
}
