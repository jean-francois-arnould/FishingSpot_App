@page "/montages"
@page "/FishingSpot_App/montages"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@using Microsoft.JSInterop
@inject ISupabaseService SupabaseService
@inject IEquipmentService EquipmentService
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Mes Montages</PageTitle>

<div class="page-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>🎣 Mes Montages</h3>
        <a href="/FishingSpot_App/montages/ajouter" class="btn btn-primary">
            ➕ Nouveau montage
        </a>
    </div>

    @if (isLoading)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement des montages...</p>
        </div>
    }
    else if (!setups.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🎣</div>
            <h4>Aucun montage enregistré</h4>
            <p class="text-muted">Utilisez le bouton + ci-dessus pour créer votre premier montage</p>
        </div>
    }
    else
    {
        <!-- Sélecteur de montage actuel -->
        <div class="current-setup-selector mb-4">
            <label class="form-label fw-bold">🎯 Montage actuel</label>
            <div class="d-flex align-items-center gap-3">
                <select class="form-select" @onchange="OnCurrentSetupChangedAsync" value="@(currentSetup?.Id ?? 0)">
                    <option value="0" disabled>-- Sélectionner un montage --</option>
                    @foreach (var setup in setups)
                    {
                        <option value="@setup.Id">
                            @(setup.IsFavorite ? "⭐ " : "")@GetSetupTitle(setup)
                        </option>
                    }
                </select>
                @if (currentSetup != null)
                {
                    <button class="btn btn-outline-primary" @onclick="() => NavigateToDetails(currentSetup.Id)">
                        👁️ Voir détails
                    </button>
                }
            </div>
        </div>

        <!-- Accordéon Mes Favoris -->
        @if (favoriteSetups.Any())
        {
            <div class="accordion mb-3" id="accordionFavorites">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFavorites" aria-expanded="true">
                            ⭐ Mes Favoris (@favoriteSetups.Count)
                        </button>
                    </h2>
                    <div id="collapseFavorites" class="accordion-collapse collapse show" data-bs-parent="#accordionFavorites">
                        <div class="accordion-body">
                            <div class="row">
                                @foreach (var setup in favoriteSetups)
                                {
                                    @RenderSetupCard(setup)
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Accordéon Mes Montages -->
        <div class="accordion" id="accordionSetups">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button @(favoriteSetups.Any() ? "collapsed" : "")" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSetups" aria-expanded="@(favoriteSetups.Any() ? "false" : "true")">
                        🎣 Mes Montages (@setups.Count)
                    </button>
                </h2>
                <div id="collapseSetups" class="accordion-collapse collapse @(favoriteSetups.Any() ? "" : "show")" data-bs-parent="#accordionSetups">
                    <div class="accordion-body">
                        <div class="row">
                            @foreach (var setup in setups)
                            {
                                @RenderSetupCard(setup)
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-3">@errorMessage</div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success mt-3">@successMessage</div>
    }
</div>

<style>
    .current-setup-selector {
        background-color: #f8f9ff;
        padding: 1rem;
        border-radius: 8px;
        border: 2px solid #0d6efd;
    }

    .accordion-button {
        font-weight: 600;
        font-size: 1.1rem;
    }

    .setup-card {
        border: 2px solid #e0e0e0;
        transition: all 0.3s;
        height: 100%;
    }

    .setup-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }

    .current-setup {
        border-color: #0d6efd;
        background-color: #f8f9ff;
    }

    .setup-details {
        margin-top: 0.75rem;
    }

    .setup-item {
        background-color: #f0f0f0;
        padding: 0.4rem 0.6rem;
        border-radius: 4px;
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
    }

    .favorite-badge {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        background-color: #ffc107;
        color: white;
        padding: 0.25rem 0.5rem;
        border-radius: 20px;
        font-size: 0.8rem;
    }
</style>

@code {
    private List<FishingSetup> setups = new();
    private List<FishingSetup> favoriteSetups => setups.Where(s => s.IsFavorite).ToList();
    private FishingSetup? currentSetup;

    // Listes d'équipement pour résolution
    private List<Rod> rods = new();
    private List<Reel> reels = new();
    private List<Line> lines = new();
    private List<Lure> lures = new();
    private List<Leader> leaders = new();
    private List<Hook> hooks = new();

    private bool isLoading = true;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        await LoadSetupsAsync();
    }

    private async Task OnCurrentSetupChangedAsync(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int setupId) && setupId > 0)
        {
            await SetAsCurrentAsync(setupId);
        }
    }

    private RenderFragment RenderSetupCard(FishingSetup setup) => __builder =>
    {
        <div class="col-md-6 col-lg-4 mb-3">
            <div class="card setup-card @(setup.IsCurrent ? "current-setup" : "")" @onclick="() => NavigateToDetails(setup.Id)" style="cursor: pointer;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title mb-0">
                            @if (setup.IsFavorite)
                            {
                                <span>⭐</span>
                            }
                            @if (setup.IsCurrent)
                            {
                                <span>🎯</span>
                            }
                            @GetSetupTitle(setup)
                        </h5>
                        <div class="dropdown" @onclick:stopPropagation>
                            <button class="btn btn-sm btn-link" type="button" data-bs-toggle="dropdown">
                                ⋮
                            </button>
                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item" href="/FishingSpot_App/montages/details/@setup.Id">
                                        👁️ Détails
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/FishingSpot_App/montages/modifier/@setup.Id">
                                        ✏️ Modifier
                                    </a>
                                </li>
                                @if (!setup.IsCurrent)
                                {
                                    <li>
                                        <button class="dropdown-item" @onclick="() => SetAsCurrentAsync(setup.Id)">
                                            🎯 Définir comme actuel
                                        </button>
                                    </li>
                                }
                                <li>
                                    <button class="dropdown-item" @onclick="() => ToggleFavoriteAsync(setup.Id, setup.IsFavorite)">
                                        @(setup.IsFavorite ? "☆ Retirer des favoris" : "⭐ Ajouter aux favoris")
                                    </button>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <button class="dropdown-item text-danger" @onclick="() => DeleteSetupAsync(setup.Id)">
                                        🗑️ Supprimer
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(setup.Description))
                    {
                        <p class="text-muted small mb-2">@setup.Description</p>
                    }

                    <div class="setup-details">
                        @if (setup.RodId.HasValue)
                        {
                            var rod = rods.FirstOrDefault(r => r.Id == setup.RodId);
                            if (rod != null)
                            {
                                <div class="setup-item">
                                    🎣 @rod.Brand @rod.Model @(!string.IsNullOrEmpty(rod.Length) ? $"({rod.Length})" : "")
                                </div>
                            }
                        }
                        @if (setup.ReelId.HasValue)
                        {
                            var reel = reels.FirstOrDefault(r => r.Id == setup.ReelId);
                            if (reel != null)
                            {
                                <div class="setup-item">🎡 @reel.Brand @reel.Model</div>
                            }
                        }
                        @if (setup.LineId.HasValue)
                        {
                            var line = lines.FirstOrDefault(l => l.Id == setup.LineId);
                            if (line != null)
                            {
                                <div class="setup-item">
                                    🧵 @line.Brand @line.Type @(!string.IsNullOrEmpty(line.Strength) ? $"({line.Strength})" : "")
                                </div>
                            }
                        }
                        @if (setup.LureId.HasValue)
                        {
                            var lure = lures.FirstOrDefault(l => l.Id == setup.LureId);
                            if (lure != null)
                            {
                                <div class="setup-item">🪝 @lure.Name</div>
                            }
                        }
                        @if (setup.LeaderId.HasValue)
                        {
                            var leader = leaders.FirstOrDefault(l => l.Id == setup.LeaderId);
                            if (leader != null)
                            {
                                <div class="setup-item">⛓️ @leader.Material</div>
                            }
                        }
                        @if (setup.HookId.HasValue)
                        {
                            var hook = hooks.FirstOrDefault(h => h.Id == setup.HookId);
                            if (hook != null)
                            {
                                <div class="setup-item">🎣 Hameçon @hook.Size</div>
                            }
                        }
                    </div>
                </div>
                <div class="card-footer text-muted small">
                    Créé le @setup.CreatedAt?.ToString("dd/MM/yyyy")
                </div>
            </div>
        </div>
    };

    private async Task LoadSetupsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            // Charger les montages et le matériel en parallèle
            var setupsTask = SupabaseService.GetAllSetupsAsync();
            var rodsTask = EquipmentService.GetAllRodsAsync();
            var reelsTask = EquipmentService.GetAllReelsAsync();
            var linesTask = EquipmentService.GetAllLinesAsync();
            var luresTask = EquipmentService.GetAllLuresAsync();
            var leadersTask = EquipmentService.GetAllLeadersAsync();
            var hooksTask = EquipmentService.GetAllHooksAsync();

            await Task.WhenAll(setupsTask, rodsTask, reelsTask, linesTask, luresTask, leadersTask, hooksTask);

            setups = await setupsTask;
            rods = await rodsTask;
            reels = await reelsTask;
            lines = await linesTask;
            lures = await luresTask;
            leaders = await leadersTask;
            hooks = await hooksTask;

            currentSetup = setups.FirstOrDefault(s => s.IsCurrent);
            Console.WriteLine($"✅ Loaded {setups.Count} setups and equipment");
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            // Token expiré ou non valide
            Console.WriteLine($"⚠️ Token expiré - Redirection vers login");
            await AuthService.SignOutAsync();
            Navigation.NavigateTo("/FishingSpot_App/login");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement des montages : {ex.Message}";
            Console.WriteLine($"❌ Error: {ex.Message}");

            // Vérifier si c'est une erreur d'authentification
            if (ex.Message.Contains("401") || ex.Message.Contains("Unauthorized") || ex.Message.Contains("auth"))
            {
                Console.WriteLine($"⚠️ Erreur d'authentification détectée - Redirection vers login");
                await AuthService.SignOutAsync();
                Navigation.NavigateTo("/FishingSpot_App/login");
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetSetupTitle(FishingSetup setup)
    {
        if (!string.IsNullOrEmpty(setup.Description))
            return setup.Description;

        if (setup.RodId.HasValue)
        {
            var rod = rods.FirstOrDefault(r => r.Id == setup.RodId);
            if (rod != null)
                return $"{rod.Brand} {rod.Model}";
        }

        return $"Montage #{setup.Id}";
    }

    private void NavigateToDetails(int setupId)
    {
        Navigation.NavigateTo($"/FishingSpot_App/montages/details/{setupId}");
    }

    private async Task ToggleFavoriteAsync(int setupId, bool currentlyFavorite)
    {
        try
        {
            var setup = setups.FirstOrDefault(s => s.Id == setupId);
            if (setup != null)
            {
                setup.IsFavorite = !currentlyFavorite;
                var success = await SupabaseService.UpdateSetupAsync(setup);

                if (success)
                {
                    successMessage = setup.IsFavorite ? "⭐ Ajouté aux favoris !" : "Retiré des favoris";
                    await LoadSetupsAsync();
                    StateHasChanged();

                    await Task.Delay(2000);
                    successMessage = null;
                    StateHasChanged();
                }
                else
                {
                    setup.IsFavorite = currentlyFavorite; // Rollback
                    errorMessage = "Erreur lors de la mise à jour.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
            Console.WriteLine($"❌ Error: {ex.Message}");
        }
    }

    private async Task SetAsCurrentAsync(int setupId)
    {
        try
        {
            var success = await SupabaseService.SetCurrentSetupAsync(setupId);
            if (success)
            {
                successMessage = "Montage actuel mis à jour !";
                await LoadSetupsAsync();
                StateHasChanged();

                await Task.Delay(3000);
                successMessage = null;
                StateHasChanged();
            }
            else
            {
                errorMessage = "Erreur lors de la mise à jour du montage actuel.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
            Console.WriteLine($"❌ Error: {ex.Message}");
        }
    }

    private async Task DeleteSetupAsync(int setupId)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Êtes-vous sûr de vouloir supprimer ce montage ?"))
        {
            return;
        }

        try
        {
            var success = await SupabaseService.DeleteSetupAsync(setupId);
            if (success)
            {
                successMessage = "Montage supprimé avec succès !";
                await LoadSetupsAsync();
                StateHasChanged();

                await Task.Delay(3000);
                successMessage = null;
                StateHasChanged();
            }
            else
            {
                errorMessage = "Erreur lors de la suppression du montage.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur : {ex.Message}";
            Console.WriteLine($"❌ Error: {ex.Message}");
        }
    }
}
