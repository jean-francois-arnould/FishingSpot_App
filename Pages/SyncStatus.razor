@page "/sync-status"
@using FishingSpot.PWA.Services.Offline
@using FishingSpot.PWA.Services.Offline.Models
@inject ISyncService SyncService
@inject INetworkStatusService NetworkStatus
@implements IDisposable

<div class="container py-4">
    <h2>🔄 État de la synchronisation</h2>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Statut réseau</h5>
            <div class="d-flex align-items-center gap-2">
                @if (NetworkStatus.IsOnline)
                {
                    <span class="badge bg-success">✅ En ligne</span>
                }
                else
                {
                    <span class="badge bg-danger">❌ Hors ligne</span>
                }
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">Synchronisation</h5>
            <div class="d-flex align-items-center gap-2 mb-2">
                @if (SyncService.IsSyncing)
                {
                    <span class="badge bg-primary">🔄 Synchronisation en cours...</span>
                }
                else
                {
                    <span class="badge bg-secondary">⏸️ Pas de synchronisation</span>
                }
            </div>
            <p class="mb-2">
                <strong>Éléments en attente:</strong> @SyncService.PendingItemsCount
            </p>
            @if (NetworkStatus.IsOnline && SyncService.PendingItemsCount > 0)
            {
                <button class="btn btn-primary btn-sm" @onclick="ManualSync" disabled="@SyncService.IsSyncing">
                    🔄 Synchroniser maintenant
                </button>
            }
            @if (SyncService.PendingItemsCount > 0)
            {
                <button class="btn btn-secondary btn-sm ms-2" @onclick="LoadPendingItems">
                    📋 Voir les détails
                </button>
            }
        </div>
    </div>

    @if (pendingItems.Any())
    {
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Éléments en attente de synchronisation</h5>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Action</th>
                                <th>Type</th>
                                <th>ID</th>
                                <th>Date</th>
                                <th>Statut</th>
                                <th>Tentatives</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in pendingItems)
                            {
                                <tr>
                                    <td>
                                        @switch (item.Action)
                                        {
                                            case SyncAction.Create:
                                                <span class="badge bg-success">➕ Créer</span>
                                                break;
                                            case SyncAction.Update:
                                                <span class="badge bg-warning">✏️ Modifier</span>
                                                break;
                                            case SyncAction.Delete:
                                                <span class="badge bg-danger">🗑️ Supprimer</span>
                                                break;
                                        }
                                    </td>
                                    <td>@item.EntityType</td>
                                    <td>@item.EntityId</td>
                                    <td>@item.Timestamp.ToLocalTime().ToString("dd/MM HH:mm")</td>
                                    <td>
                                        @switch (item.Status)
                                        {
                                            case FishingSpot.PWA.Services.Offline.Models.SyncStatus.Pending:
                                                <span class="badge bg-secondary">⏳ En attente</span>
                                                break;
                                            case FishingSpot.PWA.Services.Offline.Models.SyncStatus.InProgress:
                                                <span class="badge bg-primary">⏳ En cours</span>
                                                break;
                                            case FishingSpot.PWA.Services.Offline.Models.SyncStatus.Completed:
                                                <span class="badge bg-success">✅ Terminé</span>
                                                break;
                                            case FishingSpot.PWA.Services.Offline.Models.SyncStatus.Failed:
                                                <span class="badge bg-danger">❌ Échec</span>
                                                break;
                                        }
                                    </td>
                                    <td>@item.RetryCount / 3</td>
                                </tr>
                                @if (!string.IsNullOrEmpty(item.ErrorMessage))
                                {
                                    <tr>
                                        <td colspan="6" class="text-danger small">
                                            ⚠️ @item.ErrorMessage
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <button class="btn btn-outline-secondary btn-sm mt-2" @onclick="ClearCompleted">
                    🗑️ Nettoyer les éléments terminés
                </button>
            </div>
        </div>
    }
</div>

@code {
    private List<SyncQueueItem> pendingItems = new();

    protected override async Task OnInitializedAsync()
    {
        NetworkStatus.OnlineStatusChanged += HandleStatusChanged;
        SyncService.SyncStatusChanged += HandleStatusChanged;
        SyncService.SyncQueueChanged += HandleQueueChanged;

        await LoadPendingItems();
    }

    private async Task LoadPendingItems()
    {
        pendingItems = await SyncService.GetPendingItemsAsync();
        StateHasChanged();
    }

    private async Task ManualSync()
    {
        await SyncService.SyncAllAsync();
        await LoadPendingItems();
    }

    private async Task ClearCompleted()
    {
        await SyncService.ClearCompletedItemsAsync();
        await LoadPendingItems();
    }

    private void HandleStatusChanged(object? sender, bool status)
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleQueueChanged(object? sender, int count)
    {
        InvokeAsync(async () =>
        {
            await LoadPendingItems();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        NetworkStatus.OnlineStatusChanged -= HandleStatusChanged;
        SyncService.SyncStatusChanged -= HandleStatusChanged;
        SyncService.SyncQueueChanged -= HandleQueueChanged;
    }
}
