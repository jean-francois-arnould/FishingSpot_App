@page "/carte"
@page "/FishingSpot_App/carte"
@inject NavigationManager Navigation

<PageTitle>Carte des Spots</PageTitle>

<div class="page-content">
    <div class="card">
        <div class="card-header">
            <h3 class="mb-0">🗺️ Carte des Spots de Pêche</h3>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3">
                Explorez les meilleurs spots de pêche autour de vous grâce à la carte interactive Géopêche.
            </p>
            <a href="https://map.geopeche.com/" 
               target="_blank" 
               rel="noopener noreferrer" 
               class="btn btn-primary btn-lg w-100">
                🗺️ Ouvrir la carte Géopêche
            </a>
            <p class="text-muted mt-3" style="font-size: 0.85rem;">
                <i>La carte s'ouvrira dans un nouvel onglet</i>
            </p>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header">
            <h5 class="mb-0">💡 Astuce</h5>
        </div>
        <div class="card-body">
            <p class="mb-2"><strong>Sur Géopêche, vous pouvez :</strong></p>
            <ul style="padding-left: 1.5rem; margin-bottom: 0;">
                <li>Découvrir les spots publics près de chez vous</li>
                <li>Voir les espèces présentes dans chaque plan d'eau</li>
                <li>Consulter les avis et photos d'autres pêcheurs</li>
                <li>Vérifier les règlementations locales</li>
            </ul>
        </div>
    </div>
</div>
