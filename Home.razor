@page "/"
@page "/FishingSpot_App/"
@using FishingSpot.PWA.Services
@using FishingSpot.PWA.Models
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject NavigationManager Navigation

<PageTitle>FishingSpot - Fishing Tracker</PageTitle>

@if (AuthService.IsAuthenticated)
{
    <!-- Utilisateur connecté -->
    <div class="empty-state">
        @if (userProfile != null && !string.IsNullOrEmpty(userProfile.AvatarUrl))
        {
            <div class="profile-avatar-large">
                <img src="@userProfile.AvatarUrl" alt="Avatar de @GetDisplayName()" />
            </div>
        }
        else
        {
            <div class="empty-state-icon">👋</div>
        }
        <h1>Bienvenue @GetDisplayName()!</h1>
        <p class="empty-state-text">Prêt pour votre prochaine session de pêche ?</p>
    </div>

    <div class="card">
        <div class="card-header">🎣 Actions Rapides</div>
        <div class="d-flex flex-column gap-2">
            <a href="/FishingSpot_App/catches/add" class="btn btn-primary btn-lg">
                ➕ Enregistrer une prise
            </a>
            <a href="/FishingSpot_App/catches" class="btn btn-outline-primary">
                📋 Voir mes prises
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">⚡ Raccourcis</div>
        <div class="list-item" @onclick="@(() => Navigation.NavigateTo("/FishingSpot_App/materiel"))">
            <div class="list-item-icon">🎣</div>
            <div class="list-item-content">
                <div class="list-item-title">Matériel</div>
                <div class="list-item-subtitle">Gérer votre équipement</div>
            </div>
            <div class="list-item-action">→</div>
        </div>

        <div class="list-item" @onclick="@(() => Navigation.NavigateTo("/FishingSpot_App/montages"))">
            <div class="list-item-icon">🪝</div>
            <div class="list-item-content">
                <div class="list-item-title">Montages</div>
                <div class="list-item-subtitle">Vos configurations favorites</div>
            </div>
            <div class="list-item-action">→</div>
        </div>
    </div>
}
else
{
    <!-- Utilisateur non connecté -->
    <div class="empty-state">
        <div class="empty-state-icon">🎣</div>
        <h1>FishingSpot</h1>
        <p class="empty-state-text">Suivez toutes vos prises de pêche en un seul endroit</p>
    </div>

    <div class="card">
        <h3 class="text-center mb-3">Commencez maintenant !</h3>
        <p class="text-center mb-3">Créez un compte gratuit pour suivre vos prises de pêche</p>
        <div class="d-flex flex-column gap-2">
            <a href="/FishingSpot_App/register" class="btn btn-success btn-lg">
                ✨ Créer un compte
            </a>
            <a href="/FishingSpot_App/login" class="btn btn-outline-primary">
                🔐 Se connecter
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">✨ Fonctionnalités</div>
        <div class="list-item">
            <div class="list-item-icon">📍</div>
            <div class="list-item-content">
                <div class="list-item-title">Localisation GPS</div>
                <div class="list-item-subtitle">Enregistrez l'emplacement exact</div>
            </div>
        </div>

        <div class="list-item">
            <div class="list-item-icon">📸</div>
            <div class="list-item-content">
                <div class="list-item-title">Photos</div>
                <div class="list-item-subtitle">Immortalisez vos prises</div>
            </div>
        </div>

        <div class="list-item">
            <div class="list-item-icon">📊</div>
            <div class="list-item-content">
                <div class="list-item-title">Statistiques</div>
                <div class="list-item-subtitle">Suivez vos performances</div>
            </div>
        </div>
    </div>
}

@code {
    private UserProfile? userProfile;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsAuthenticated)
        {
            try
            {
                userProfile = await ProfileService.GetProfileAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading profile: {ex.Message}");
            }
        }
    }

    private string GetDisplayName()
    {
        if (userProfile != null && !string.IsNullOrEmpty(userProfile.DisplayName))
        {
            return userProfile.DisplayName;
        }
        return AuthService.CurrentUser?.Email ?? "Pêcheur";
    }
}
