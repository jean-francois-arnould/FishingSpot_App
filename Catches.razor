@page "/catches"
@page "/FishingSpot_App/catches"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@using Microsoft.JSInterop
@inject ISupabaseService SupabaseService
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Mes Prises</PageTitle>

<AuthorizeView>
    <div class="page-content">
        @if (isLoading)
        {
            <div class="empty-state">
                <div class="spinner"></div>
                <p class="mt-3">Chargement des prises...</p>
            </div>
        }
        else if (catches == null || !catches.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">🐟</div>
                <h3>Aucune prise enregistrée</h3>
                <p class="text-muted">Commencez par ajouter votre première prise de pêche !</p>
                <button class="btn btn-primary" @onclick="NavigateToAddCatch">
                    ➕ Ajouter une prise
                </button>
            </div>
        }
        else
        {
            <div class="catch-list">
                @foreach (var fishCatch in catches)
                {
                    <div class="list-item" @onclick="() => NavigateToCatchDetail(fishCatch.Id)">
                        @if (!string.IsNullOrEmpty(fishCatch.PhotoUrl))
                        {
                            <img src="@fishCatch.PhotoUrl" alt="@fishCatch.FishName" class="list-item-img" />
                        }
                        else
                        {
                            <div class="list-item-icon">🐟</div>
                        }
                        <div class="list-item-content">
                            <div class="list-item-title">@fishCatch.FishName</div>
                            <div class="list-item-subtitle">
                                📍 @fishCatch.LocationName
                            </div>
                            <div class="list-item-meta">
                                <span class="badge badge-info">@fishCatch.Length cm</span>
                                <span class="badge badge-info">@fishCatch.Weight kg</span>
                                <span class="badge badge-secondary">@fishCatch.CatchDate.ToShortDateString()</span>
                            </div>
                        </div>
                        <div class="list-item-action">›</div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Floating Action Button -->
    <button class="fab" @onclick="NavigateToAddCatch" title="Ajouter une prise">
        <span class="fab-icon">+</span>
    </button>
</AuthorizeView>

@code {
    private List<FishCatch>? catches;
    private UserProfile? userProfile;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        await LoadCatches();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Rafraîchir lors du retour à la page
            await JSRuntime.InvokeVoidAsync("window.addEventListener", "focus", 
                DotNetObjectReference.Create(this), "RefreshCatches");
        }
    }

    [JSInvokable]
    public async Task RefreshCatches()
    {
        Console.WriteLine("🔄 Rafraîchissement des prises...");
        await LoadCatches();
        StateHasChanged();
    }

    private async Task LoadCatches()
    {
        isLoading = true;
        try
        {
            // Charger le profil et les prises en parallèle
            var profileTask = ProfileService.GetProfileAsync();
            var catchesTask = SupabaseService.GetAllCatchesAsync();

            await Task.WhenAll(profileTask, catchesTask);

            userProfile = await profileTask;
            catches = await catchesTask;

            Console.WriteLine($"✅ {catches.Count} prises chargées");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            catches = new List<FishCatch>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/FishingSpot_App/");
    }

    private void NavigateToAddCatch()
    {
        Navigation.NavigateTo("/FishingSpot_App/catches/add");
    }

    private void NavigateToCatchDetail(int catchId)
    {
        Navigation.NavigateTo($"/FishingSpot_App/catches/{catchId}");
    }

    private void NavigateToEditCatch(int catchId)
    {
        Navigation.NavigateTo($"/FishingSpot_App/edit-catch/{catchId}");
    }
}
