@page "/catches"
@page "/FishingSpot_App/catches"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@inject ISupabaseService SupabaseService
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject NavigationManager Navigation

<PageTitle>My Catches</PageTitle>

<AuthorizeView>
    <div class="container-fluid">
        <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">🎣 FishingSpot</a>
                <div class="navbar-nav me-auto">
                    <a class="nav-link active" href="/catches">Mes Prises</a>
                    <a class="nav-link" href="/montages">Montages</a>
                    <a class="nav-link" href="/materiel">Matériel</a>
                    <a class="nav-link" href="/profile">Profil</a>
                </div>
                <div class="d-flex">
                    <span class="navbar-text me-3">
                        👋 @(userProfile != null && !string.IsNullOrEmpty(userProfile.FirstName) 
                            ? $"{userProfile.FirstName} {userProfile.LastName}" 
                            : AuthService.CurrentUser?.Email)
                    </span>
                    <button class="btn btn-outline-danger btn-sm" @onclick="HandleLogout">
                        Déconnexion
                    </button>
                </div>
            </div>
        </nav>

        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>🎣 My Fishing Catches</h1>
                <button class="btn btn-primary btn-lg" @onclick="NavigateToAddCatch">
                    ➕ Add New Catch
                </button>
            </div>

            @if (isLoading)
            {
                <div class="text-center my-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2">Loading catches...</p>
                </div>
            }
            else if (catches == null || !catches.Any())
            {
                <div class="alert alert-info text-center my-5">
                    <h4>No catches recorded yet. Start fishing! 🐟</h4>
                    <p>Click the "Add New Catch" button above to record your first catch!</p>
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var fishCatch in catches)
                    {
                        <div class="col-md-4 mb-3">
                            <div class="card h-100">
                                @if (!string.IsNullOrEmpty(fishCatch.PhotoUrl))
                                {
                                    <img src="@fishCatch.PhotoUrl" class="card-img-top" alt="@fishCatch.FishName" style="max-height: 200px; object-fit: cover;" />
                                }
                                <div class="card-body">
                                    <h5 class="card-title">🐟 @fishCatch.FishName</h5>
                                    <p class="card-text">
                                        <strong>📅 Date:</strong> @fishCatch.CatchDate.ToShortDateString()<br />
                                        <strong>📍 Location:</strong> @fishCatch.LocationName<br />
                                        <strong>📏 Length:</strong> @fishCatch.Length cm<br />
                                        <strong>⚖️ Weight:</strong> @fishCatch.Weight kg
                                    </p>
                                    @if (!string.IsNullOrEmpty(fishCatch.Notes))
                                    {
                                        <p class="card-text"><small class="text-muted">💭 @fishCatch.Notes</small></p>
                                    }
                                </div>
                                <div class="card-footer">
                                    <button class="btn btn-sm btn-outline-primary w-100" @onclick="() => NavigateToEditCatch(fishCatch.Id)">
                                        ✏️ Edit Catch
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</AuthorizeView>

@code {
    private List<FishCatch>? catches;
    private UserProfile? userProfile;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        try
        {
            // Charger le profil et les prises en parallèle
            var profileTask = ProfileService.GetProfileAsync();
            var catchesTask = SupabaseService.GetAllCatchesAsync();

            await Task.WhenAll(profileTask, catchesTask);

            userProfile = await profileTask;
            catches = await catchesTask;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            catches = new List<FishCatch>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/FishingSpot_App/");
    }

    private void NavigateToAddCatch()
    {
        Navigation.NavigateTo("/FishingSpot_App/catches/add");
    }

    private void NavigateToEditCatch(int catchId)
    {
        Navigation.NavigateTo($"/FishingSpot_App/catches/edit/{catchId}");
    }
}
