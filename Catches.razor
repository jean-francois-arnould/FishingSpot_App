@page "/catches"
@page "/FishingSpot_App/catches"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@using Microsoft.JSInterop
@inject ISupabaseService SupabaseService
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Mes Prises</PageTitle>

<AuthorizeView>
    <div class="page-content">
        @if (isLoading)
        {
            <div class="empty-state">
                <div class="spinner"></div>
                <p class="mt-3">Chargement des prises...</p>
            </div>
        }
        else if (catches == null || !catches.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">🐟</div>
                <h3>Aucune prise enregistrée</h3>
                <p class="text-muted">Commencez par ajouter votre première prise de pêche !</p>
                <button class="btn btn-primary" @onclick="NavigateToAddCatch">
                    ➕ Ajouter une prise
                </button>
            </div>
        }
        else
        {
            <div class="catch-list">
                @foreach (var fishCatch in catches)
                {
                    <div class="swipeable-item @(swipedItemId == fishCatch.Id ? "swiped" : "")" 
                         @ontouchstart="@((args) => HandleTouchStart(args, fishCatch.Id))"
                         @ontouchmove="@((args) => HandleTouchMove(args))"
                         @ontouchend="@((args) => HandleTouchEnd(args))">

                        <div class="swipe-content" @onclick="() => NavigateToCatchDetail(fishCatch.Id)">
                            @if (!string.IsNullOrEmpty(fishCatch.PhotoUrl))
                            {
                                <img src="@fishCatch.PhotoUrl" alt="@fishCatch.FishName" class="list-item-img" />
                            }
                            else
                            {
                                <div class="list-item-icon">🐟</div>
                            }
                            <div class="list-item-content">
                                <div class="list-item-title">@fishCatch.FishName</div>
                                <div class="list-item-subtitle">
                                    📍 @fishCatch.LocationName
                                </div>
                                <div class="list-item-meta">
                                    <span class="badge badge-info">@fishCatch.Length cm</span>
                                    <span class="badge badge-info">@fishCatch.Weight kg</span>
                                    <span class="badge badge-secondary">@fishCatch.CatchDate.ToShortDateString()</span>
                                </div>
                            </div>
                            <div class="list-item-action">›</div>
                        </div>

                        <div class="swipe-delete" @onclick="() => ShowDeleteConfirmation(fishCatch)">
                            <span class="delete-icon">🗑️</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Floating Action Button -->
    <button class="fab" @onclick="NavigateToAddCatch" title="Ajouter une prise">
        <span class="fab-icon">+</span>
    </button>
</AuthorizeView>

<!-- Modale de confirmation de suppression -->
@if (showDeleteModal && catchToDelete != null)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>⚠️ Confirmer la suppression</h3>
            </div>
            <div class="modal-body">
                <p>Êtes-vous sûr de vouloir supprimer cette prise ?</p>
                <p><strong>@catchToDelete.FishName</strong></p>
                <p class="text-muted">@catchToDelete.LocationName - @catchToDelete.CatchDate.ToShortDateString()</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">
                    Annuler
                </button>
                <button type="button" class="btn btn-danger" @onclick="ConfirmDelete" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <div class="spinner"></div>
                    }
                    Supprimer
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<FishCatch>? catches;
    private UserProfile? userProfile;
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private bool isDeleting = false;
    private FishCatch? catchToDelete = null;

    // Pour le swipe
    private int? swipedItemId = null;
    private double touchStartX = 0;
    private double touchCurrentX = 0;
    private int? touchingItemId = null;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        await LoadCatches();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Rafraîchir lors du retour à la page
            await JSRuntime.InvokeVoidAsync("window.addEventListener", "focus", 
                DotNetObjectReference.Create(this), "RefreshCatches");
        }
    }

    [JSInvokable]
    public async Task RefreshCatches()
    {
        Console.WriteLine("🔄 Rafraîchissement des prises...");
        await LoadCatches();
        StateHasChanged();
    }

    private async Task LoadCatches()
    {
        isLoading = true;
        try
        {
            // Charger le profil et les prises en parallèle
            var profileTask = ProfileService.GetProfileAsync();
            var catchesTask = SupabaseService.GetAllCatchesAsync();

            await Task.WhenAll(profileTask, catchesTask);

            userProfile = await profileTask;
            catches = await catchesTask;

            Console.WriteLine($"✅ {catches.Count} prises chargées");
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Console.WriteLine($"⚠️ Token expiré - Redirection vers login");
            await AuthService.SignOutAsync();
            Navigation.NavigateTo("/FishingSpot_App/login");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            catches = new List<FishCatch>();

            if (ex.Message.Contains("401") || ex.Message.Contains("Unauthorized") || ex.Message.Contains("auth"))
            {
                Console.WriteLine($"⚠️ Erreur d'authentification détectée - Redirection vers login");
                await AuthService.SignOutAsync();
                Navigation.NavigateTo("/FishingSpot_App/login");
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/FishingSpot_App/");
    }

    private void NavigateToAddCatch()
    {
        Navigation.NavigateTo("/FishingSpot_App/catches/add");
    }

    private void NavigateToCatchDetail(int catchId)
    {
        // Ne pas naviguer si on est en train de swiper
        if (swipedItemId == null)
        {
            Navigation.NavigateTo($"/FishingSpot_App/catches/{catchId}");
        }
    }

    private void NavigateToEditCatch(int catchId)
    {
        Navigation.NavigateTo($"/FishingSpot_App/edit-catch/{catchId}");
    }

    // Gestion du swipe
    private void HandleTouchStart(TouchEventArgs e, int catchId)
    {
        if (e.Touches.Length > 0)
        {
            touchStartX = e.Touches[0].ClientX;
            touchCurrentX = touchStartX;
            touchingItemId = catchId;
        }
    }

    private void HandleTouchMove(TouchEventArgs e)
    {
        if (e.Touches.Length > 0 && touchingItemId.HasValue)
        {
            touchCurrentX = e.Touches[0].ClientX;
            double deltaX = touchStartX - touchCurrentX;

            // Swipe vers la gauche et assez loin (au moins 50px)
            if (deltaX > 50)
            {
                swipedItemId = touchingItemId;
                StateHasChanged();
            }
            // Swipe vers la droite pour fermer
            else if (deltaX < -20 && swipedItemId == touchingItemId)
            {
                swipedItemId = null;
                StateHasChanged();
            }
        }
    }

    private void HandleTouchEnd(TouchEventArgs e)
    {
        touchingItemId = null;
    }

    private void ShowDeleteConfirmation(FishCatch fishCatch)
    {
        catchToDelete = fishCatch;
        showDeleteModal = true;
        swipedItemId = null; // Fermer le swipe
    }

    private void CancelDelete()
    {
        catchToDelete = null;
        showDeleteModal = false;
    }

    private async Task ConfirmDelete()
    {
        if (catchToDelete == null) return;

        isDeleting = true;
        try
        {
            var success = await SupabaseService.DeleteCatchAsync(catchToDelete.Id);
            if (success)
            {
                Console.WriteLine($"✅ Prise {catchToDelete.Id} supprimée");
                showDeleteModal = false;
                catchToDelete = null;
                await LoadCatches(); // Recharger la liste
            }
            else
            {
                Console.WriteLine("❌ Erreur lors de la suppression");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Erreur: {ex.Message}");
        }
        finally
        {
            isDeleting = false;
        }
    }
}
