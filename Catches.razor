@page "/catches"
@page "/FishingSpot_App/catches"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@using FishingSpot.PWA.Components.Shared
@using Microsoft.JSInterop
@inject ISupabaseService SupabaseService
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Mes Prises</PageTitle>

<AuthorizeView>
    <div class="page-content">
        @if (isLoading)
        {
            <div class="empty-state">
                <div class="spinner"></div>
                <p class="mt-3">Chargement des prises...</p>
            </div>
        }
        else if (catches == null || !catches.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">🐟</div>
                <h3>Aucune prise enregistrée</h3>
                <p class="text-muted">Commencez par ajouter votre première prise de pêche !</p>
            </div>
        }
        else
        {
            <!-- Section de filtres -->
            <div class="filters-section">
                <div class="filters-header" @onclick="ToggleFilters">
                    <h3>🔍 Filtres</h3>
                    <span class="toggle-icon">@(showFilters ? "▼" : "▶")</span>
                </div>

                @if (showFilters)
                {
                    <div class="filters-content">
                        <div class="filter-group">
                            <label class="filter-label">📅 Période</label>
                            <select class="form-control" @bind="selectedPeriod" @bind:after="ApplyFilters">
                                <option value="all">Toutes les dates</option>
                                <option value="today">Aujourd'hui</option>
                                <option value="week">Cette semaine</option>
                                <option value="month">Ce mois-ci</option>
                                <option value="year">Cette année</option>
                                <option value="custom">Période personnalisée</option>
                            </select>
                        </div>

                        @if (selectedPeriod == "custom")
                        {
                            <div class="filter-row">
                                <div class="filter-group">
                                    <label class="filter-label">Du</label>
                                    <input type="date" class="form-control" @bind="filterDateFrom" @bind:after="ApplyFilters" />
                                </div>
                                <div class="filter-group">
                                    <label class="filter-label">Au</label>
                                    <input type="date" class="form-control" @bind="filterDateTo" @bind:after="ApplyFilters" />
                                </div>
                            </div>
                        }

                        <div class="filter-group">
                            <label class="filter-label">🐟 Espèce</label>
                            <select class="form-control" @bind="selectedFishName" @bind:after="ApplyFilters">
                                <option value="">Toutes les espèces</option>
                                @foreach (var fishName in availableFishNames)
                                {
                                    <option value="@fishName">@fishName</option>
                                }
                            </select>
                        </div>

                        @if (IsAnyFilterActive())
                        {
                            <button class="btn btn-outline-secondary btn-block" @onclick="ResetFilters">
                                ↺ Réinitialiser les filtres
                            </button>
                        }

                        <div class="filter-results">
                            @if (filteredCatches.Count != catches.Count)
                            {
                                <small class="text-muted">
                                    @filteredCatches.Count prise(s) sur @catches.Count
                                </small>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Liste des prises filtrées -->
            @if (!filteredCatches.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon">🔍</div>
                    <h3>Aucune prise trouvée</h3>
                    <p class="text-muted">Aucune prise ne correspond aux filtres sélectionnés.</p>
                    <button class="btn btn-outline-primary" @onclick="ResetFilters">
                        Réinitialiser les filtres
                    </button>
                </div>
            }
            else
            {
                <div class="catch-list">
                    @foreach (var fishCatch in filteredCatches)
                    {
                        <div class="swipeable-item @(swipedItemId == fishCatch.Id ? "swiped" : "")" 
                             @ontouchstart="@((args) => HandleTouchStart(args, fishCatch.Id))"
                             @ontouchmove="@((args) => HandleTouchMove(args))"
                             @ontouchend="@((args) => HandleTouchEnd(args))">

                            <div class="swipe-content" @onclick="() => NavigateToCatchDetail(fishCatch.Id)">
                                @if (!string.IsNullOrEmpty(fishCatch.PhotoUrl))
                                {
                                    <img src="@fishCatch.PhotoUrl" alt="@fishCatch.FishName" class="list-item-img" />
                                }
                                else
                                {
                                    <div class="list-item-icon">🐟</div>
                                }
                                <div class="list-item-content">
                                    <div class="list-item-title">@fishCatch.FishName</div>
                                    <div class="list-item-subtitle">
                                        📍 @fishCatch.LocationName
                                    </div>
                                    <div class="list-item-meta">
                                        <span class="badge badge-info">@fishCatch.Length cm</span>
                                        <span class="badge badge-info">@fishCatch.Weight kg</span>
                                        <span class="badge badge-secondary">@fishCatch.CatchDate.ToShortDateString()</span>
                                    </div>
                                </div>
                                <div class="list-item-action">›</div>
                            </div>

                            <div class="swipe-delete" @onclick="() => ShowDeleteConfirmation(fishCatch)">
                                <span class="delete-icon">🗑️</span>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>

    <!-- Floating Action Button -->
    <button class="fab" @onclick="NavigateToAddCatch" title="Ajouter une prise">
        <span class="fab-icon">+</span>
    </button>
</AuthorizeView>

<!-- Popup de confirmation de suppression stylée -->
<ConfirmationModal IsVisible="@showDeleteModal"
                   Icon="🗑️"
                   Title="Supprimer cette prise ?"
                   Message="Cette action est irréversible. La prise sera définitivement supprimée."
                   DetailLine1="@(catchToDelete?.FishName)"
                   DetailLine2="@(catchToDelete != null ? $"{catchToDelete.LocationName} - {catchToDelete.CatchDate.ToShortDateString()}" : "")"
                   CancelText="Annuler"
                   ConfirmText="🗑️ Supprimer"
                   ConfirmButtonClass="danger"
                   IsProcessing="@isDeleting"
                   OnConfirm="ConfirmDelete"
                   OnCancel="CancelDelete" />

@code {
    private List<FishCatch>? catches;
    private List<FishCatch> filteredCatches = new();
    private List<string> availableFishNames = new();
    private UserProfile? userProfile;
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private bool isDeleting = false;
    private FishCatch? catchToDelete = null;

    // Filtres
    private bool showFilters = false;
    private string selectedPeriod = "all";
    private string selectedFishName = "";
    private DateTime? filterDateFrom = null;
    private DateTime? filterDateTo = null;

    // Pour le swipe
    private int? swipedItemId = null;
    private double touchStartX = 0;
    private double touchCurrentX = 0;
    private int? touchingItemId = null;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        await LoadCatches();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Rafraîchir lors du retour à la page
            await JSRuntime.InvokeVoidAsync("window.addEventListener", "focus", 
                DotNetObjectReference.Create(this), "RefreshCatches");
        }
    }

    [JSInvokable]
    public async Task RefreshCatches()
    {
        Console.WriteLine("🔄 Rafraîchissement des prises...");
        await LoadCatches();
        StateHasChanged();
    }

    private async Task LoadCatches()
    {
        isLoading = true;
        try
        {
            // Charger le profil et les prises en parallèle
            var profileTask = ProfileService.GetProfileAsync();
            var catchesTask = SupabaseService.GetAllCatchesAsync();

            await Task.WhenAll(profileTask, catchesTask);

            userProfile = await profileTask;
            catches = await catchesTask;

            Console.WriteLine($"✅ {catches.Count} prises chargées");

            // Extraire les noms de poissons uniques
            availableFishNames = catches
                .Select(c => c.FishName)
                .Distinct()
                .OrderBy(name => name)
                .ToList();

            // Appliquer les filtres
            ApplyFilters();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Console.WriteLine($"⚠️ Token expiré - Redirection vers login");
            await AuthService.SignOutAsync();
            Navigation.NavigateTo("/FishingSpot_App/login");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            catches = new List<FishCatch>();
            filteredCatches = new List<FishCatch>();

            if (ex.Message.Contains("401") || ex.Message.Contains("Unauthorized") || ex.Message.Contains("auth"))
            {
                Console.WriteLine($"⚠️ Erreur d'authentification détectée - Redirection vers login");
                await AuthService.SignOutAsync();
                Navigation.NavigateTo("/FishingSpot_App/login");
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleFilters()
    {
        showFilters = !showFilters;
    }

    private void ApplyFilters()
    {
        if (catches == null || !catches.Any())
        {
            filteredCatches = new List<FishCatch>();
            return;
        }

        var query = catches.AsEnumerable();

        // Filtre par période
        switch (selectedPeriod)
        {
            case "today":
                query = query.Where(c => c.CatchDate.Date == DateTime.Today);
                break;
            case "week":
                var startOfWeek = DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + (int)DayOfWeek.Monday);
                query = query.Where(c => c.CatchDate.Date >= startOfWeek);
                break;
            case "month":
                var startOfMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
                query = query.Where(c => c.CatchDate.Date >= startOfMonth);
                break;
            case "year":
                var startOfYear = new DateTime(DateTime.Today.Year, 1, 1);
                query = query.Where(c => c.CatchDate.Date >= startOfYear);
                break;
            case "custom":
                if (filterDateFrom.HasValue)
                {
                    query = query.Where(c => c.CatchDate.Date >= filterDateFrom.Value.Date);
                }
                if (filterDateTo.HasValue)
                {
                    query = query.Where(c => c.CatchDate.Date <= filterDateTo.Value.Date);
                }
                break;
        }

        // Filtre par nom de poisson
        if (!string.IsNullOrEmpty(selectedFishName))
        {
            query = query.Where(c => c.FishName.Equals(selectedFishName, StringComparison.OrdinalIgnoreCase));
        }

        filteredCatches = query.OrderByDescending(c => c.CatchDate).ToList();
        Console.WriteLine($"🔍 Filtres appliqués: {filteredCatches.Count} prises affichées sur {catches.Count}");
    }

    private void ResetFilters()
    {
        selectedPeriod = "all";
        selectedFishName = "";
        filterDateFrom = null;
        filterDateTo = null;
        ApplyFilters();
    }

    private bool IsAnyFilterActive()
    {
        return selectedPeriod != "all" || !string.IsNullOrEmpty(selectedFishName);
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/FishingSpot_App/");
    }

    private void NavigateToAddCatch()
    {
        Navigation.NavigateTo("/FishingSpot_App/catches/add");
    }

    private void NavigateToCatchDetail(int catchId)
    {
        // Ne pas naviguer si on est en train de swiper
        if (swipedItemId == null)
        {
            Navigation.NavigateTo($"/FishingSpot_App/catches/{catchId}");
        }
    }

    private void NavigateToEditCatch(int catchId)
    {
        Navigation.NavigateTo($"/FishingSpot_App/edit-catch/{catchId}");
    }

    // Gestion du swipe
    private void HandleTouchStart(TouchEventArgs e, int catchId)
    {
        if (e.Touches.Length > 0)
        {
            touchStartX = e.Touches[0].ClientX;
            touchCurrentX = touchStartX;
            touchingItemId = catchId;
        }
    }

    private void HandleTouchMove(TouchEventArgs e)
    {
        if (e.Touches.Length > 0 && touchingItemId.HasValue)
        {
            touchCurrentX = e.Touches[0].ClientX;
            double deltaX = touchStartX - touchCurrentX;

            // Swipe vers la gauche et assez loin (au moins 50px)
            if (deltaX > 50)
            {
                swipedItemId = touchingItemId;
                StateHasChanged();
            }
            // Swipe vers la droite pour fermer
            else if (deltaX < -20 && swipedItemId == touchingItemId)
            {
                swipedItemId = null;
                StateHasChanged();
            }
        }
    }

    private void HandleTouchEnd(TouchEventArgs e)
    {
        touchingItemId = null;
    }

    private void ShowDeleteConfirmation(FishCatch fishCatch)
    {
        catchToDelete = fishCatch;
        showDeleteModal = true;
        swipedItemId = null; // Fermer le swipe
    }

    private void CancelDelete()
    {
        catchToDelete = null;
        showDeleteModal = false;
    }

    private async Task ConfirmDelete()
    {
        if (catchToDelete == null) return;

        isDeleting = true;
        try
        {
            var success = await SupabaseService.DeleteCatchAsync(catchToDelete.Id);
            if (success)
            {
                Console.WriteLine($"✅ Prise {catchToDelete.Id} supprimée");
                showDeleteModal = false;
                catchToDelete = null;
                await LoadCatches(); // Recharger la liste
            }
            else
            {
                Console.WriteLine("❌ Erreur lors de la suppression");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Erreur: {ex.Message}");
        }
        finally
        {
            isDeleting = false;
        }
    }
}
