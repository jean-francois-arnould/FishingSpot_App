@inherits LayoutComponentBase
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

@if (_initialized)
{
    <div class="app-container">
        <!-- Top Bar -->
        <div class="top-bar">
            <div class="top-bar-title">
                <span>🎣</span>
                <span>FishingSpot</span>
            </div>
        </div>

        <!-- Main Content -->
        <main class="content">
            @Body
        </main>

        <!-- Burger Menu Overlay -->
        @if (AuthService.IsAuthenticated && isMenuOpen)
        {
            <div class="menu-overlay" @onclick="CloseMenu"></div>
        }

        <!-- Burger Menu Sidebar -->
        @if (AuthService.IsAuthenticated)
        {
            <div class="burger-menu @(isMenuOpen ? "open" : "")">
                <div class="burger-menu-header">
                    <div class="burger-menu-title">
                        <span>🎣</span>
                        <span>Menu</span>
                    </div>
                    <button class="menu-close-btn" @onclick="CloseMenu">✕</button>
                </div>

                <nav class="burger-menu-nav">
                    <a href="/FishingSpot_App/" class="burger-menu-item @(IsActive("/FishingSpot_App/") && !IsActive("/FishingSpot_App/catches") && !IsActive("/FishingSpot_App/statistiques") ? "active" : "")" @onclick="CloseMenu">
                        <span class="burger-menu-icon">🏠</span>
                        <span class="burger-menu-label">Accueil</span>
                    </a>

                    <a href="/FishingSpot_App/catches" class="burger-menu-item @(IsActive("/FishingSpot_App/catches") ? "active" : "")" @onclick="CloseMenu">
                        <span class="burger-menu-icon">🐟</span>
                        <span class="burger-menu-label">Mes Prises</span>
                    </a>

                    <a href="/FishingSpot_App/statistiques" class="burger-menu-item @(IsActive("/FishingSpot_App/statistiques") ? "active" : "")" @onclick="CloseMenu">
                        <span class="burger-menu-icon">📊</span>
                        <span class="burger-menu-label">Statistiques</span>
                    </a>

                    <a href="/FishingSpot_App/carte" class="burger-menu-item @(IsActive("/FishingSpot_App/carte") ? "active" : "")" @onclick="CloseMenu">
                        <span class="burger-menu-icon">🗺️</span>
                        <span class="burger-menu-label">Carte Géopêche</span>
                    </a>

                    <div class="burger-menu-divider"></div>

                    <a href="/FishingSpot_App/materiel" class="burger-menu-item @(IsActive("/FishingSpot_App/materiel") ? "active" : "")" @onclick="CloseMenu">
                        <span class="burger-menu-icon">🎣</span>
                        <span class="burger-menu-label">Mon Matériel</span>
                    </a>

                    <a href="/FishingSpot_App/montages" class="burger-menu-item @(IsActive("/FishingSpot_App/montages") ? "active" : "")" @onclick="CloseMenu">
                        <span class="burger-menu-icon">🪝</span>
                        <span class="burger-menu-label">Mes Montages</span>
                    </a>

                    <div class="burger-menu-divider"></div>

                    <a href="/FishingSpot_App/profile" class="burger-menu-item @(IsActive("/FishingSpot_App/profile") ? "active" : "")" @onclick="CloseMenu">
                        <span class="burger-menu-icon">👤</span>
                        <span class="burger-menu-label">Mon Profil</span>
                    </a>

                    <button class="burger-menu-item burger-menu-logout" @onclick="HandleLogoutFromMenu">
                        <span class="burger-menu-icon">🚪</span>
                        <span class="burger-menu-label">Déconnexion</span>
                    </button>
                </nav>
            </div>
        }

        <!-- Bottom Navigation (Simplified) -->
        @if (AuthService.IsAuthenticated)
        {
            <nav class="bottom-nav">
                <a href="/FishingSpot_App/" class="bottom-nav-item @(IsActive("/FishingSpot_App/") && !IsActive("/FishingSpot_App/catches") && !IsActive("/FishingSpot_App/statistiques") ? "active" : "")">
                    <div class="bottom-nav-icon">🏠</div>
                    <div class="bottom-nav-label">Accueil</div>
                </a>

                <a href="/FishingSpot_App/catches" class="bottom-nav-item @(IsActive("/FishingSpot_App/catches") ? "active" : "")">
                    <div class="bottom-nav-icon">🐟</div>
                    <div class="bottom-nav-label">Prises</div>
                </a>

                <a href="/FishingSpot_App/statistiques" class="bottom-nav-item @(IsActive("/FishingSpot_App/statistiques") ? "active" : "")">
                    <div class="bottom-nav-icon">📊</div>
                    <div class="bottom-nav-label">Stats</div>
                </a>

                <button class="bottom-nav-item @(isMenuOpen ? "active" : "")" @onclick="ToggleMenu">
                    <div class="bottom-nav-icon">☰</div>
                    <div class="bottom-nav-label">Menu</div>
                </button>
            </nav>
        }
    </div>
}
else
{
    <div class="loading-overlay">
        <div class="spinner"></div>
    </div>
}

@code {
    private bool _initialized = false;
    private string currentUrl = "";
    private bool isMenuOpen = false;

    protected override async Task OnInitializedAsync()
    {
        await AuthService.InitializeAsync();
        _initialized = true;
        currentUrl = Navigation.Uri;
        Navigation.LocationChanged += OnLocationChanged;
        AuthService.OnAuthStateChanged += OnAuthChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        currentUrl = e.Location;
        isMenuOpen = false; // Close menu on navigation
        StateHasChanged();
    }

    private void OnAuthChanged(Models.User? user)
    {
        StateHasChanged();
    }

    private bool IsActive(string path)
    {
        return currentUrl.Contains(path);
    }

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    private void CloseMenu()
    {
        isMenuOpen = false;
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/FishingSpot_App/", forceLoad: true);
    }

    private async Task HandleLogoutFromMenu()
    {
        CloseMenu();
        await HandleLogout();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        AuthService.OnAuthStateChanged -= OnAuthChanged;
    }
}
