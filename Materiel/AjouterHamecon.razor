
@page "/materiel/hamecons/ajouter"
@page "/FishingSpot_App/materiel/hamecons/ajouter"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject IEquipmentService EquipmentService
@inject ISupabaseService SupabaseService
@inject NavigationManager Navigation

<h3 class="mb-4">🪝 Ajouter un Hameçon</h3>

<EditForm Model="@newHook" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="size" class="form-label">Taille *</label>
        <InputText id="size" class="form-control" @bind-Value="newHook.Size" required />
        <small class="form-text text-muted">Ex: 1/0, 2, 4, 6, 8, 10</small>
    </div>

    <div class="mb-3">
        <label for="type" class="form-label">Type</label>
        <InputText id="type" class="form-control" @bind-Value="newHook.Type" />
        <small class="form-text text-muted">Ex: J Hook, Circle, Treble, Octopus</small>
    </div>

    <div class="mb-3">
        <label for="brand" class="form-label">Marque</label>
        <div class="fish-species-readonly">
            <input type="text" 
                   id="brand" 
                   class="form-control" 
                   value="@GetBrandDisplayValue()" 
                   placeholder="Sélectionner une marque..." 
                   readonly />
        </div>
        <div class="fish-species-buttons">
            @if (availableBrands != null && availableBrands.Any())
            {
                <button type="button" class="btn btn-primary" @onclick="ShowBrandsList">
                    🔍 Chercher dans la liste
                </button>
            }
            <button type="button" class="btn btn-success" @onclick="ShowAddBrandForm">
                ➕ Ajouter une nouvelle marque
            </button>
        </div>
    </div>

    <div class="mb-3">
        <label for="notes" class="form-label">Notes</label>
        <InputTextArea id="notes" class="form-control" @bind-Value="newHook.Notes" rows="3" />
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <div class="mt-3">
        <button type="submit" class="btn btn-success" disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            }
            <i class="bi bi-check-circle"></i> Enregistrer
        </button>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">
            <i class="bi bi-x-circle"></i> Annuler
        </button>
    </div>
</EditForm>

@* Modal pour afficher la liste des marques *@
@if (showBrandsModal && availableBrands != null)
{
    <div class="modal-backdrop" @onclick="HideBrandsModal"></div>
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">🔍 Sélectionner une marque</h3>
                <button type="button" class="btn-close" @onclick="HideBrandsModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="fish-list">
                    @foreach (var brand in availableBrands)
                    {
                        <button type="button" class="fish-item" @onclick="() => SelectBrand(brand)">
                            <div class="fish-info">
                                <div class="fish-name">@brand.Name</div>
                            </div>
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* Modal pour ajouter une nouvelle marque *@
@if (showAddBrandModal)
{
    <div class="modal-backdrop" @onclick="HideAddBrandModal"></div>
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">➕ Ajouter une nouvelle marque</h3>
                <button type="button" class="btn-close" @onclick="HideAddBrandModal">✕</button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(addBrandError))
                {
                    <div class="alert alert-danger">@addBrandError</div>
                }
                @if (!string.IsNullOrEmpty(addBrandSuccess))
                {
                    <div class="alert alert-success">@addBrandSuccess</div>
                }

                <EditForm Model="@newBrand" OnValidSubmit="HandleAddBrand">
                    <div class="form-group">
                        <label class="form-label">Nom de la marque *</label>
                        <InputText class="form-control" @bind-Value="newBrand.Name" 
                                   placeholder="Ex: Owner, Gamakatsu" required />
                    </div>

                    <div class="modal-actions">
                        <button type="button" class="btn btn-outline-secondary" @onclick="HideAddBrandModal">
                            Annuler
                        </button>
                        <button type="submit" class="btn btn-primary" disabled="@isAddingBrand">
                            @if (isAddingBrand)
                            {
                                <div class="spinner"></div>
                            }
                            ✅ Ajouter
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private Hook newHook = new();
    private FishingBrand newBrand = new FishingBrand { Category = BrandCategory.Hook };
    private List<FishingBrand>? availableBrands;
    private bool isSubmitting = false;
    private bool isAddingBrand = false;
    private bool showBrandsModal = false;
    private bool showAddBrandModal = false;
    private string? errorMessage;
    private string? successMessage;
    private string? addBrandError;
    private string? addBrandSuccess;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            availableBrands = await SupabaseService.GetBrandsByCategoryAsync(BrandCategory.Hook);
            Console.WriteLine($"✅ Loaded {availableBrands.Count} hook brands");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading brands: {ex.Message}");
        }
    }

    private string GetBrandDisplayValue()
    {
        return string.IsNullOrEmpty(newHook.Brand) ? "" : newHook.Brand;
    }

    private void ShowBrandsList()
    {
        showBrandsModal = true;
    }

    private void HideBrandsModal()
    {
        showBrandsModal = false;
    }

    private void SelectBrand(FishingBrand brand)
    {
        newHook.Brand = brand.Name;
        showBrandsModal = false;
    }

    private void ShowAddBrandForm()
    {
        newBrand = new FishingBrand { Category = BrandCategory.Hook };
        addBrandError = null;
        addBrandSuccess = null;
        showAddBrandModal = true;
    }

    private void HideAddBrandModal()
    {
        showAddBrandModal = false;
        newBrand = new FishingBrand { Category = BrandCategory.Hook };
        addBrandError = null;
        addBrandSuccess = null;
    }

    private async Task HandleAddBrand()
    {
        addBrandError = null;
        addBrandSuccess = null;
        isAddingBrand = true;

        try
        {
            if (string.IsNullOrWhiteSpace(newBrand.Name))
            {
                addBrandError = "Le nom de la marque est requis.";
                isAddingBrand = false;
                return;
            }

            Console.WriteLine($"Attempting to add brand: {newBrand.Name}");
            var brandId = await SupabaseService.AddFishingBrandAsync(newBrand);

            if (brandId == -1)
            {
                addBrandError = $"❌ La marque '{newBrand.Name}' existe déjà dans la base de données.";
                isAddingBrand = false;
                return;
            }

            if (brandId > 0)
            {
                addBrandSuccess = $"✅ La marque '{newBrand.Name}' a été ajoutée avec succès !";
                Console.WriteLine($"Brand added with ID: {brandId}");

                // Recharger la liste des marques
                availableBrands = await SupabaseService.GetBrandsByCategoryAsync(BrandCategory.Hook);

                // Sélectionner automatiquement la nouvelle marque
                newHook.Brand = newBrand.Name;

                // Attendre 2 secondes puis fermer le modal
                await Task.Delay(2000);
                HideAddBrandModal();
            }
            else
            {
                addBrandError = "Erreur lors de l'ajout de la marque.";
            }
        }
        catch (Exception ex)
        {
            addBrandError = $"Erreur: {ex.Message}";
            Console.WriteLine($"Error adding brand: {ex.Message}");
        }
        finally
        {
            isAddingBrand = false;
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(newHook.Size))
        {
            errorMessage = "La taille est requise.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            await EquipmentService.AddHookAsync(newHook);
            Navigation.NavigateTo("/FishingSpot_App/materiel/hamecons");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de l'ajout de l'hameçon: {ex.Message}";
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/FishingSpot_App/materiel/hamecons");
    }
}
