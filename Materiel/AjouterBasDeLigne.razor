@page "/FishingSpot_App/materiel/bas-de-ligne/ajouter"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<h3 class="mb-4">⛓️ Ajouter un Bas de Ligne</h3>

<EditForm Model="@newLeader" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="material" class="form-label">Matériau *</label>
        <InputText id="material" class="form-control" @bind-Value="newLeader.Material" required />
        <small class="form-text text-muted">Ex: Fluorocarbone, Acier, Titanium</small>
    </div>

    <div class="mb-3">
        <label for="strength" class="form-label">Résistance (ex: 30lb, 15kg)</label>
        <InputText id="strength" class="form-control" @bind-Value="newLeader.Strength" />
    </div>

    <div class="mb-3">
        <label for="length" class="form-label">Longueur (ex: 50cm, 2m)</label>
        <InputText id="length" class="form-control" @bind-Value="newLeader.Length" />
    </div>

    <div class="mb-3">
        <label for="notes" class="form-label">Notes</label>
        <InputTextArea id="notes" class="form-control" @bind-Value="newLeader.Notes" rows="3" />
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="mt-3">
        <button type="submit" class="btn btn-success" disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            }
            <i class="bi bi-check-circle"></i> Enregistrer
        </button>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">
            <i class="bi bi-x-circle"></i> Annuler
        </button>
    </div>
</EditForm>

@code {
    private Leader newLeader = new();
    private bool isSubmitting = false;
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(newLeader.Material))
        {
            errorMessage = "Le matériau est requis.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            await EquipmentService.AddLeaderAsync(newLeader);
            Navigation.NavigateTo("/materiel/bas-de-ligne");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de l'ajout du bas de ligne: {ex.Message}";
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/materiel/bas-de-ligne");
    }
}
