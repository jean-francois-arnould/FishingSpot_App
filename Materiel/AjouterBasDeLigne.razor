
@page "/materiel/bas-de-ligne/ajouter"
@page "/FishingSpot_App/materiel/bas-de-ligne/ajouter"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Ajouter un Bas de Ligne</PageTitle>

<div class="page-content">
    <a href="/FishingSpot_App/materiel/bas-de-ligne" class="btn btn-outline-secondary btn-sm mb-3">← Retour aux bas de ligne</a>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <EditForm Model="@newLeader" OnValidSubmit="HandleSubmit">
        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">⛓️ Ajouter un bas de ligne</h3>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label for="material" class="form-label">Matériau *</label>
                    <InputText id="material" class="form-control" @bind-Value="newLeader.Material" placeholder="Fluorocarbone, Acier, Titane..." required />
                    <small class="text-muted">Fluorocarbone, Nylon, Acier, Titane...</small>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="length" class="form-label">📏 Longueur (cm)</label>
                        <InputText id="length" class="form-control" @bind-Value="newLeader.Length" placeholder="50" />
                    </div>
                    <div class="form-group">
                        <label for="strength" class="form-label">💪 Résistance (kg)</label>
                        <InputText id="strength" class="form-control" @bind-Value="newLeader.Strength" placeholder="15" />
                    </div>
                </div>

                <div class="form-group">
                    <label for="notes" class="form-label">Notes</label>
                    <InputTextArea id="notes" class="form-control" rows="4" @bind-Value="newLeader.Notes" placeholder="Type de pêche, utilisation, état..." />
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">Annuler</button>
            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                @if (isSaving) { <div class="spinner"></div> }
                ✅ Enregistrer
            </button>
        </div>
    </EditForm>
</div>

@code {
    private Leader newLeader = new Leader();
    private string? errorMessage;
    private bool isSaving;

    protected override void OnInitialized()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(newLeader.Material))
        {
            errorMessage = "Le matériau est requis.";
            return;
        }

        isSaving = true;
        errorMessage = null;

        try
        {
            var leaderId = await EquipmentService.AddLeaderAsync(newLeader);
            if (leaderId > 0)
            {
                Navigation.NavigateTo("/FishingSpot_App/materiel/bas-de-ligne", forceLoad: true);
            }
            else
            {
                errorMessage = "Erreur lors de l'enregistrement du bas de ligne.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/FishingSpot_App/materiel/bas-de-ligne");
    }
}
