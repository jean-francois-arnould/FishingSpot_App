
@page "/materiel/cannes/modifier/{RodId:int}"
@page "/FishingSpot_App/materiel/cannes/modifier/{RodId:int}"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Modifier une Canne</PageTitle>

<div class="container-fluid">
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">🎣 FishingSpot</a>
            <div class="navbar-nav me-auto">
                <a class="nav-link" href="/catches">Mes Prises</a>
                <a class="nav-link" href="/montages">Montages</a>
                <a class="nav-link active" href="/materiel">Matériel</a>
                <a class="nav-link" href="/profile">Profil</a>
            </div>
            <div class="d-flex">
                <span class="navbar-text me-3">
                    👋 @AuthService.CurrentUser?.Email
                </span>
                <button class="btn btn-outline-danger btn-sm" @onclick="HandleLogout">
                    Déconnexion
                </button>
            </div>
        </div>
    </nav>

    <div class="container" style="max-width: 800px;">
        @if (isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Chargement...</span>
                </div>
                <p class="mt-2">Chargement...</p>
            </div>
        }
        else if (rod == null)
        {
            <div class="alert alert-danger">
                <h4>Canne introuvable</h4>
                <p>La canne que vous essayez de modifier n'existe pas.</p>
                <a href="/materiel/cannes" class="btn btn-primary">Retour aux cannes</a>
            </div>
        }
        else
        {
            <a href="/materiel/cannes" class="btn btn-outline-secondary btn-sm mb-3">
                ← Retour aux cannes
            </a>

            <h2>✏️ Modifier une Canne</h2>
            <p class="text-muted">@rod.Brand @rod.Model</p>

            <hr class="my-4" />

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @errorMessage
                </div>
            }

            <EditForm Model="@rod" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Informations principales</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="brand" class="form-label">Marque *</label>
                            <InputText id="brand" class="form-control" @bind-Value="rod.Brand" required />
                        </div>

                        <div class="mb-3">
                            <label for="model" class="form-label">Modèle *</label>
                            <InputText id="model" class="form-control" @bind-Value="rod.Model" required />
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">Caractéristiques</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="length" class="form-label">Longueur</label>
                            <InputText id="length" class="form-control" @bind-Value="rod.Length" />
                        </div>

                        <div class="mb-3">
                            <label for="power" class="form-label">Puissance</label>
                            <InputText id="power" class="form-control" @bind-Value="rod.Power" />
                        </div>

                        <div class="mb-3">
                            <label for="action" class="form-label">Action</label>
                            <InputText id="action" class="form-control" @bind-Value="rod.Action" />
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">Notes</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="notes" class="form-label">Notes personnelles</label>
                            <InputTextArea id="notes" class="form-control" rows="4" @bind-Value="rod.Notes" />
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">
                        Annuler
                    </button>
                    <button type="submit" class="btn btn-primary btn-lg" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        ✅ Enregistrer les modifications
                    </button>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter]
    public int RodId { get; set; }

    private Rod? rod;
    private string? errorMessage;
    private bool isLoading = true;
    private bool isSaving;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        try
        {
            rod = await EquipmentService.GetRodByIdAsync(RodId);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
            errorMessage = $"Erreur lors du chargement: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        if (rod == null) return;

        errorMessage = null;

        if (string.IsNullOrWhiteSpace(rod.Brand))
        {
            errorMessage = "La marque est obligatoire.";
            return;
        }

        if (string.IsNullOrWhiteSpace(rod.Model))
        {
            errorMessage = "Le modèle est obligatoire.";
            return;
        }

        isSaving = true;

        try
        {
            var success = await EquipmentService.UpdateRodAsync(rod);

            if (success)
            {
                Navigation.NavigateTo("/materiel/cannes");
            }
            else
            {
                errorMessage = "Erreur lors de la modification. Veuillez réessayer.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/materiel/cannes");
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/");
    }
}
