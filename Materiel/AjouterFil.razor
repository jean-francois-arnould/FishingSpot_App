
@page "/materiel/fils/ajouter"
@page "/FishingSpot_App/materiel/fils/ajouter"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<h3 class="mb-4">🧵 Ajouter un Fil</h3>

<EditForm Model="@newLine" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="brand" class="form-label">Marque *</label>
        <InputText id="brand" class="form-control" @bind-Value="newLine.Brand" required />
    </div>

    <div class="mb-3">
        <label for="type" class="form-label">Type *</label>
        <InputText id="type" class="form-control" @bind-Value="newLine.Type" required />
    </div>

    <div class="mb-3">
        <label for="strength" class="form-label">Résistance (ex: 20lb, 10kg)</label>
        <InputText id="strength" class="form-control" @bind-Value="newLine.Strength" />
    </div>

    <div class="mb-3">
        <label for="diameter" class="form-label">Diamètre (ex: 0.30mm)</label>
        <InputText id="diameter" class="form-control" @bind-Value="newLine.Diameter" />
    </div>

    <div class="mb-3">
        <label for="color" class="form-label">Couleur</label>
        <InputText id="color" class="form-control" @bind-Value="newLine.Color" />
    </div>

    <div class="mb-3">
        <label for="notes" class="form-label">Notes</label>
        <InputTextArea id="notes" class="form-control" @bind-Value="newLine.Notes" rows="3" />
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="mt-3">
        <button type="submit" class="btn btn-success" disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            }
            <i class="bi bi-check-circle"></i> Enregistrer
        </button>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">
            <i class="bi bi-x-circle"></i> Annuler
        </button>
    </div>
</EditForm>

@code {
    private Line newLine = new();
    private bool isSubmitting = false;
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(newLine.Brand) || string.IsNullOrWhiteSpace(newLine.Type))
        {
            errorMessage = "La marque et le type sont requis.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            await EquipmentService.AddLineAsync(newLine);
            Navigation.NavigateTo("/FishingSpot_App/materiel/fils");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de l'ajout du fil: {ex.Message}";
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/FishingSpot_App/materiel/fils");
    }
}
