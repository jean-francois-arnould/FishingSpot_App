@page "/materiel/leurres/details/{id:int}"
@page "/FishingSpot_App/materiel/leurres/details/{id:int}"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Détails - Leurre</PageTitle>

<div class="page-content">
    <a href="/FishingSpot_App/materiel" class="btn btn-outline-secondary btn-sm mb-3">
        ← Retour au matériel
    </a>

    @if (isLoading)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement...</p>
        </div>
    }
    else if (lure == null)
    {
        <div class="empty-state">
            <div class="empty-state-icon">❌</div>
            <h3>Leurre introuvable</h3>
            <p class="text-muted">Ce leurre n'existe pas ou a été supprimé.</p>
            <a href="/FishingSpot_App/materiel" class="btn btn-primary">
                ← Retour au matériel
            </a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">🐟 @lure.Name</h3>
            </div>
            <div class="card-body">
                <div class="detail-row">
                    <span class="detail-label">🏷️ Nom</span>
                    <span class="detail-value">@lure.Name</span>
                </div>

                @if (!string.IsNullOrEmpty(lure.Type))
                {
                    <div class="detail-row">
                        <span class="detail-label">📦 Type</span>
                        <span class="detail-value">@lure.Type</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(lure.Color))
                {
                    <div class="detail-row">
                        <span class="detail-label">🎨 Couleur</span>
                        <span class="detail-value">@lure.Color</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(lure.Weight))
                {
                    <div class="detail-row">
                        <span class="detail-label">⚖️ Poids</span>
                        <span class="detail-value">@lure.Weight</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(lure.Size))
                {
                    <div class="detail-row">
                        <span class="detail-label">📏 Taille</span>
                        <span class="detail-value">@lure.Size</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(lure.Notes))
                {
                    <div class="detail-row">
                        <span class="detail-label">💭 Notes</span>
                        <span class="detail-value">@lure.Notes</span>
                    </div>
                }

                <div class="detail-row">
                    <span class="detail-label">📅 Ajouté le</span>
                    <span class="detail-value">@lure.CreatedAt.ToString("dd/MM/yyyy")</span>
                </div>
            </div>

            <div class="card-footer">
                <div class="btn-group w-100" role="group">
                    <a href="/FishingSpot_App/materiel/leurres/modifier/@lure.Id" class="btn btn-primary">
                        ✏️ Modifier
                    </a>
                    <button class="btn btn-outline-danger" @onclick="ShowDeleteConfirmation">
                        🗑️ Supprimer
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal de confirmation de suppression -->
@if (showDeleteModal)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>⚠️ Confirmer la suppression</h3>
            </div>
            <div class="modal-body">
                <p>Êtes-vous sûr de vouloir supprimer ce leurre ?</p>
                <p><strong>@lure?.Name</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">
                    Annuler
                </button>
                <button type="button" class="btn btn-danger" @onclick="HandleDelete" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <div class="spinner"></div>
                    }
                    Supprimer
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Lure? lure;
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private bool isDeleting = false;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        await LoadLure();
    }

    private async Task LoadLure()
    {
        isLoading = true;
        try
        {
            lure = await EquipmentService.GetLureByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement du leurre: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowDeleteConfirmation()
    {
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
    }

    private async Task HandleDelete()
    {
        if (lure == null) return;

        isDeleting = true;
        try
        {
            var success = await EquipmentService.DeleteLureAsync(lure.Id);
            if (success)
            {
                Navigation.NavigateTo("/FishingSpot_App/materiel", forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors de la suppression: {ex.Message}");
        }
        finally
        {
            isDeleting = false;
        }
    }
}
