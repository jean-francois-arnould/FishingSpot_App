
@page "/materiel/cannes"
@page "/FishingSpot_App/materiel/cannes"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Mes Cannes</PageTitle>

<div class="page-content">
    <a href="/FishingSpot_App/materiel" class="btn btn-outline-secondary btn-sm mb-3">
        ← Retour au matériel
    </a>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🎣 Mes Cannes</h1>
        <a href="/FishingSpot_App/materiel/cannes/ajouter" class="btn btn-primary">
            ➕ Ajouter
        </a>
    </div>

    @if (isLoading)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement des cannes...</p>
        </div>
    }
    else if (rods == null || !rods.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">🎣</div>
            <h3>Aucune canne enregistrée</h3>
            <p class="text-muted">Commencez par ajouter votre première canne !</p>
            <a href="/FishingSpot_App/materiel/cannes/ajouter" class="btn btn-primary">
                ➕ Ajouter ma première canne
            </a>
        </div>
    }
        else
        {
            <div class="list">
                @foreach (var rod in rods)
                {
                    <div class="card mb-3">
                        <div class="card-header">
                            <h5 class="mb-0">🎣 @rod.Brand @rod.Model</h5>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(rod.Length))
                            {
                                <p class="mb-2">
                                    <strong>📏 Longueur :</strong> @rod.Length m
                                </p>
                            }
                            @if (!string.IsNullOrEmpty(rod.Power))
                            {
                                <p class="mb-2">
                                    <strong>💪 Puissance :</strong> @rod.Power
                                </p>
                            }
                            @if (!string.IsNullOrEmpty(rod.Action))
                            {
                                <p class="mb-2">
                                    <strong>⚡ Action :</strong> @rod.Action
                                </p>
                            }
                            @if (!string.IsNullOrEmpty(rod.Notes))
                            {
                                <p class="card-text mt-3">
                                    <small class="text-muted">💭 @rod.Notes</small>
                                </p>
                            }
                        </div>
                        <div class="card-footer">
                            <div class="btn-group w-100" role="group">
                                <a href="/FishingSpot_App/materiel/cannes/modifier/@rod.Id" class="btn btn-outline-primary">
                                    ✏️ Modifier
                                </a>
                                <button class="btn btn-outline-danger" @onclick="() => ShowDeleteConfirmation(rod)">
                                    🗑️ Supprimer
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

<!-- Modal de confirmation de suppression -->
@if (showDeleteModal && rodToDelete != null)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>⚠️ Confirmer la suppression</h3>
            </div>
            <div class="modal-body">
                <p>Êtes-vous sûr de vouloir supprimer cette canne ?</p>
                <p><strong>@rodToDelete.Brand @rodToDelete.Model</strong></p>
                <p class="text-danger">⚠️ Les montages utilisant cette canne ne seront pas supprimés mais perdront cette référence.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">
                    Annuler
                </button>
                <button type="button" class="btn btn-danger" @onclick="HandleDelete" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <div class="spinner"></div>
                    }
                    Supprimer
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Rod>? rods;
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private bool isDeleting = false;
    private Rod? rodToDelete;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        await LoadRods();
    }

    private async Task LoadRods()
    {
        isLoading = true;
        try
        {
            rods = await EquipmentService.GetAllRodsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des cannes: {ex.Message}");
            rods = new List<Rod>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowDeleteConfirmation(Rod rod)
    {
        rodToDelete = rod;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        rodToDelete = null;
        showDeleteModal = false;
    }

    private async Task HandleDelete()
    {
        if (rodToDelete == null) return;

        isDeleting = true;
        try
        {
            var success = await EquipmentService.DeleteRodAsync(rodToDelete.Id);
            if (success)
            {
                showDeleteModal = false;
                rodToDelete = null;
                await LoadRods(); // Recharger la liste
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors de la suppression: {ex.Message}");
        }
        finally
        {
            isDeleting = false;
        }
    }
}
