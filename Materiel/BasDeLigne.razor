
@page "/materiel/bas-de-ligne"
@page "/FishingSpot_App/materiel/bas-de-ligne"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Mes Bas de Ligne</PageTitle>

<div class="page-content">
    <a href="/FishingSpot_App/materiel" class="btn btn-outline-secondary btn-sm mb-3">
        ← Retour au matériel
    </a>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>⛓️ Mes Bas de Ligne</h1>
        <button class="btn btn-primary" @onclick="AddLeader">
            ➕ Ajouter
        </button>
    </div>

    @if (isLoading)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement des bas de ligne...</p>
        </div>
    }
    else if (leaders == null || !leaders.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">⛓️</div>
            <h3>Aucun bas de ligne enregistré</h3>
            <p class="text-muted">Commencez par ajouter votre premier bas de ligne !</p>
            <button class="btn btn-primary" @onclick="AddLeader">
                ➕ Ajouter mon premier bas de ligne
            </button>
        </div>
    }
    else
    {
        <div class="list">
            @foreach (var leader in leaders)
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <h5 class="mb-0">⛓️ @leader.Material</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(leader.Strength))
                        {
                            <p class="mb-2"><strong>💪 Résistance :</strong> @leader.Strength</p>
                        }
                        @if (!string.IsNullOrEmpty(leader.Length))
                        {
                            <p class="mb-2"><strong>📏 Longueur :</strong> @leader.Length</p>
                        }
                        @if (!string.IsNullOrEmpty(leader.Notes))
                        {
                            <p class="card-text mt-3"><small class="text-muted">💭 @leader.Notes</small></p>
                        }
                    </div>
                    <div class="card-footer">
                        <div class="btn-group w-100" role="group">
                            <button class="btn btn-outline-primary" @onclick="() => EditLeader(leader.Id)">
                                ✏️ Modifier
                            </button>
                            <button class="btn btn-outline-danger" @onclick="() => ShowDeleteConfirmation(leader)">
                                🗑️ Supprimer
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showDeleteModal && leaderToDelete != null)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>⚠️ Confirmer la suppression</h3>
                                </div>
                                <div class="modal-body">
                                    <p>Êtes-vous sûr de vouloir supprimer ce bas de ligne ?</p>
                                    <p><strong>@leaderToDelete.Material</strong></p>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">
                                        Annuler
                                    </button>
                                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">
                                        Supprimer
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

@code {
    private List<Leader> leaders = new();
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private Leader? leaderToDelete = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadLeaders();
    }

    private async Task LoadLeaders()
    {
        isLoading = true;
        try
        {
            leaders = await EquipmentService.GetAllLeadersAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des bas de ligne: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddLeader()
    {
        Navigation.NavigateTo("/FishingSpot_App/materiel/bas-de-ligne/ajouter");
    }

    private void EditLeader(int id)
    {
        Navigation.NavigateTo($"/FishingSpot_App/materiel/bas-de-ligne/modifier/{id}");
    }

    private void ShowDeleteConfirmation(Leader leader)
    {
        leaderToDelete = leader;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
        leaderToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (leaderToDelete != null)
        {
            try
            {
                await EquipmentService.DeleteLeaderAsync(leaderToDelete.Id);
                await LoadLeaders();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erreur lors de la suppression: {ex.Message}");
            }
        }
        showDeleteModal = false;
        leaderToDelete = null;
    }
}
