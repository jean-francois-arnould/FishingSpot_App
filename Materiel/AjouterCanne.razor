
@page "/materiel/cannes/ajouter"
@page "/FishingSpot_App/materiel/cannes/ajouter"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject IEquipmentService EquipmentService
@inject ISupabaseService SupabaseService
@inject NavigationManager Navigation

<PageTitle>Ajouter une Canne</PageTitle>

<div class="page-content">
    <a href="/FishingSpot_App/materiel/cannes" class="btn btn-outline-secondary btn-sm mb-3">← Retour aux cannes</a>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }

    <EditForm Model="@newRod" OnValidSubmit="HandleSubmit">
        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">🎣 Ajouter une canne</h3>
            </div>
            <div class="card-body">
                <!-- Marque -->
                <div class="form-group">
                    <label for="brand" class="form-label">Marque *</label>
                    <div class="fish-species-readonly">
                        <input type="text" 
                               id="brand" 
                               class="form-control" 
                               value="@GetBrandDisplayValue()" 
                               placeholder="Sélectionner une marque..." 
                               readonly 
                               required />
                    </div>
                    <div class="fish-species-buttons">
                        @if (availableBrands != null && availableBrands.Any())
                        {
                            <button type="button" class="btn btn-primary" @onclick="ShowBrandsList">
                                🔍 Chercher dans la liste
                            </button>
                        }
                        <button type="button" class="btn btn-success" @onclick="ShowAddBrandForm">
                            ➕ Ajouter une nouvelle marque
                        </button>
                    </div>
                </div>

                <div class="form-group">
                    <label for="model" class="form-label">Modèle *</label>
                    <InputText id="model" class="form-control" @bind-Value="newRod.Model" placeholder="Zodias, Procaster..." required />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="length" class="form-label">📏 Longueur (m)</label>
                        <InputText id="length" class="form-control" @bind-Value="newRod.Length" placeholder="2.10" />
                    </div>
                    <div class="form-group">
                        <label for="power" class="form-label">💪 Puissance</label>
                        <InputText id="power" class="form-control" @bind-Value="newRod.Power" placeholder="M, MH, H..." />
                        <small class="text-muted">UL, L, ML, M, MH, H, XH</small>
                    </div>
                </div>

                <div class="form-group">
                    <label for="action" class="form-label">Action</label>
                    <InputText id="action" class="form-control" @bind-Value="newRod.Action" placeholder="Fast, Moderate..." />
                    <small class="text-muted">Slow, Moderate, Fast, Extra Fast</small>
                </div>

                <div class="form-group">
                    <label for="notes" class="form-label">Notes</label>
                    <InputTextArea id="notes" class="form-control" rows="4" @bind-Value="newRod.Notes" placeholder="État, technique de pêche, utilisation..." />
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">Annuler</button>
            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                @if (isSaving) { <div class="spinner"></div> }
                ✅ Enregistrer
            </button>
        </div>
    </EditForm>

    @* Modal pour afficher la liste des marques *@
    @if (showBrandsModal && availableBrands != null)
    {
        <div class="modal-backdrop" @onclick="HideBrandsModal"></div>
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title">🔍 Sélectionner une marque</h3>
                    <button type="button" class="btn-close" @onclick="HideBrandsModal">✕</button>
                </div>
                <div class="modal-body">
                    <div class="fish-list">
                        @foreach (var brand in availableBrands)
                        {
                            <button type="button" class="fish-item" @onclick="() => SelectBrand(brand)">
                                <div class="fish-info">
                                    <div class="fish-name">@brand.Name</div>
                                </div>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @* Modal pour ajouter une nouvelle marque *@
    @if (showAddBrandModal)
    {
        <div class="modal-backdrop" @onclick="HideAddBrandModal"></div>
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title">➕ Ajouter une nouvelle marque</h3>
                    <button type="button" class="btn-close" @onclick="HideAddBrandModal">✕</button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(addBrandError))
                    {
                        <div class="alert alert-danger">@addBrandError</div>
                    }
                    @if (!string.IsNullOrEmpty(addBrandSuccess))
                    {
                        <div class="alert alert-success">@addBrandSuccess</div>
                    }

                    <EditForm Model="@newBrand" OnValidSubmit="HandleAddBrand">
                        <div class="form-group">
                            <label class="form-label">Nom de la marque *</label>
                            <InputText class="form-control" @bind-Value="newBrand.Name" 
                                       placeholder="Ex: Shimano" required />
                        </div>

                        <div class="modal-actions">
                            <button type="button" class="btn btn-outline-secondary" @onclick="HideAddBrandModal">
                                Annuler
                            </button>
                            <button type="submit" class="btn btn-primary" disabled="@isAddingBrand">
                                @if (isAddingBrand)
                                {
                                    <div class="spinner"></div>
                                }
                                ✅ Ajouter
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private Rod newRod = new Rod();
    private FishingBrand newBrand = new FishingBrand { Category = BrandCategory.Rod };
    private List<FishingBrand>? availableBrands;
    private string? errorMessage;
    private string? successMessage;
    private string? addBrandError;
    private string? addBrandSuccess;
    private bool isSaving;
    private bool isAddingBrand;
    private bool showBrandsModal = false;
    private bool showAddBrandModal = false;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        try
        {
            availableBrands = await SupabaseService.GetBrandsByCategoryAsync(BrandCategory.Rod);
            Console.WriteLine($"✅ Loaded {availableBrands.Count} rod brands");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading brands: {ex.Message}");
        }
    }

    private string GetBrandDisplayValue()
    {
        return string.IsNullOrEmpty(newRod.Brand) ? "" : newRod.Brand;
    }

    private void ShowBrandsList()
    {
        showBrandsModal = true;
    }

    private void HideBrandsModal()
    {
        showBrandsModal = false;
    }

    private void SelectBrand(FishingBrand brand)
    {
        newRod.Brand = brand.Name;
        showBrandsModal = false;
    }

    private void ShowAddBrandForm()
    {
        newBrand = new FishingBrand { Category = BrandCategory.Rod };
        addBrandError = null;
        addBrandSuccess = null;
        showAddBrandModal = true;
    }

    private void HideAddBrandModal()
    {
        showAddBrandModal = false;
        newBrand = new FishingBrand { Category = BrandCategory.Rod };
        addBrandError = null;
        addBrandSuccess = null;
    }

    private async Task HandleAddBrand()
    {
        addBrandError = null;
        addBrandSuccess = null;
        isAddingBrand = true;

        try
        {
            if (string.IsNullOrWhiteSpace(newBrand.Name))
            {
                addBrandError = "Le nom de la marque est requis.";
                isAddingBrand = false;
                return;
            }

            Console.WriteLine($"Attempting to add brand: {newBrand.Name}");
            var brandId = await SupabaseService.AddFishingBrandAsync(newBrand);

            if (brandId == -1)
            {
                addBrandError = $"❌ La marque '{newBrand.Name}' existe déjà dans la base de données.";
                isAddingBrand = false;
                return;
            }

            if (brandId > 0)
            {
                addBrandSuccess = $"✅ La marque '{newBrand.Name}' a été ajoutée avec succès !";
                Console.WriteLine($"Brand added with ID: {brandId}");

                // Recharger la liste des marques
                availableBrands = await SupabaseService.GetBrandsByCategoryAsync(BrandCategory.Rod);

                // Sélectionner automatiquement la nouvelle marque
                newRod.Brand = newBrand.Name;

                // Attendre 2 secondes puis fermer le modal
                await Task.Delay(2000);
                HideAddBrandModal();
            }
            else
            {
                addBrandError = "Erreur lors de l'ajout de la marque.";
            }
        }
        catch (Exception ex)
        {
            addBrandError = $"Erreur: {ex.Message}";
            Console.WriteLine($"Error adding brand: {ex.Message}");
        }
        finally
        {
            isAddingBrand = false;
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(newRod.Brand) || string.IsNullOrWhiteSpace(newRod.Model))
        {
            errorMessage = "La marque et le modèle sont requis.";
            return;
        }

        isSaving = true;
        errorMessage = null;

        try
        {
            var rodId = await EquipmentService.AddRodAsync(newRod);
            if (rodId > 0)
            {
                Navigation.NavigateTo("/FishingSpot_App/materiel", forceLoad: true);
            }
            else
            {
                errorMessage = "Erreur lors de l'enregistrement de la canne.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/FishingSpot_App/materiel");
    }
}
