
@page "/materiel/leurres"
@page "/FishingSpot_App/materiel/leurres"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Mes Leurres</PageTitle>

<div class="page-content">
    <a href="/FishingSpot_App/materiel" class="btn btn-outline-secondary btn-sm mb-3">
        ← Retour au matériel
    </a>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🪝 Mes Leurres</h1>
        <button class="btn btn-primary" @onclick="AddLure">
            ➕ Ajouter
        </button>
    </div>

    @if (isLoading)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement des leurres...</p>
        </div>
    }
    else if (lures == null || !lures.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">🪝</div>
            <h3>Aucun leurre enregistré</h3>
            <p class="text-muted">Commencez par ajouter votre premier leurre !</p>
            <button class="btn btn-primary" @onclick="AddLure">
                ➕ Ajouter mon premier leurre
            </button>
        </div>
    }
    else
    {
        <div class="list">
            @foreach (var lure in lures)
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <h5 class="mb-0">🪝 @lure.Name</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(lure.Type))
                        {
                            <p class="mb-2"><strong>Type :</strong> @lure.Type</p>
                        }
                        @if (!string.IsNullOrEmpty(lure.Color))
                        {
                            <p class="mb-2"><strong>🎨 Couleur :</strong> @lure.Color</p>
                        }
                        @if (!string.IsNullOrEmpty(lure.Weight))
                        {
                            <p class="mb-2"><strong>⚖️ Poids :</strong> @lure.Weight</p>
                        }
                        @if (!string.IsNullOrEmpty(lure.Size))
                        {
                            <p class="mb-2"><strong>📏 Taille :</strong> @lure.Size</p>
                        }
                        @if (!string.IsNullOrEmpty(lure.Notes))
                        {
                            <p class="card-text mt-3"><small class="text-muted">💭 @lure.Notes</small></p>
                        }
                    </div>
                    <div class="card-footer">
                        <div class="btn-group w-100" role="group">
                            <button class="btn btn-outline-primary" @onclick="() => EditLure(lure.Id)">
                                ✏️ Modifier
                            </button>
                            <button class="btn btn-outline-danger" @onclick="() => ShowDeleteConfirmation(lure)">
                                🗑️ Supprimer
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showDeleteModal && lureToDelete != null)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>⚠️ Confirmer la suppression</h3>
            </div>
            <div class="modal-body">
                <p>Êtes-vous sûr de vouloir supprimer ce leurre ?</p>
                <p><strong>@lureToDelete.Name</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">
                    Annuler
                </button>
                <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">
                    Supprimer
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Lure> lures = new();
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private Lure? lureToDelete = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadLures();
    }

    private async Task LoadLures()
    {
        isLoading = true;
        try
        {
            lures = await EquipmentService.GetAllLuresAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des leurres: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddLure()
    {
        Navigation.NavigateTo("/FishingSpot_App/materiel/leurres/ajouter");
    }

    private void EditLure(int id)
    {
        Navigation.NavigateTo($"/FishingSpot_App/materiel/leurres/modifier/{id}");
    }

    private void ShowDeleteConfirmation(Lure lure)
    {
        lureToDelete = lure;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
        lureToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (lureToDelete != null)
        {
            try
            {
                await EquipmentService.DeleteLureAsync(lureToDelete.Id);
                await LoadLures();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erreur lors de la suppression: {ex.Message}");
            }
        }
        showDeleteModal = false;
        lureToDelete = null;
    }
}
        Navigation.NavigateTo("/FishingSpot_App/materiel");
    }
}
