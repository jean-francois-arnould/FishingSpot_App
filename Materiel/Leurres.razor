
@page "/FishingSpot_App/materiel/leurres"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<h3 class="mb-4">🪝 Mes Leurres</h3>

@if (isLoading)
{
    <div class="text-center">
        <div class="spinner-border text-warning" role="status">
            <span class="visually-hidden">Chargement...</span>
        </div>
    </div>
}
else if (lures == null || !lures.Any())
{
    <div class="alert alert-warning">
        <p class="mb-0">Vous n'avez pas encore de leurres enregistrés.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var lure in lures)
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card h-100">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="card-title mb-0">@lure.Name</h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text">
                            @if (!string.IsNullOrEmpty(lure.Type))
                            {
                                <span><strong>Type:</strong> @lure.Type<br /></span>
                            }
                            @if (!string.IsNullOrEmpty(lure.Color))
                            {
                                <span><strong>Couleur:</strong> @lure.Color<br /></span>
                            }
                            @if (!string.IsNullOrEmpty(lure.Weight))
                            {
                                <span><strong>Poids:</strong> @lure.Weight<br /></span>
                            }
                            @if (!string.IsNullOrEmpty(lure.Size))
                            {
                                <span><strong>Taille:</strong> @lure.Size<br /></span>
                            }
                            @if (!string.IsNullOrEmpty(lure.Notes))
                            {
                                <span><strong>Notes:</strong> @lure.Notes</span>
                            }
                        </p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <button class="btn btn-sm btn-primary" @onclick="() => EditLure(lure.Id)">
                            <i class="bi bi-pencil"></i> Modifier
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => ShowDeleteConfirmation(lure)">
                            <i class="bi bi-trash"></i> Supprimer
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-3">
    <button class="btn btn-success" @onclick="AddLure">
        <i class="bi bi-plus-circle"></i> Ajouter un leurre
    </button>
    <button class="btn btn-secondary" @onclick="GoBack">
        <i class="bi bi-arrow-left"></i> Retour
    </button>
</div>

@if (showDeleteModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmer la suppression</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Êtes-vous sûr de vouloir supprimer le leurre <strong>@lureToDelete?.Name</strong> ?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Annuler</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Supprimer</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<Lure> lures = new();
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private Lure? lureToDelete = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadLures();
    }

    private async Task LoadLures()
    {
        isLoading = true;
        try
        {
            lures = await EquipmentService.GetAllLuresAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des leurres: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddLure()
    {
        Navigation.NavigateTo("/materiel/leurres/ajouter");
    }

    private void EditLure(int id)
    {
        Navigation.NavigateTo($"/materiel/leurres/modifier/{id}");
    }

    private void ShowDeleteConfirmation(Lure lure)
    {
        lureToDelete = lure;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
        lureToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (lureToDelete != null)
        {
            try
            {
                await EquipmentService.DeleteLureAsync(lureToDelete.Id);
                await LoadLures();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erreur lors de la suppression: {ex.Message}");
            }
        }
        showDeleteModal = false;
        lureToDelete = null;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/materiel");
    }
}
