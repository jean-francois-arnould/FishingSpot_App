
@page "/materiel/hamecons"
@page "/FishingSpot_App/materiel/hamecons"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Mes Hameçons</PageTitle>

<div class="page-content">
    <a href="/FishingSpot_App/materiel" class="btn btn-outline-secondary btn-sm mb-3">
        ← Retour au matériel
    </a>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🪝 Mes Hameçons</h1>
        <button class="btn btn-primary" @onclick="AddHook">
            ➕ Ajouter
        </button>
    </div>

    @if (isLoading)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement des hameçons...</p>
        </div>
    }
    else if (hooks == null || !hooks.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">🪝</div>
            <h3>Aucun hameçon enregistré</h3>
            <p class="text-muted">Commencez par ajouter votre premier hameçon !</p>
            <button class="btn btn-primary" @onclick="AddHook">
                ➕ Ajouter mon premier hameçon
            </button>
        </div>
    }
    else
    {
        <div class="list">
            @foreach (var hook in hooks)
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <h5 class="mb-0">🪝 Taille @hook.Size</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(hook.Type))
                        {
                            <p class="mb-2"><strong>Type :</strong> @hook.Type</p>
                        }
                        @if (!string.IsNullOrEmpty(hook.Brand))
                        {
                            <p class="mb-2"><strong>Marque :</strong> @hook.Brand</p>
                        }
                        @if (!string.IsNullOrEmpty(hook.Notes))
                        {
                            <p class="card-text mt-3"><small class="text-muted">💭 @hook.Notes</small></p>
                        }
                    </div>
                    <div class="card-footer">
                        <div class="btn-group w-100" role="group">
                            <button class="btn btn-outline-primary" @onclick="() => EditHook(hook.Id)">
                                ✏️ Modifier
                            </button>
                            <button class="btn btn-outline-danger" @onclick="() => ShowDeleteConfirmation(hook)">
                                🗑️ Supprimer
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showDeleteModal && hookToDelete != null)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>⚠️ Confirmer la suppression</h3>
                                </div>
                                <div class="modal-body">
                                    <p>Êtes-vous sûr de vouloir supprimer cet hameçon ?</p>
                                    <p><strong>Taille @hookToDelete.Size</strong></p>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">
                                        Annuler
                                    </button>
                                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">
                                        Supprimer
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

@code {
    private List<Hook> hooks = new();
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private Hook? hookToDelete = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadHooks();
    }

    private async Task LoadHooks()
    {
        isLoading = true;
        try
        {
            hooks = await EquipmentService.GetAllHooksAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des hameçons: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddHook()
    {
        Navigation.NavigateTo("/FishingSpot_App/materiel/hamecons/ajouter");
    }

    private void EditHook(int id)
    {
        Navigation.NavigateTo($"/FishingSpot_App/materiel/hamecons/modifier/{id}");
    }

    private void ShowDeleteConfirmation(Hook hook)
    {
        hookToDelete = hook;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
        hookToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (hookToDelete != null)
        {
            try
            {
                await EquipmentService.DeleteHookAsync(hookToDelete.Id);
                await LoadHooks();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erreur lors de la suppression: {ex.Message}");
            }
        }
        showDeleteModal = false;
        hookToDelete = null;
    }
}
