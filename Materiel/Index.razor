                            <div class="list-item-subtitle">@reelsCount moulinet(s) enregistré(s)</div>
                        </div>
                        <div class="list-item-action">›</div>
                    </div>
                    <div class="list-item" @onclick='() => Navigation.NavigateTo("/FishingSpot_App/materiel/moulinets/ajouter")'>
                        <div class="list-item-icon">➕</div>
                        <div class="list-item-content">
