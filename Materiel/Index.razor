
@page "/materiel"
@page "/FishingSpot_App/materiel"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Mon Matériel</PageTitle>

<div class="page-content">
    @if (isLoading)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement...</p>
        </div>
    }
    else
    {
        <!-- CANNES -->
        <div class="accordion-item @(expandedSection == "cannes" ? "expanded" : "")">
            <div class="accordion-header" @onclick='() => ToggleSection("cannes")'>
                <div class="accordion-title">
                    <span class="accordion-icon">🎣</span>
                    <span>Cannes</span>
                    <span class="badge badge-info">@rods.Count</span>
                </div>
                <div class="accordion-arrow">@(expandedSection == "cannes" ? "▼" : "▶")</div>
            </div>
            @if (expandedSection == "cannes")
            {
                <div class="accordion-content">
                    @if (rods.Any())
                    {
                        @foreach (var rod in rods)
                        {
                            <div class="list-item" @onclick='() => Navigation.NavigateTo($"/FishingSpot_App/materiel/cannes/details/{rod.Id}")'>
                                <div class="list-item-icon">🎣</div>
                                <div class="list-item-content">
                                    <div class="list-item-title">@rod.Brand @rod.Model</div>
                                    <div class="list-item-subtitle">@rod.Length @rod.Power</div>
                                </div>
                                <div class="list-item-action">›</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state-small">
                            <p class="text-muted">Aucune canne enregistrée</p>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- MOULINETS -->
        <div class="accordion-item @(expandedSection == "moulinets" ? "expanded" : "")">
            <div class="accordion-header" @onclick='() => ToggleSection("moulinets")'>
                <div class="accordion-title">
                    <span class="accordion-icon">🎡</span>
                    <span>Moulinets</span>
                    <span class="badge badge-info">@reels.Count</span>
                </div>
                <div class="accordion-arrow">@(expandedSection == "moulinets" ? "▼" : "▶")</div>
            </div>
            @if (expandedSection == "moulinets")
            {
                <div class="accordion-content">
                    @if (reels.Any())
                    {
                        @foreach (var reel in reels)
                        {
                            <div class="list-item" @onclick='() => Navigation.NavigateTo($"/FishingSpot_App/materiel/moulinets/details/{reel.Id}")'>
                                <div class="list-item-icon">🎡</div>
                                <div class="list-item-content">
                                    <div class="list-item-title">@reel.Brand @reel.Model</div>
                                    <div class="list-item-subtitle">@reel.Type</div>
                                </div>
                                <div class="list-item-action">›</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state-small">
                            <p class="text-muted">Aucun moulinet enregistré</p>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- FILS -->
        <div class="accordion-item @(expandedSection == "fils" ? "expanded" : "")">
            <div class="accordion-header" @onclick='() => ToggleSection("fils")'>
                <div class="accordion-title">
                    <span class="accordion-icon">🧵</span>
                    <span>Fils</span>
                    <span class="badge badge-info">@lines.Count</span>
                </div>
                <div class="accordion-arrow">@(expandedSection == "fils" ? "▼" : "▶")</div>
            </div>
            @if (expandedSection == "fils")
            {
                <div class="accordion-content">
                    @if (lines.Any())
                    {
                        @foreach (var line in lines)
                        {
                            <div class="list-item" @onclick='() => Navigation.NavigateTo($"/FishingSpot_App/materiel/fils/details/{line.Id}")'>
                                <div class="list-item-icon">🧵</div>
                                <div class="list-item-content">
                                    <div class="list-item-title">@line.Brand @line.Type</div>
                                    <div class="list-item-subtitle">@line.Strength</div>
                                </div>
                                <div class="list-item-action">›</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state-small">
                            <p class="text-muted">Aucun fil enregistré</p>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- LEURRES -->
        <div class="accordion-item @(expandedSection == "leurres" ? "expanded" : "")">
            <div class="accordion-header" @onclick='() => ToggleSection("leurres")'>
                <div class="accordion-title">
                    <span class="accordion-icon">🐟</span>
                    <span>Leurres</span>
                    <span class="badge badge-info">@lures.Count</span>
                </div>
                <div class="accordion-arrow">@(expandedSection == "leurres" ? "▼" : "▶")</div>
            </div>
            @if (expandedSection == "leurres")
            {
                <div class="accordion-content">
                    @if (lures.Any())
                    {
                        @foreach (var lure in lures)
                        {
                            <div class="list-item" @onclick='() => Navigation.NavigateTo($"/FishingSpot_App/materiel/leurres/details/{lure.Id}")'>
                                <div class="list-item-icon">🐟</div>
                                <div class="list-item-content">
                                    <div class="list-item-title">@lure.Name</div>
                                    <div class="list-item-subtitle">@lure.Type - @lure.Color</div>
                                </div>
                                <div class="list-item-action">›</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state-small">
                            <p class="text-muted">Aucun leurre enregistré</p>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- HAMEÇONS -->
        <div class="accordion-item @(expandedSection == "hamecons" ? "expanded" : "")">
            <div class="accordion-header" @onclick='() => ToggleSection("hamecons")'>
                <div class="accordion-title">
                    <span class="accordion-icon">🪝</span>
                    <span>Hameçons</span>
                    <span class="badge badge-info">@hooks.Count</span>
                </div>
                <div class="accordion-arrow">@(expandedSection == "hamecons" ? "▼" : "▶")</div>
            </div>
            @if (expandedSection == "hamecons")
            {
                <div class="accordion-content">
                    @if (hooks.Any())
                    {
                        @foreach (var hook in hooks)
                        {
                            <div class="list-item" @onclick='() => Navigation.NavigateTo($"/FishingSpot_App/materiel/hamecons/details/{hook.Id}")'>
                                <div class="list-item-icon">🪝</div>
                                <div class="list-item-content">
                                    <div class="list-item-title">Taille @hook.Size @(!string.IsNullOrEmpty(hook.Brand) ? $"- {hook.Brand}" : "")</div>
                                    <div class="list-item-subtitle">@hook.Type</div>
                                </div>
                                <div class="list-item-action">›</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state-small">
                            <p class="text-muted">Aucun hameçon enregistré</p>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- BAS DE LIGNE -->
        <div class="accordion-item @(expandedSection == "bas-de-ligne" ? "expanded" : "")">
            <div class="accordion-header" @onclick='() => ToggleSection("bas-de-ligne")'>
                <div class="accordion-title">
                    <span class="accordion-icon">⛓️</span>
                    <span>Bas de ligne</span>
                    <span class="badge badge-info">@leaders.Count</span>
                </div>
                <div class="accordion-arrow">@(expandedSection == "bas-de-ligne" ? "▼" : "▶")</div>
            </div>
            @if (expandedSection == "bas-de-ligne")
            {
                <div class="accordion-content">
                    @if (leaders.Any())
                    {
                        @foreach (var leader in leaders)
                        {
                            <div class="list-item" @onclick='() => Navigation.NavigateTo($"/FishingSpot_App/materiel/bas-de-ligne/details/{leader.Id}")'>
                                <div class="list-item-icon">⛓️</div>
                                <div class="list-item-content">
                                    <div class="list-item-title">@leader.Material</div>
                                    <div class="list-item-subtitle">@leader.Length - @leader.Strength</div>
                                </div>
                                <div class="list-item-action">›</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state-small">
                            <p class="text-muted">Aucun bas de ligne enregistré</p>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<!-- Floating Action Button avec menu -->
<div class="fab-container">
    @if (showFabMenu)
    {
        <div class="fab-menu">
            <button class="fab-menu-item" @onclick='() => Navigation.NavigateTo("/FishingSpot_App/materiel/cannes/ajouter")'>
                <span class="fab-menu-icon">🎣</span>
                <span class="fab-menu-label">Canne</span>
            </button>
            <button class="fab-menu-item" @onclick='() => Navigation.NavigateTo("/FishingSpot_App/materiel/moulinets/ajouter")'>
                <span class="fab-menu-icon">🎡</span>
                <span class="fab-menu-label">Moulinet</span>
            </button>
            <button class="fab-menu-item" @onclick='() => Navigation.NavigateTo("/FishingSpot_App/materiel/fils/ajouter")'>
                <span class="fab-menu-icon">🧵</span>
                <span class="fab-menu-label">Fil</span>
            </button>
            <button class="fab-menu-item" @onclick='() => Navigation.NavigateTo("/FishingSpot_App/materiel/leurres/ajouter")'>
                <span class="fab-menu-icon">🐟</span>
                <span class="fab-menu-label">Leurre</span>
            </button>
            <button class="fab-menu-item" @onclick='() => Navigation.NavigateTo("/FishingSpot_App/materiel/hamecons/ajouter")'>
                <span class="fab-menu-icon">🪝</span>
                <span class="fab-menu-label">Hameçon</span>
            </button>
            <button class="fab-menu-item" @onclick='() => Navigation.NavigateTo("/FishingSpot_App/materiel/bas-de-ligne/ajouter")'>
                <span class="fab-menu-icon">⛓️</span>
                <span class="fab-menu-label">Bas de ligne</span>
            </button>
        </div>
    }
    <button class="fab @(showFabMenu ? "fab-active" : "")" @onclick="ToggleFabMenu" title="Ajouter du matériel">
        <span class="fab-icon">@(showFabMenu ? "×" : "+")</span>
    </button>
</div>

@code {
    private bool isLoading = true;
    private List<Rod> rods = new();
    private List<Reel> reels = new();
    private List<Line> lines = new();
    private List<Lure> lures = new();
    private List<Leader> leaders = new();
    private List<Hook> hooks = new();
    private string? expandedSection = null;
    private bool showFabMenu = false;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        await LoadAllEquipment();
    }

    private async Task LoadAllEquipment()
    {
        isLoading = true;
        try
        {
            // Charger tout le matériel en parallèle
            var rodsTask = EquipmentService.GetAllRodsAsync();
            var reelsTask = EquipmentService.GetAllReelsAsync();
            var linesTask = EquipmentService.GetAllLinesAsync();
            var luresTask = EquipmentService.GetAllLuresAsync();
            var leadersTask = EquipmentService.GetAllLeadersAsync();
            var hooksTask = EquipmentService.GetAllHooksAsync();

            await Task.WhenAll(rodsTask, reelsTask, linesTask, luresTask, leadersTask, hooksTask);

            rods = rodsTask.Result;
            reels = reelsTask.Result;
            lines = linesTask.Result;
            lures = luresTask.Result;
            leaders = leadersTask.Result;
            hooks = hooksTask.Result;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement du matériel: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleSection(string section)
    {
        if (expandedSection == section)
        {
            expandedSection = null;
        }
        else
        {
            expandedSection = section;
        }
    }

    private void ToggleFabMenu()
    {
        showFabMenu = !showFabMenu;
    }
}
