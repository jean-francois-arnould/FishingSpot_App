                        </div>
                        <div class="list-item-action">›</div>
                    </div>
                    <div class="list-item" @onclick='() => Navigation.NavigateTo("/FishingSpot_App/materiel/fils/ajouter")'>
                        <div class="list-item-icon">➕</div>
                        <div class="list-item-content">
