                </div>
                <div class="accordion-arrow">@(expandedSection == "fils" ? "▼" : "▶")</div>
            </div>
            @if (expandedSection == "fils")
            {
                <div class="accordion-content">
                    <div class="list-item" @onclick='() => Navigation.NavigateTo("/FishingSpot_App/materiel/fils")'>
                        <div class="list-item-icon">📋</div>
