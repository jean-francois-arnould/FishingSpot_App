
@page "/materiel/fils"
@page "/FishingSpot_App/materiel/fils"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Mes Fils</PageTitle>

<div class="page-content">
    <a href="/FishingSpot_App/materiel" class="btn btn-outline-secondary btn-sm mb-3">
        ← Retour au matériel
    </a>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🧵 Mes Fils</h1>
        <button class="btn btn-primary" @onclick="AddLine">
            ➕ Ajouter
        </button>
    </div>

    @if (isLoading)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement des fils...</p>
        </div>
    }
    else if (lines == null || !lines.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">🧵</div>
            <h3>Aucun fil enregistré</h3>
            <p class="text-muted">Commencez par ajouter votre premier fil !</p>
            <button class="btn btn-primary" @onclick="AddLine">
                ➕ Ajouter mon premier fil
            </button>
        </div>
    }
    else
    {
        <div class="list">
            @foreach (var line in lines)
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <h5 class="mb-0">🧵 @line.Brand</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-2"><strong>Type :</strong> @line.Type</p>
                        @if (!string.IsNullOrEmpty(line.Strength))
                        {
                            <p class="mb-2"><strong>💪 Résistance :</strong> @line.Strength</p>
                        }
                        @if (!string.IsNullOrEmpty(line.Diameter))
                        {
                            <p class="mb-2"><strong>📏 Diamètre :</strong> @line.Diameter</p>
                        }
                        @if (!string.IsNullOrEmpty(line.Color))
                        {
                            <p class="mb-2"><strong>🎨 Couleur :</strong> @line.Color</p>
                        }
                        @if (!string.IsNullOrEmpty(line.Notes))
                        {
                            <p class="card-text mt-3"><small class="text-muted">💭 @line.Notes</small></p>
                        }
                    </div>
                    <div class="card-footer">
                        <div class="btn-group w-100" role="group">
                            <button class="btn btn-outline-primary" @onclick="() => EditLine(line.Id)">
                                ✏️ Modifier
                            </button>
                            <button class="btn btn-outline-danger" @onclick="() => ShowDeleteConfirmation(line)">
                                🗑️ Supprimer
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showDeleteModal && lineToDelete != null)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>⚠️ Confirmer la suppression</h3>
            </div>
            <div class="modal-body">
                <p>Êtes-vous sûr de vouloir supprimer ce fil ?</p>
                <p><strong>@lineToDelete.Brand @lineToDelete.Type</strong></p>
            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">
                                    Annuler
                                </button>
                                <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">
                                    Supprimer
                                </button>
                            </div>
                        </div>
                    </div>
                }

@code {
    private List<Line> lines = new();
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private Line? lineToDelete = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadLines();
    }

    private async Task LoadLines()
    {
        isLoading = true;
        try
        {
            lines = await EquipmentService.GetAllLinesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des fils: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddLine()
    {
        Navigation.NavigateTo("/FishingSpot_App/materiel/fils/ajouter");
    }

    private void EditLine(int id)
    {
        Navigation.NavigateTo($"/FishingSpot_App/materiel/fils/modifier/{id}");
    }

    private void ShowDeleteConfirmation(Line line)
    {
        lineToDelete = line;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
        lineToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (lineToDelete != null)
        {
            try
            {
                await EquipmentService.DeleteLineAsync(lineToDelete.Id);
                await LoadLines();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erreur lors de la suppression: {ex.Message}");
            }
        }
        showDeleteModal = false;
        lineToDelete = null;
    }
}
