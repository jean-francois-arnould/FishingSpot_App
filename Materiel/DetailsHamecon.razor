@page "/materiel/hamecons/details/{id:int}"
@page "/FishingSpot_App/materiel/hamecons/details/{id:int}"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Détails - Hameçon</PageTitle>

<div class="page-content">
    <a href="/FishingSpot_App/materiel" class="btn btn-outline-secondary btn-sm mb-3">
        ← Retour au matériel
    </a>

    @if (isLoading)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement...</p>
        </div>
    }
    else if (hook == null)
    {
        <div class="empty-state">
            <div class="empty-state-icon">❌</div>
            <h3>Hameçon introuvable</h3>
            <p class="text-muted">Cet hameçon n'existe pas ou a été supprimé.</p>
            <a href="/FishingSpot_App/materiel" class="btn btn-primary">
                ← Retour au matériel
            </a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">🪝 Hameçon Taille @hook.Size</h3>
            </div>
            <div class="card-body">
                <div class="detail-row">
                    <span class="detail-label">📏 Taille</span>
                    <span class="detail-value">@hook.Size</span>
                </div>

                @if (!string.IsNullOrEmpty(hook.Type))
                {
                    <div class="detail-row">
                        <span class="detail-label">📦 Type</span>
                        <span class="detail-value">@hook.Type</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(hook.Brand))
                {
                    <div class="detail-row">
                        <span class="detail-label">🏷️ Marque</span>
                        <span class="detail-value">@hook.Brand</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(hook.Notes))
                {
                    <div class="detail-row">
                        <span class="detail-label">💭 Notes</span>
                        <span class="detail-value">@hook.Notes</span>
                    </div>
                }

                <div class="detail-row">
                    <span class="detail-label">📅 Ajouté le</span>
                    <span class="detail-value">@hook.CreatedAt.ToString("dd/MM/yyyy")</span>
                </div>
            </div>

            <div class="card-footer">
                <div class="btn-group w-100" role="group">
                    <a href="/FishingSpot_App/materiel/hamecons/modifier/@hook.Id" class="btn btn-primary">
                        ✏️ Modifier
                    </a>
                    <button class="btn btn-outline-danger" @onclick="ShowDeleteConfirmation">
                        🗑️ Supprimer
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal de confirmation de suppression -->
@if (showDeleteModal)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>⚠️ Confirmer la suppression</h3>
            </div>
            <div class="modal-body">
                <p>Êtes-vous sûr de vouloir supprimer cet hameçon ?</p>
                <p><strong>Taille @hook?.Size @(!string.IsNullOrEmpty(hook?.Brand) ? $"- {hook.Brand}" : "")</strong></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">
                    Annuler
                </button>
                <button type="button" class="btn btn-danger" @onclick="HandleDelete" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <div class="spinner"></div>
                    }
                    Supprimer
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Hook? hook;
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private bool isDeleting = false;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        await LoadHook();
    }

    private async Task LoadHook()
    {
        isLoading = true;
        try
        {
            hook = await EquipmentService.GetHookByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement de l'hameçon: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowDeleteConfirmation()
    {
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
    }

    private async Task HandleDelete()
    {
        if (hook == null) return;

        isDeleting = true;
        try
        {
            var success = await EquipmentService.DeleteHookAsync(hook.Id);
            if (success)
            {
                Navigation.NavigateTo("/FishingSpot_App/materiel", forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors de la suppression: {ex.Message}");
        }
        finally
        {
            isDeleting = false;
        }
    }
}
