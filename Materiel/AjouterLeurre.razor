
@page "/FishingSpot_App/materiel/leurres/ajouter"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<h3 class="mb-4">🪝 Ajouter un Leurre</h3>

<EditForm Model="@newLure" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="name" class="form-label">Nom *</label>
        <InputText id="name" class="form-control" @bind-Value="newLure.Name" required />
    </div>

    <div class="mb-3">
        <label for="type" class="form-label">Type (ex: Crankbait, Spinnerbait, Jig)</label>
        <InputText id="type" class="form-control" @bind-Value="newLure.Type" />
    </div>

    <div class="mb-3">
        <label for="color" class="form-label">Couleur</label>
        <InputText id="color" class="form-control" @bind-Value="newLure.Color" />
    </div>

    <div class="mb-3">
        <label for="weight" class="form-label">Poids (ex: 10g, 1/4oz)</label>
        <InputText id="weight" class="form-control" @bind-Value="newLure.Weight" />
    </div>

    <div class="mb-3">
        <label for="size" class="form-label">Taille (ex: 7cm, 3")</label>
        <InputText id="size" class="form-control" @bind-Value="newLure.Size" />
    </div>

    <div class="mb-3">
        <label for="notes" class="form-label">Notes</label>
        <InputTextArea id="notes" class="form-control" @bind-Value="newLure.Notes" rows="3" />
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="mt-3">
        <button type="submit" class="btn btn-success" disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            }
            <i class="bi bi-check-circle"></i> Enregistrer
        </button>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">
            <i class="bi bi-x-circle"></i> Annuler
        </button>
    </div>
</EditForm>

@code {
    private Lure newLure = new();
    private bool isSubmitting = false;
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(newLure.Name))
        {
            errorMessage = "Le nom est requis.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            await EquipmentService.AddLureAsync(newLure);
            Navigation.NavigateTo("/materiel/leurres");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de l'ajout du leurre: {ex.Message}";
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/materiel/leurres");
    }
}
