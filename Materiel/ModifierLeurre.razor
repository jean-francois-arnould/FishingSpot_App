
@page "/FishingSpot_App/materiel/leurres/modifier/{LureId:int}"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<h3 class="mb-4">🪝 Modifier le Leurre</h3>

@if (isLoading)
{
    <div class="text-center">
        <div class="spinner-border text-warning" role="status">
            <span class="visually-hidden">Chargement...</span>
        </div>
    </div>
}
else if (lure == null)
{
    <div class="alert alert-danger">
        Leurre non trouvé.
    </div>
}
else
{
    <EditForm Model="@lure" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="name" class="form-label">Nom *</label>
            <InputText id="name" class="form-control" @bind-Value="lure.Name" required />
        </div>

        <div class="mb-3">
            <label for="type" class="form-label">Type (ex: Crankbait, Spinnerbait, Jig)</label>
            <InputText id="type" class="form-control" @bind-Value="lure.Type" />
        </div>

        <div class="mb-3">
            <label for="color" class="form-label">Couleur</label>
            <InputText id="color" class="form-control" @bind-Value="lure.Color" />
        </div>

        <div class="mb-3">
            <label for="weight" class="form-label">Poids (ex: 10g, 1/4oz)</label>
            <InputText id="weight" class="form-control" @bind-Value="lure.Weight" />
        </div>

        <div class="mb-3">
            <label for="size" class="form-label">Taille (ex: 7cm, 3")</label>
            <InputText id="size" class="form-control" @bind-Value="lure.Size" />
        </div>

        <div class="mb-3">
            <label for="notes" class="form-label">Notes</label>
            <InputTextArea id="notes" class="form-control" @bind-Value="lure.Notes" rows="3" />
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <div class="mt-3">
            <button type="submit" class="btn btn-success" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                }
                <i class="bi bi-check-circle"></i> Enregistrer
            </button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">
                <i class="bi bi-x-circle"></i> Annuler
            </button>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public int LureId { get; set; }

    private Lure? lure;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var lures = await EquipmentService.GetAllLuresAsync();
            lure = lures.FirstOrDefault(l => l.Id == LureId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement: {ex.Message}";
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        if (lure == null || string.IsNullOrWhiteSpace(lure.Name))
        {
            errorMessage = "Le nom est requis.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            await EquipmentService.UpdateLureAsync(lure);
            Navigation.NavigateTo("/materiel/leurres");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de la modification: {ex.Message}";
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/materiel/leurres");
    }
}
