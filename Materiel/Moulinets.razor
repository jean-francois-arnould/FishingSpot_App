
@page "/materiel/moulinets"
@page "/FishingSpot_App/materiel/moulinets"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Mes Moulinets</PageTitle>

<div class="page-content">
    <a href="/FishingSpot_App/materiel" class="btn btn-outline-secondary btn-sm mb-3">
        ← Retour au matériel
    </a>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🎡 Mes Moulinets</h1>
        <a href="/FishingSpot_App/materiel/moulinets/ajouter" class="btn btn-primary">
            ➕ Ajouter
        </a>
    </div>

    @if (isLoading)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement des moulinets...</p>
        </div>
    }
    else if (reels == null || !reels.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">🎡</div>
            <h3>Aucun moulinet enregistré</h3>
            <p class="text-muted">Commencez par ajouter votre premier moulinet !</p>
            <a href="/FishingSpot_App/materiel/moulinets/ajouter" class="btn btn-primary">
                ➕ Ajouter mon premier moulinet
            </a>
        </div>
    }
    else
    {
        <div class="list">
            @foreach (var reel in reels)
            {
                <div class="card mb-3">
                    <div class="card-header">
                        <h5 class="mb-0">🎡 @reel.Brand @reel.Model</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(reel.Type))
                        {
                            <p class="mb-2"><strong>🎡 Type :</strong> @reel.Type</p>
                        }
                        @if (!string.IsNullOrEmpty(reel.GearRatio))
                        {
                            <p class="mb-2"><strong>⚙️ Ratio :</strong> @reel.GearRatio</p>
                        }
                        @if (!string.IsNullOrEmpty(reel.Notes))
                        {
                            <p class="card-text mt-3"><small class="text-muted">💭 @reel.Notes</small></p>
                        }
                    </div>
                    <div class="card-footer">
                        <div class="btn-group w-100" role="group">
                            <a href="/FishingSpot_App/materiel/moulinets/modifier/@reel.Id" class="btn btn-outline-primary">
                                ✏️ Modifier
                            </a>
                            <button class="btn btn-outline-danger" @onclick="() => ShowDeleteConfirmation(reel)">
                                🗑️ Supprimer
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showDeleteModal && reelToDelete != null)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>⚠️ Confirmer la suppression</h3>
            </div>
            <div class="modal-body">
                <p>Êtes-vous sûr de vouloir supprimer ce moulinet ?</p>
                <p><strong>@reelToDelete.Brand @reelToDelete.Model</strong></p>
                <p class="text-danger">⚠️ Les montages utilisant ce moulinet ne seront pas supprimés mais perdront cette référence.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">
                    Annuler
                </button>
                <button type="button" class="btn btn-danger" @onclick="HandleDelete" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <div class="spinner"></div>
                    }
                    Supprimer
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Reel>? reels;
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private bool isDeleting = false;
    private Reel? reelToDelete;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }
        await LoadReels();
    }

    private async Task LoadReels()
    {
        isLoading = true;
        try
        {
            reels = await EquipmentService.GetAllReelsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
            reels = new List<Reel>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowDeleteConfirmation(Reel reel)
    {
        reelToDelete = reel;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        reelToDelete = null;
        showDeleteModal = false;
    }

    private async Task HandleDelete()
    {
        if (reelToDelete == null) return;
        isDeleting = true;
        try
        {
            var success = await EquipmentService.DeleteReelAsync(reelToDelete.Id);
            if (success)
            {
                showDeleteModal = false;
                reelToDelete = null;
                await LoadReels();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isDeleting = false;
        }
    }
}
