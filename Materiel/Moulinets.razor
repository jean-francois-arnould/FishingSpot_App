
@page "/materiel/moulinets"
@page "/FishingSpot_App/materiel/moulinets"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Mes Moulinets</PageTitle>

<div class="container-fluid">
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">🎣 FishingSpot</a>
            <div class="navbar-nav me-auto">
                <a class="nav-link" href="/catches">Mes Prises</a>
                <a class="nav-link" href="/montages">Montages</a>
                <a class="nav-link active" href="/materiel">Matériel</a>
                <a class="nav-link" href="/profile">Profil</a>
            </div>
            <div class="d-flex">
                <span class="navbar-text me-3">👋 @AuthService.CurrentUser?.Email</span>
                <button class="btn btn-outline-danger btn-sm" @onclick="HandleLogout">Déconnexion</button>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <a href="/materiel" class="btn btn-outline-secondary btn-sm mb-2">← Retour au matériel</a>
                <h1>🎡 Mes Moulinets</h1>
            </div>
            <a href="/materiel/moulinets/ajouter" class="btn btn-success btn-lg">➕ Ajouter un moulinet</a>
        </div>

        @if (isLoading)
        {
            <div class="text-center my-5">
                <div class="spinner-border text-success" role="status"></div>
                <p class="mt-2">Chargement des moulinets...</p>
            </div>
        }
        else if (reels == null || !reels.Any())
        {
            <div class="alert alert-info text-center my-5">
                <h4>Aucun moulinet enregistré</h4>
                <p>Commencez par ajouter votre premier moulinet !</p>
                <a href="/materiel/moulinets/ajouter" class="btn btn-success mt-3">➕ Ajouter mon premier moulinet</a>
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var reel in reels)
                {
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0">@reel.Brand @reel.Model</h5>
                            </div>
                            <div class="card-body">
                                @if (!string.IsNullOrEmpty(reel.Type))
                                {
                                    <p class="mb-2"><strong>🎡 Type :</strong> @reel.Type</p>
                                }
                                @if (!string.IsNullOrEmpty(reel.GearRatio))
                                {
                                    <p class="mb-2"><strong>⚙️ Ratio :</strong> @reel.GearRatio</p>
                                }
                                @if (!string.IsNullOrEmpty(reel.Notes))
                                {
                                    <p class="card-text mt-3"><small class="text-muted">💭 @reel.Notes</small></p>
                                }
                            </div>
                            <div class="card-footer">
                                <div class="btn-group w-100" role="group">
                                    <a href="/materiel/moulinets/modifier/@reel.Id" class="btn btn-outline-success">✏️ Modifier</a>
                                    <button class="btn btn-outline-danger" @onclick="() => ShowDeleteConfirmation(reel)">🗑️ Supprimer</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (showDeleteModal && reelToDelete != null)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">⚠️ Confirmer la suppression</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Êtes-vous sûr de vouloir supprimer ce moulinet ?</p>
                    <p><strong>@reelToDelete.Brand @reelToDelete.Model</strong></p>
                    <p class="text-danger">⚠️ Les montages utilisant ce moulinet ne seront pas supprimés mais perdront cette référence.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Annuler</button>
                    <button type="button" class="btn btn-danger" @onclick="HandleDelete" disabled="@isDeleting">
                        @if (isDeleting) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        Supprimer
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Reel>? reels;
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private bool isDeleting = false;
    private Reel? reelToDelete;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }
        await LoadReels();
    }

    private async Task LoadReels()
    {
        isLoading = true;
        try
        {
            reels = await EquipmentService.GetAllReelsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
            reels = new List<Reel>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowDeleteConfirmation(Reel reel)
    {
        reelToDelete = reel;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        reelToDelete = null;
        showDeleteModal = false;
    }

    private async Task HandleDelete()
    {
        if (reelToDelete == null) return;
        isDeleting = true;
        try
        {
            var success = await EquipmentService.DeleteReelAsync(reelToDelete.Id);
            if (success)
            {
                showDeleteModal = false;
                reelToDelete = null;
                await LoadReels();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isDeleting = false;
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/FishingSpot_App/");
    }
}
