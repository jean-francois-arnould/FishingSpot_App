
@page "/montages"
@page "/FishingSpot_App/montages"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject ISupabaseService SupabaseService
@inject IEquipmentService EquipmentService
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject NavigationManager Navigation

<PageTitle>Mes Montages</PageTitle>

<div class="container-fluid">
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/FishingSpot_App/">🎣 FishingSpot</a>
            <div class="navbar-nav me-auto">
                <a class="nav-link" href="/FishingSpot_App/catches">Mes Prises</a>
                <a class="nav-link active" href="/FishingSpot_App/montages">Montages</a>
                <a class="nav-link" href="/FishingSpot_App/materiel">Matériel</a>
                <a class="nav-link" href="/FishingSpot_App/profile">Profil</a>
            </div>
            <div class="d-flex">
                <span class="navbar-text me-3">
                    👋 @(userProfile != null && !string.IsNullOrEmpty(userProfile.FirstName) 
                        ? $"{userProfile.FirstName} {userProfile.LastName}" 
                        : AuthService.CurrentUser?.Email)
                </span>
                <button class="btn btn-outline-danger btn-sm" @onclick="HandleLogout">
                    Déconnexion
                </button>
            </div>
        </div>
    </nav>

    <div class="container">
        <h3 class="mb-4">🎣 Mes Montages</h3>

        @if (isLoading)
        {
            <div class="text-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Chargement...</span>
                </div>
            </div>
        }
        else if (setups == null || !setups.Any())
        {
            <div class="alert alert-info">
                <p class="mb-0">Vous n'avez pas encore de montages enregistrés. Créez votre premier montage en combinant votre matériel !</p>
            </div>
        }
        else
        {
            <div class="row">
        @foreach (var setup in setups)
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card h-100 @(setup.IsCurrent ? "border-success border-3" : "")">
                    <div class="card-header @(setup.IsCurrent ? "bg-success text-white" : "bg-primary text-white")">
                        <h5 class="card-title mb-0">
                            @if (setup.IsCurrent)
                            {
                                <span class="badge bg-warning text-dark me-2">ACTUEL</span>
                            }
                            @(string.IsNullOrEmpty(setup.Description) ? "Montage sans nom" : setup.Description)
                        </h5>
                    </div>
                    <div class="card-body">
                        @if (equipmentDetails.ContainsKey(setup.Id))
                        {
                            var details = equipmentDetails[setup.Id];
                            <p class="card-text">
                                @if (details.Rod != null)
                                {
                                    <span><strong>🎣 Canne:</strong> @details.Rod.Brand @details.Rod.Model<br /></span>
                                }
                                @if (details.Reel != null)
                                {
                                    <span><strong>🎡 Moulinet:</strong> @details.Reel.Brand @details.Reel.Model<br /></span>
                                }
                                @if (details.Line != null)
                                {
                                    <span><strong>🧵 Fil:</strong> @details.Line.Brand @details.Line.Type<br /></span>
                                }
                                @if (details.Lure != null)
                                {
                                    <span><strong>🪝 Leurre:</strong> @details.Lure.Name<br /></span>
                                }
                                @if (details.Leader != null)
                                {
                                    <span><strong>⛓️ Bas de ligne:</strong> @details.Leader.Material<br /></span>
                                }
                                @if (details.Hook != null)
                                {
                                    <span><strong>🪝 Hameçon:</strong> Taille @details.Hook.Size</span>
                                }
                            </p>
                        }
                        else
                        {
                            <p class="text-muted">Aucun équipement configuré</p>
                        }

                        @if (setup.IsFavorite)
                        {
                            <span class="badge bg-warning text-dark">⭐ Favori</span>
                        }
                    </div>
                    <div class="card-footer bg-transparent">
                        @if (!setup.IsCurrent)
                        {
                            <button class="btn btn-sm btn-success me-1" @onclick="() => SetAsCurrent(setup.Id)">
                                <i class="bi bi-check-circle"></i> Définir comme actuel
                            </button>
                        }
                        <button class="btn btn-sm btn-primary me-1" @onclick="() => EditSetup(setup.Id)">
                            <i class="bi bi-pencil"></i> Modifier
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => ShowDeleteConfirmation(setup)">
                            <i class="bi bi-trash"></i> Supprimer
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

    <div class="mt-3">
                <button class="btn btn-success" @onclick="AddSetup">
                    <i class="bi bi-plus-circle"></i> Créer un montage
                </button>
            </div>

            @if (showDeleteModal)
            {
                <div class="modal fade show" style="display: block;" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Confirmer la suppression</h5>
                                <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                            </div>
                            <div class="modal-body">
                                <p>Êtes-vous sûr de vouloir supprimer le montage <strong>@(string.IsNullOrEmpty(setupToDelete?.Description) ? "sans nom" : setupToDelete?.Description)</strong> ?</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Annuler</button>
                                <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Supprimer</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-backdrop fade show"></div>
            }
            </div>
        </div>

@code {
    private List<FishingSetup> setups = new();
    private Dictionary<int, SetupEquipmentDetails> equipmentDetails = new();
    private UserProfile? userProfile;
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private FishingSetup? setupToDelete = null;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        // Charger le profil et les montages en parallèle
        var profileTask = ProfileService.GetProfileAsync();
        var setupsTask = LoadSetups();

        await Task.WhenAll(profileTask, setupsTask);

        userProfile = await profileTask;
    }

    private async Task LoadSetups()
    {
        isLoading = true;
        try
        {
            setups = await SupabaseService.GetAllSetupsAsync();

            // Charger les détails du matériel pour chaque montage
            equipmentDetails.Clear();
            foreach (var setup in setups)
            {
                equipmentDetails[setup.Id] = await LoadEquipmentDetails(setup);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des montages: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<SetupEquipmentDetails> LoadEquipmentDetails(FishingSetup setup)
    {
        var details = new SetupEquipmentDetails();

        try
        {
            // Charger chaque pièce d'équipement si l'ID existe
            if (setup.RodId.HasValue)
            {
                var rods = await EquipmentService.GetAllRodsAsync();
                details.Rod = rods.FirstOrDefault(r => r.Id == setup.RodId.Value);
            }

            if (setup.ReelId.HasValue)
            {
                var reels = await EquipmentService.GetAllReelsAsync();
                details.Reel = reels.FirstOrDefault(r => r.Id == setup.ReelId.Value);
            }

            if (setup.LineId.HasValue)
            {
                var lines = await EquipmentService.GetAllLinesAsync();
                details.Line = lines.FirstOrDefault(l => l.Id == setup.LineId.Value);
            }

            if (setup.LureId.HasValue)
            {
                var lures = await EquipmentService.GetAllLuresAsync();
                details.Lure = lures.FirstOrDefault(l => l.Id == setup.LureId.Value);
            }

            if (setup.LeaderId.HasValue)
            {
                var leaders = await EquipmentService.GetAllLeadersAsync();
                details.Leader = leaders.FirstOrDefault(l => l.Id == setup.LeaderId.Value);
            }

            if (setup.HookId.HasValue)
            {
                var hooks = await EquipmentService.GetAllHooksAsync();
                details.Hook = hooks.FirstOrDefault(h => h.Id == setup.HookId.Value);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des détails d'équipement: {ex.Message}");
        }

        return details;
    }

    private async Task SetAsCurrent(int setupId)
    {
        try
        {
            await SupabaseService.SetCurrentSetupAsync(setupId);
            await LoadSetups(); // Recharger pour refléter les changements
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors de la définition du montage actuel: {ex.Message}");
        }
    }

    private void AddSetup()
    {
        Navigation.NavigateTo("/FishingSpot_App/montages/ajouter");
    }

    private void EditSetup(int id)
    {
        Navigation.NavigateTo($"/FishingSpot_App/montages/modifier/{id}");
    }

    private void ShowDeleteConfirmation(FishingSetup setup)
    {
        setupToDelete = setup;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
        setupToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (setupToDelete != null)
        {
            try
            {
                await SupabaseService.DeleteSetupAsync(setupToDelete.Id);
                await LoadSetups();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erreur lors de la suppression: {ex.Message}");
            }
        }
        showDeleteModal = false;
        setupToDelete = null;
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/FishingSpot_App/login");
    }

    // Classe pour organiser les détails de l'équipement
    private class SetupEquipmentDetails
    {
        public Rod? Rod { get; set; }
        public Reel? Reel { get; set; }
        public Line? Line { get; set; }
        public Lure? Lure { get; set; }
        public Leader? Leader { get; set; }
        public Hook? Hook { get; set; }
    }
}
