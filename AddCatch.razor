    private async Task GetCurrentLocation()
    {
        isGettingLocation = true;
        errorMessage = null;

        try
        {
            // Appeler l'API Geolocation via JavaScript
            var position = await JSRuntime.InvokeAsync<GeolocationPosition>("getCurrentPosition");

            if (position != null)
            {
                newCatch.Latitude = position.Latitude;
                newCatch.Longitude = position.Longitude;

                // Reverse geocoding pour obtenir le nom du lieu
                try
                {
                    var locationName = await JSRuntime.InvokeAsync<string>("reverseGeocode", position.Latitude, position.Longitude);
                    if (!string.IsNullOrEmpty(locationName))
                    {
                        newCatch.LocationName = locationName;
                    }
                    successMessage = "📍 Position et lieu récupérés avec succès !";
                }
                catch
                {
                    successMessage = "📍 Position récupérée (lieu non trouvé)";
                }

                // Récupérer automatiquement la météo après avoir obtenu la position (si activée et en mode auto)
                if (useWeatherData && weatherMode == "auto")
                {
                    await GetWeatherData();
                }

                await Task.Delay(2000);
                successMessage = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error getting location: {ex.Message}");
            errorMessage = "Impossible de récupérer votre position. Vérifiez que vous avez autorisé l'accès à la localisation.";
        }
        finally
        {
            isGettingLocation = false;
        }
    }

    private async Task GetWeatherData()
    {
        if (string.IsNullOrEmpty(newCatch.Latitude) || string.IsNullOrEmpty(newCatch.Longitude))
        {
            return;
        }

        if (!double.TryParse(newCatch.Latitude, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out double lat) ||
            !double.TryParse(newCatch.Longitude, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out double lon))
        {
            return;
        }

        isGettingWeather = true;
        errorMessage = null;

        try
        {
            weatherData = await WeatherService.GetCurrentWeatherAsync(lat, lon);

            if (weatherData != null)
            {
                // Enregistrer les données météo dans la prise
                newCatch.WeatherTemperature = weatherData.Temperature;
                newCatch.WeatherCondition = weatherData.WeatherDescription;
                newCatch.WeatherCode = weatherData.WeatherCode;
                newCatch.WindSpeed = weatherData.WindSpeed;
                newCatch.Humidity = weatherData.Humidity;

                successMessage = "🌤️ Données météo récupérées !";
                await Task.Delay(2000);
                successMessage = null;
            }
            else
            {
                errorMessage = "Impossible de récupérer les données météo";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error getting weather: {ex.Message}");
            errorMessage = "Erreur lors de la récupération de la météo";
        }
        finally
        {
            isGettingWeather = false;
            StateHasChanged();
        }
    }

    private void OnWeatherToggleChanged()
    {
        if (!useWeatherData)
        {
            // Si on désactive la météo, réinitialiser les données
            weatherData = null;
