@page "/catches/add"
@page "/FishingSpot_App/catches/add"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@using Microsoft.JSInterop
@inject ISupabaseService SupabaseService
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject IWeatherService WeatherService
@inject IImageCompressionService ImageCompression
@inject IToastService Toast
@inject ILoggerService Logger
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Ajouter une prise</PageTitle>

<div class="page-content">
    @if (isLoadingData)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement...</p>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">
                @errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">
                @successMessage
            </div>
        }

    <EditForm Model="@newCatch" OnValidSubmit="HandleAddCatch">
        <DataAnnotationsValidator />

        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">🐟 Information du poisson</h3>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label for="fishName" class="form-label">Espèce *</label>
                    <div class="fish-species-readonly">
                        <input type="text" 
                               id="fishName" 
                               class="form-control" 
                               value="@GetFishDisplayValue()" 
                               placeholder="Sélectionner un poisson..." 
                               readonly 
                               required />
                    </div>
                    <div class="fish-species-buttons">
                        @if (availableFishSpecies != null && availableFishSpecies.Any())
                        {
                            <button type="button" class="btn btn-primary" @onclick="ShowFishSpeciesList">
                                🔍 Chercher dans la liste
                            </button>
                        }
                        <button type="button" class="btn btn-success" @onclick="ShowAddFishSpeciesForm">
                            ➕ Ajouter une nouvelle espèce
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(fishSpeciesError))
                    {
                        <small class="text-warning">
                            ⚠️ @fishSpeciesError
                        </small>
                    }
                    @if (selectedFishInfo != null && !string.IsNullOrEmpty(selectedFishInfo.Description))
                    {
                        <small class="text-muted">
                            @selectedFishInfo.IconEmoji @selectedFishInfo.Description
                            @if (selectedFishInfo.MinLegalSize.HasValue)
                            {
                                <span class="badge bg-warning text-dark ms-2">
                                    Taille légale: @selectedFishInfo.MinLegalSize cm
                                </span>
                            }
                        </small>
                    }
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">📏 Longueur</label>
                        <div class="measurement-input">
                            <div class="measurement-unit">
                                <InputSelect class="form-control" @bind-Value="newCatch.LengthMeters">
                                    @foreach (var m in FishSpeciesHelper.LengthMetersOptions)
                                    {
                                        <option value="@m">@m m</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="measurement-unit">
                                <InputSelect class="form-control" @bind-Value="newCatch.LengthCentimeters">
                                    @foreach (var cm in FishSpeciesHelper.LengthCentimetersOptions)
                                    {
                                        <option value="@cm">@cm cm</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">⚖️ Poids</label>
                        <div class="measurement-input">
                            <div class="measurement-unit">
                                <InputSelect class="form-control" @bind-Value="newCatch.WeightKilograms">
                                    @foreach (var kg in FishSpeciesHelper.WeightKilogramsOptions)
                                    {
                                        <option value="@kg">@kg kg</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="measurement-unit">
                                <InputSelect class="form-control" @bind-Value="newCatch.WeightGrams">
                                    @foreach (var g in FishSpeciesHelper.WeightGramsOptions)
                                    {
                                        <option value="@g">@g g</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">📍 Lieu et date</h3>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label for="locationName" class="form-label">Lieu</label>
                    <InputText id="locationName" class="form-control" @bind-Value="newCatch.LocationName" 
                               placeholder="Ex: Lac Léman, Rivière Loire..." />
                </div>

                <div class="form-group">
                    <label for="latitude" class="form-label">Coordonnées GPS (optionnel)</label>
                    <div class="gps-fields">
                        <input type="text" id="latitude" class="form-control" @bind="newCatch.Latitude" 
                               placeholder="Latitude" inputmode="decimal" readonly />
                        <input type="text" id="longitude" class="form-control" @bind="newCatch.Longitude" 
                               placeholder="Longitude" inputmode="decimal" readonly />
                        <button type="button" class="btn btn-outline-primary" @onclick="GetCurrentLocation" disabled="@isGettingLocation" title="Obtenir ma position">
                            @if (isGettingLocation)
                            {
                                <div class="spinner"></div>
                            }
                            else
                            {
                                <span>📍</span>
                            }
                        </button>
                        @if (!string.IsNullOrEmpty(newCatch.Latitude) && !string.IsNullOrEmpty(newCatch.Longitude))
                        {
                            <button type="button" class="btn btn-outline-secondary" @onclick="CopyGpsCoordinates" title="Copier les coordonnées">
                                📋
                            </button>
                        }
                    </div>
                    <small class="text-muted">Position détectée automatiquement • Cliquez sur 📋 pour partager</small>
                </div>

                <div class="form-group">
                    <label class="form-label">🌤️ Conditions météo</label>

                    <!-- Toggle pour activer/désactiver la météo -->
                    <div class="weather-toggle">
                        <label class="toggle-switch">
                            <input type="checkbox" @bind="useWeatherData" @bind:after="OnWeatherToggleChanged" />
                            <span class="toggle-slider"></span>
                        </label>
                        <span class="toggle-label">@(useWeatherData ? "Météo activée" : "Météo désactivée")</span>
                    </div>

                    @if (useWeatherData)
                    {
                        <div class="weather-mode-selector">
                            <button type="button" 
                                    class="btn btn-sm @(weatherMode == "auto" ? "btn-primary" : "btn-outline-secondary")" 
                                    @onclick="@(() => SetWeatherMode("auto"))">
                                🤖 Automatique
                            </button>
                            <button type="button" 
                                    class="btn btn-sm @(weatherMode == "manual" ? "btn-primary" : "btn-outline-secondary")" 
                                    @onclick="@(() => SetWeatherMode("manual"))">
                                ✏️ Manuel
                            </button>
                        </div>

                        @if (weatherMode == "auto")
                        {
                            @if (weatherData != null)
                            {
                                <div class="weather-info">
                                    <div class="weather-main">
                                        <span class="weather-icon">@weatherData.WeatherEmoji</span>
                                        <span class="weather-temp">@weatherData.Temperature.ToString("F1")°C</span>
                                        <span class="weather-desc">@weatherData.WeatherDescription</span>
                                    </div>
                                    <div class="weather-details">
                                        <small>💨 Vent: @weatherData.WindSpeed.ToString("F1") km/h</small>
                                        <small>💧 Humidité: @weatherData.Humidity%</small>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-secondary mt-2" @onclick="GetWeatherData">
                                        🔄 Actualiser la météo
                                    </button>
                                </div>
                            }
                            else if (isGettingWeather)
                            {
                                <div class="weather-loading">
                                    <div class="spinner"></div>
                                    <span>Récupération de la météo...</span>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(newCatch.Latitude) && !string.IsNullOrEmpty(newCatch.Longitude))
                            {
                                <button type="button" class="btn btn-outline-primary" @onclick="GetWeatherData">
                                    🌤️ Récupérer la météo
                                </button>
                            }
                            else
                            {
                                <small class="text-muted">Obtenez d'abord votre position GPS pour récupérer la météo</small>
                            }
                        }
                        else if (weatherMode == "manual")
                        {
                            <div class="weather-manual-inputs">
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">🌡️ Température (°C)</label>
                                        <InputNumber class="form-control" @bind-Value="manualTemperature" step="0.1" placeholder="Ex: 18.5" />
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">💧 Humidité (%)</label>
                                        <InputNumber class="form-control" @bind-Value="manualHumidity" min="0" max="100" placeholder="Ex: 65" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">💨 Vitesse du vent (km/h)</label>
                                        <InputNumber class="form-control" @bind-Value="manualWindSpeed" step="0.1" placeholder="Ex: 12.5" />
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">☁️ Condition</label>
                                        <InputText class="form-control" @bind-Value="manualWeatherCondition" placeholder="Ex: Ensoleillé, Nuageux..." />
                                    </div>
                                </div>
                                <small class="text-muted">💡 Saisissez manuellement les conditions météo au moment de la prise</small>
                            </div>
                        }
                    }
                    else
                    {
                        <small class="text-muted">Les données météo ne seront pas enregistrées pour cette prise</small>
                    }
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="catchDate" class="form-label">Date *</label>
                        <InputDate id="catchDate" class="form-control" @bind-Value="newCatch.CatchDate" required />
                    </div>
                    <div class="form-group">
                        <label for="catchTime" class="form-label">Heure</label>
                        <InputText id="catchTime" class="form-control" @bind-Value="newCatch.CatchTimeString" 
                                 placeholder="14:30" type="time" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">📸 Photo et détails</h3>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label class="form-label">Photo</label>
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-primary" @onclick="OpenGallery" disabled="@isUploadingPhoto">
                            🖼️ Galerie
                        </button>
                        <button type="button" class="btn btn-outline-primary" @onclick="OpenCamera" disabled="@isUploadingPhoto">
                            📷 Caméra
                        </button>
                    </div>

                    <InputFile id="photoFileGallery" style="display: none;" OnChange="HandlePhotoSelected" accept="image/*" />
                    <InputFile id="photoFileCamera" style="display: none;" OnChange="HandlePhotoSelected" accept="image/*" capture="environment" />

                    @if (isUploadingPhoto)
                    {
                        <div class="upload-status">
                            <div class="spinner"></div>
                            <span>Upload en cours...</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(newCatch.PhotoUrl))
                    {
                        <div class="photo-preview">
                            <img src="@newCatch.PhotoUrl" alt="Aperçu" class="preview-img" />
                            <button type="button" class="btn btn-sm btn-danger" @onclick="RemovePhoto">
                                ❌ Supprimer
                            </button>
                        </div>
                    }
                </div>

                <div class="form-group">
                    <label for="notes" class="form-label">Notes</label>
                    <InputTextArea id="notes" class="form-control" rows="4" @bind-Value="newCatch.Notes" 
                                 placeholder="Conditions météo, appât, technique..." />
                </div>
            </div>
        </div>

        <div class="card setup-card">
            <div class="card-header">
                <h3 class="mb-0">🎣 Montage utilisé</h3>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label for="setupId" class="form-label">Sélectionner un montage</label>
                    <InputSelect id="setupId" class="form-control" @bind-Value="selectedSetupId">
                        <option value="">-- Aucun montage --</option>
                        @if (availableSetups != null && availableSetups.Any())
                        {
                            @foreach (var setup in availableSetups)
                            {
                                <option value="@setup.Id">
                                    @(setup.IsCurrent ? "🎯 " : "")@(setup.IsFavorite ? "⭐ " : "")@setup.Name
                                </option>
                            }
                        }
                    </InputSelect>
                    @if (availableSetups == null || !availableSetups.Any())
                    {
                        <small class="text-muted">Aucun montage disponible. Créez-en un dans la section Montages.</small>
                    }
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">
                Annuler
            </button>
            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                @if (isSaving)
                {
                    <div class="spinner"></div>
                }
                ✅ Enregistrer
            </button>
        </div>
    </EditForm>
    }

    @* Modal pour afficher la liste des poissons *@
    @if (showFishSpeciesModal && availableFishSpecies != null)
    {
        <div class="modal-backdrop" @onclick="HideFishSpeciesModal"></div>
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title">🔍 Sélectionner un poisson</h3>
                    <button type="button" class="btn-close" @onclick="HideFishSpeciesModal">✕</button>
                </div>
                <div class="modal-body">
                    @foreach (var category in availableFishSpecies.GroupBy(f => f.Category).OrderBy(g => GetCategoryOrder(g.Key)))
                    {
                        <div class="fish-category">
                            <h4 class="category-label">@GetCategoryLabel(category.Key)</h4>
                            <div class="fish-list">
                                @foreach (var fish in category.OrderBy(f => f.CommonName))
                                {
                                    <button type="button" class="fish-item" @onclick="() => SelectFishSpecies(fish)">
                                        <span class="fish-icon">@fish.IconEmoji</span>
                                        <div class="fish-info">
                                            <div class="fish-name">@fish.CommonName</div>
                                            @if (!string.IsNullOrEmpty(fish.ScientificName))
                                            {
                                                <div class="fish-scientific">@fish.ScientificName</div>
                                            }
                                        </div>
                                        @if (fish.MinLegalSize.HasValue)
                                        {
                                            <span class="fish-size-badge">@fish.MinLegalSize cm</span>
                                        }
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @* Modal pour ajouter un nouveau poisson *@
    @if (showAddFishModal)
    {
        <div class="modal-backdrop" @onclick="HideAddFishModal"></div>
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h3 class="modal-title">➕ Ajouter un nouveau poisson</h3>
                    <button type="button" class="btn-close" @onclick="HideAddFishModal">✕</button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(addFishError))
                    {
                        <div class="alert alert-danger">@addFishError</div>
                    }
                    @if (!string.IsNullOrEmpty(addFishSuccess))
                    {
                        <div class="alert alert-success">@addFishSuccess</div>
                    }

                    <EditForm Model="@newFishSpecies" OnValidSubmit="HandleAddFishSpecies">
                        <div class="form-group">
                            <label class="form-label">Nom commun *</label>
                            <InputText class="form-control" @bind-Value="newFishSpecies.CommonName" 
                                       placeholder="Ex: Brochet" required />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Nom scientifique</label>
                            <InputText class="form-control" @bind-Value="newFishSpecies.ScientificName" 
                                       placeholder="Ex: Esox lucius" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Famille</label>
                            <InputText class="form-control" @bind-Value="newFishSpecies.Family" 
                                       placeholder="Ex: Esocidae" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Catégorie *</label>
                            <InputSelect class="form-control" @bind-Value="newFishSpecies.Category" required>
                                <option value="">-- Sélectionner --</option>
                                <option value="carnassier">🦈 Carnassier</option>
                                <option value="salmonidé">🌊 Salmonidé</option>
                                <option value="migrateur">➡️ Migrateur</option>
                                <option value="cyprinidé">🐠 Cyprinidé</option>
                                <option value="autre">🐟 Autre</option>
                            </InputSelect>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Taille légale minimale (cm)</label>
                            <InputNumber class="form-control" @bind-Value="newFishSpecies.MinLegalSize" 
                                         placeholder="Ex: 60" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Emoji / Icône *</label>
                            <InputText class="form-control" @bind-Value="newFishSpecies.IconEmoji" 
                                       placeholder="Ex: 🐟" maxlength="5" required />
                            <small class="text-muted">Un emoji pour représenter le poisson</small>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="newFishSpecies.Description" 
                                           placeholder="Description du poisson..." />
                        </div>

                        <div class="modal-actions">
                            <button type="button" class="btn btn-outline-secondary" @onclick="HideAddFishModal">
                                Annuler
                            </button>
                            <button type="submit" class="btn btn-primary" disabled="@isAddingFish">
                                @if (isAddingFish)
                                {
                                    <div class="spinner"></div>
                                }
                                ✅ Ajouter
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private FishCatch newCatch = new FishCatch
    {
        CatchDate = DateTime.Today,
        CatchTimeString = DateTime.Now.ToString("HH:mm")
    };

    private List<FishingSetup>? availableSetups;
    private List<FishSpecies>? availableFishSpecies;
    private FishSpecies? selectedFishInfo;
    private FishSpecies newFishSpecies = new FishSpecies();
    private UserProfile? userProfile;
    private string selectedSetupId = "";
    private string selectedFishSpecies = "";
    private string? errorMessage;
    private string? successMessage;
    private string? fishSpeciesError;
    private string? addFishError;
    private string? addFishSuccess;
    private bool isSaving;
    private bool isUploadingPhoto;
    private bool isGettingLocation;
    private bool isAddingFish;
    private bool showFishSpeciesModal = false;
    private bool showAddFishModal = false;
    private bool isLoadingData = true;
    private WeatherData? weatherData;
    private bool isGettingWeather = false;

    // Météo optionnelle et éditable
    private bool useWeatherData = true; // Par défaut activé
    private string weatherMode = "auto"; // "auto" ou "manual"
    private double? manualTemperature = null;
    private int? manualHumidity = null;
    private double? manualWindSpeed = null;
    private string? manualWeatherCondition = null;

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine($"🔵 [OnInitializedAsync] Composant initialisé - newCatch.Id = {newCatch.Id}");

        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        // Load available setups, profile and fish species
        try
        {
            // Charger le profil, les setups et les espèces en parallèle
            var profileTask = ProfileService.GetProfileAsync();
            var setupsTask = SupabaseService.GetAllSetupsAsync();
            var speciesTask = SupabaseService.GetAllFishSpeciesAsync();

            await Task.WhenAll(profileTask, setupsTask, speciesTask);

            userProfile = await profileTask;
            availableSetups = await setupsTask;
            availableFishSpecies = await speciesTask;

            if (availableFishSpecies != null && availableFishSpecies.Any())
            {
                Console.WriteLine($"✅ Loaded {availableFishSpecies.Count} fish species");
            }
            else
            {
                Console.WriteLine("⚠️ No fish species loaded - using manual entry");
                fishSpeciesError = "Liste des poissons non disponible. Veuillez saisir le nom manuellement.";
            }

            // Pré-sélectionner le montage actuel s'il existe
            var currentSetup = availableSetups?.FirstOrDefault(s => s.IsCurrent);
            if (currentSetup != null)
            {
                selectedSetupId = currentSetup.Id.ToString();
                newCatch.SetupId = currentSetup.Id;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
            fishSpeciesError = "Impossible de charger la liste des poissons. Saisie manuelle disponible.";
        }
        finally
        {
            isLoadingData = false;
        }

        // Lancer la géolocalisation automatiquement au chargement
        await GetCurrentLocation();
    }

    protected override void OnParametersSet()
    {
        // La réinitialisation n'est plus nécessaire car nous créons une copie lors de la sauvegarde
        // Cela évite que l'objet newCatch soit modifié par référence
        base.OnParametersSet();
    }

    private void ShowFishSpeciesList()
    {
        showFishSpeciesModal = true;
    }

    private void HideFishSpeciesModal()
    {
        showFishSpeciesModal = false;
    }

    private string GetFishDisplayValue()
    {
        if (selectedFishInfo != null)
        {
            return selectedFishInfo.DisplayName;
        }
        else if (!string.IsNullOrEmpty(newCatch.FishName))
        {
            return newCatch.FishName;
        }
        return "";
    }

    private void SelectFishSpecies(FishSpecies fish)
    {
        newCatch.FishName = fish.CommonName;
        selectedFishInfo = fish;
        showFishSpeciesModal = false;
    }

    private void ShowAddFishSpeciesForm()
    {
        newFishSpecies = new FishSpecies
        {
            IconEmoji = "🐟"
        };
        addFishError = null;
        addFishSuccess = null;
        showAddFishModal = true;
    }

    private void HideAddFishModal()
    {
        showAddFishModal = false;
        newFishSpecies = new FishSpecies();
        addFishError = null;
        addFishSuccess = null;
    }

    private async Task HandleAddFishSpecies()
    {
        addFishError = null;
        addFishSuccess = null;
        isAddingFish = true;

        try
        {
            // Validation
            if (string.IsNullOrWhiteSpace(newFishSpecies.CommonName))
            {
                addFishError = "Le nom commun est requis.";
                isAddingFish = false;
                return;
            }

            if (string.IsNullOrWhiteSpace(newFishSpecies.Category))
            {
                addFishError = "La catégorie est requise.";
                isAddingFish = false;
                return;
            }

            if (string.IsNullOrWhiteSpace(newFishSpecies.IconEmoji))
            {
                addFishError = "L'emoji / icône est requis.";
                isAddingFish = false;
                return;
            }

            Console.WriteLine($"Attempting to add fish species: {newFishSpecies.CommonName}");
            var fishId = await SupabaseService.AddFishSpeciesAsync(newFishSpecies);

            if (fishId == -1)
            {
                addFishError = $"❌ Le poisson '{newFishSpecies.CommonName}' existe déjà dans la base de données.";
                isAddingFish = false;
                return;
            }

            if (fishId > 0)
            {
                addFishSuccess = $"✅ Le poisson '{newFishSpecies.CommonName}' a été ajouté avec succès !";
                Console.WriteLine($"Fish species added with ID: {fishId}");

                // Recharger la liste des poissons
                availableFishSpecies = await SupabaseService.GetAllFishSpeciesAsync();

                // Sélectionner automatiquement le nouveau poisson
                newCatch.FishName = newFishSpecies.CommonName;
                selectedFishInfo = availableFishSpecies?.FirstOrDefault(f => f.Id == fishId);

                // Attendre 2 secondes puis fermer le modal
                await Task.Delay(2000);
                HideAddFishModal();
            }
            else
            {
