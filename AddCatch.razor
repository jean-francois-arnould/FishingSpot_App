    private async Task HandlePhotoSelected(InputFileChangeEventArgs e)
    {
        isUploadingPhoto = true;
        errorMessage = null;
        string? tempPhotoUrl = null;

        try
        {
            var file = e.File;
            if (file != null)
            {
                // Vérifier la taille (max 5 MB)
                if (file.Size > 5 * 1024 * 1024)
                {
                    errorMessage = "La photo est trop volumineuse (max 5 MB).";
                    isUploadingPhoto = false;
                    StateHasChanged();
                    return;
                }

                // Vérifier le type
                if (!file.ContentType.StartsWith("image/"))
                {
                    errorMessage = "Seules les images sont acceptées.";
                    isUploadingPhoto = false;
                    StateHasChanged();
                    return;
                }

                Console.WriteLine($"📸 Traitement de la photo : {file.Name} ({file.Size} bytes)");

                // Étape 1 : Lire le fichier en mémoire
                var buffer = new byte[file.Size];
                await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
                Console.WriteLine($"✅ Fichier lu en mémoire");

                // Étape 2 : Convertir en base64 pour la compression JavaScript
                var base64Original = Convert.ToBase64String(buffer);
                var base64DataUrl = $"data:{file.ContentType};base64,{base64Original}";
                Console.WriteLine($"✅ Conversion base64 terminée");

                // Étape 3 : Compresser l'image avec le service
                Console.WriteLine($"🗜️ Compression de l'image...");
                var compressionStartTime = DateTime.Now;
                var compressed = await ImageCompression.CompressImageAsync(base64DataUrl, maxWidth: 1200, thumbnailSize: 150, quality: 85);
                var compressionTime = (DateTime.Now - compressionStartTime).TotalMilliseconds;

                var reductionPercent = 100 - (compressed.CompressedSize * 100 / compressed.OriginalSize);
                Console.WriteLine($"✅ Compression terminée en {compressionTime:F0}ms");
                Console.WriteLine($"📊 Taille originale: {compressed.OriginalSize / 1024}KB");
                Console.WriteLine($"📊 Taille compressée: {compressed.CompressedSize / 1024}KB");
                Console.WriteLine($"📊 Réduction: {reductionPercent:F1}%");

                // Étape 4 : Afficher l'aperçu immédiatement (version compressée)
                tempPhotoUrl = compressed.Base64Data;
                newCatch.PhotoUrl = tempPhotoUrl;
                StateHasChanged();
                Console.WriteLine($"✅ Aperçu affiché");

                // Étape 5 : Upload vers Supabase Storage en arrière-plan (si online)
                try
                {
                    Console.WriteLine($"🌐 Upload vers Supabase...");
                    var uploadStartTime = DateTime.Now;

                    // Extraire les données base64 (sans le préfixe data:image/jpeg;base64,)
                    var base64Data = compressed.Base64Data.Contains(",") 
                        ? compressed.Base64Data.Split(',')[1] 
                        : compressed.Base64Data;
                    var compressedBytes = Convert.FromBase64String(base64Data);
                    var stream = new MemoryStream(compressedBytes);

                    var photoUrl = await SupabaseService.UploadPhotoAsync(stream, file.Name);
                    var uploadTime = (DateTime.Now - uploadStartTime).TotalMilliseconds;
                    Console.WriteLine($"✅ Upload terminé en {uploadTime:F0}ms");

                    if (!string.IsNullOrEmpty(photoUrl) && !photoUrl.StartsWith("offline_"))
                    {
                        newCatch.PhotoUrl = photoUrl; // Remplacer par l'URL Supabase
                        successMessage = $"✅ Photo uploadée avec succès ! (-{reductionPercent:F0}% taille)";
                        StateHasChanged();
                        await Task.Delay(2000);
                        successMessage = null;
                        StateHasChanged();
                    }
                    else
                    {
                        // Mode offline : garder l'aperçu local
                        Console.WriteLine("⚠️ Mode offline détecté, la photo sera uploadée lors de la synchronisation");
                        successMessage = "📸 Photo ajoutée (sera uploadée en ligne)";
                        StateHasChanged();
                        await Task.Delay(2000);
                        successMessage = null;
                        StateHasChanged();
                    }
                }
                catch (Exception uploadEx)
                {
                    Console.WriteLine($"⚠️ Erreur upload photo (mode offline?): {uploadEx.Message}");
                    // Garder l'aperçu local en mode offline
                    successMessage = "📸 Photo ajoutée localement";
                    StateHasChanged();
                    await Task.Delay(2000);
                    successMessage = null;
                    StateHasChanged();
                }
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error uploading photo: {ex.Message}");
                    errorMessage = $"Erreur lors de l'upload: {ex.Message}";
                    if (!string.IsNullOrEmpty(tempPhotoUrl))
                    {
                        newCatch.PhotoUrl = tempPhotoUrl; // Garder l'aperçu local en cas d'erreur
                    }
                    StateHasChanged();
                }
                finally
                {
                    isUploadingPhoto = false;
                    StateHasChanged();
                }
    }

