    private void SetWeatherMode(string mode)
    {
        weatherMode = mode;
        Console.WriteLine($"🌤️ Mode météo changé: {mode}");

        if (mode == "manual")
        {
            // Pré-remplir avec les données existantes si disponibles
            if (weatherData != null)
            {
                manualTemperature = weatherData.Temperature;
                manualHumidity = weatherData.Humidity;
                manualWindSpeed = weatherData.WindSpeed;
                manualWeatherCondition = weatherData.WeatherDescription;
            }
            else if (newCatch.WeatherTemperature.HasValue)
            {
                manualTemperature = newCatch.WeatherTemperature;
                manualHumidity = newCatch.Humidity;
                manualWindSpeed = newCatch.WindSpeed;
                manualWeatherCondition = newCatch.WeatherCondition;
            }
        }
    }

    private async Task HandleAddCatch()
    {
        // Empêcher les soumissions multiples (protection critique)
        if (isSaving)
        {
            Console.WriteLine("⚠️ ⚠️ ⚠️ DOUBLE SUBMISSION BLOCKED! Save already in progress.");
            return;
        }

        errorMessage = null;
        successMessage = null;
        isSaving = true; // ✅ Bloquer IMMÉDIATEMENT avant toute opération async
        StateHasChanged(); // Forcer le re-render pour désactiver le bouton

        try
        {
            // Vérifier l'authentification
            if (!AuthService.IsAuthenticated || AuthService.CurrentUser == null)
            {
                errorMessage = "❌ Vous devez être connecté pour enregistrer une prise. Veuillez vous reconnecter.";
                Console.WriteLine("User not authenticated - redirecting to login");
                await Task.Delay(2000);
                Navigation.NavigateTo("/FishingSpot_App/login");
                return;
            }

            // Validation basique
            if (string.IsNullOrWhiteSpace(newCatch.FishName))
            {
                errorMessage = "Le nom de l'espèce est requis.";
                return;
            }

            // Convertir le SetupId sélectionné
            if (!string.IsNullOrEmpty(selectedSetupId) && int.TryParse(selectedSetupId, out int setupId))
            {
                newCatch.SetupId = setupId;
            }
            else
            {
                newCatch.SetupId = null;
            }

            Logger.LogInformation("Saving catch", new Dictionary<string, object>
            {
                { "FishName", newCatch.FishName },
                { "UserId", AuthService.CurrentUser.Id }
            });

            Console.WriteLine($"========================================");
            Console.WriteLine($"🎣 DÉBUT DE LA SAUVEGARDE");
            Console.WriteLine($"========================================");
            Console.WriteLine($"User: {AuthService.CurrentUser.Email}");
            Console.WriteLine($"User ID: {AuthService.CurrentUser.Id}");
            Console.WriteLine($"Token présent: {!string.IsNullOrEmpty(AuthService.AccessToken)}");
            Console.WriteLine($"Token expiré: {AuthService.IsTokenExpired}");
            Console.WriteLine($"Poisson: {newCatch.FishName}");
            Console.WriteLine($"Localisation: Lat={newCatch.Latitude}, Lon={newCatch.Longitude}");
            Console.WriteLine($"Taille: {newCatch.Length}cm, Poids: {newCatch.Weight}kg");
            Console.WriteLine($"========================================");

            // Appliquer les données météo selon le mode sélectionné
            if (useWeatherData)
            {
                if (weatherMode == "manual")
                {
                    // Mode manuel : utiliser les données saisies par l'utilisateur
                    newCatch.WeatherTemperature = manualTemperature;
                    newCatch.Humidity = manualHumidity;
                    newCatch.WindSpeed = manualWindSpeed;
                    newCatch.WeatherCondition = manualWeatherCondition;
                    newCatch.WeatherCode = null; // Pas de code météo en mode manuel
                    Console.WriteLine($"🌤️ Météo manuelle: Temp={manualTemperature}°C, Humidité={manualHumidity}%, Vent={manualWindSpeed}km/h");
                }
                else
                {
                    // Mode auto : les données sont déjà dans newCatch si récupérées
                    Console.WriteLine($"🌤️ Météo automatique: Temp={newCatch.WeatherTemperature}°C");
                }
            }
            else
            {
                // Météo désactivée : s'assurer que les champs sont null
                newCatch.WeatherTemperature = null;
                newCatch.WeatherCondition = null;
                newCatch.WeatherCode = null;
                newCatch.WindSpeed = null;
                newCatch.Humidity = null;
                Console.WriteLine($"🌤️ Météo désactivée pour cette prise");
            }

            // ✅ IMPORTANT: Créer une copie pour éviter que les services modifient newCatch par référence
            var catchToSave = new FishCatch
            {
                Id = 0, // Force à 0 pour une nouvelle prise
                UserId = newCatch.UserId,
                FishName = newCatch.FishName,
                PhotoUrl = newCatch.PhotoUrl,
                Latitude = newCatch.Latitude,
                Longitude = newCatch.Longitude,
                LocationName = newCatch.LocationName,
                CatchDate = newCatch.CatchDate,
                CatchTime = newCatch.CatchTime,
                Length = newCatch.Length,
                Weight = newCatch.Weight,
                Notes = newCatch.Notes,
                SetupId = newCatch.SetupId,
                CreatedAt = newCatch.CreatedAt,
                WeatherTemperature = newCatch.WeatherTemperature,
                WeatherCondition = newCatch.WeatherCondition,
                WeatherCode = newCatch.WeatherCode,
                WindSpeed = newCatch.WindSpeed,
                Humidity = newCatch.Humidity
            };

            var catchId = await SupabaseService.AddCatchAsync(catchToSave);

            Console.WriteLine($"========================================");
            Console.WriteLine($"✅ SAUVEGARDE TERMINÉE");
            Console.WriteLine($"ID retourné: {catchId}");
            Console.WriteLine($"Est offline: {catchId < 0}");
            Console.WriteLine($"========================================");

            // Vérifier que l'ID est valide
            if (catchId == 0)
            {
                Logger.LogError("Server returned ID = 0");
                errorMessage = "❌ Erreur critique: Le serveur n'a pas retourné d'ID valide.";
                Toast.ShowError("Erreur critique de sauvegarde");
                isSaving = false;
                StateHasChanged();
                return;
            }

            // ID valide (positif ou négatif)
            Logger.LogInformation("Catch saved successfully", new Dictionary<string, object>
            {
                { "CatchId", catchId },
                { "IsOffline", catchId < 0 }
            });

            if (catchId < 0)
            {
                Console.WriteLine($"📱 Mode offline: Prise enregistrée localement");
                Toast.ShowInfo("Prise enregistrée en mode hors-ligne. Elle sera synchronisée une fois connecté.");
            }
            else
            {
                Console.WriteLine($"🌐 Mode online: Prise enregistrée sur le serveur");
                Toast.ShowSuccess("Prise enregistrée avec succès !");
            }

            // Attendre que le toast soit visible
            await Task.Delay(1500);

            // ✅ IMPORTANT : Réinitialiser l'objet pour éviter la double sauvegarde si l'utilisateur revient
            Console.WriteLine($"🔄 Réinitialisation de newCatch (ancien ID: {newCatch.Id})");
            newCatch = new FishCatch
            {
                CatchDate = DateTime.Today,
                CatchTimeString = DateTime.Now.ToString("HH:mm")
            };
            isSaving = false; // Réinitialiser le flag

            // Navigation vers la liste
            Console.WriteLine($"🔄 Navigation vers /FishingSpot_App/catches");
            Navigation.NavigateTo("/FishingSpot_App/catches", forceLoad: false);
        }
        catch (HttpRequestException ex) when (ex.Message.Contains("409"))
        {
            Logger.LogError("Conflict error (409)", ex);
            Console.WriteLine($"❌ Conflit (409): {ex.Message}");
            errorMessage = "❌ Cette prise existe peut-être déjà. Vérifiez dans la liste.";
            Toast.ShowError("Conflit détecté");
            isSaving = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError("Error adding catch", ex);
            Console.WriteLine($"========================================");
            Console.WriteLine($"❌ ERREUR LORS DE LA SAUVEGARDE");
            Console.WriteLine($"Type: {ex.GetType().Name}");
            Console.WriteLine($"Message: {ex.Message}");
            Console.WriteLine($"Stack: {ex.StackTrace}");
            Console.WriteLine($"========================================");

            if (ex.Message.Contains("401") || ex.Message.Contains("Unauthorized"))
            {
                errorMessage = "❌ Session expirée. Reconnexion requise.";
                Toast.ShowError("Session expirée");
                await Task.Delay(2000);
                Navigation.NavigateTo("/FishingSpot_App/login");
            }
            else if (ex.Message.Contains("409") || ex.Message.Contains("Conflict"))
            {
                errorMessage = "❌ Erreur de conflit (409): Cette prise existe peut-être déjà ou il y a un problème de contrainte unique.";
                Toast.ShowError("Conflit de données. Vérifiez dans la liste des prises.");
            }
            else if (ex.Message.Contains("Empty response") || ex.Message.Contains("return=representation"))
            {
                errorMessage = "❌ Configuration serveur incorrecte. Contactez l'administrateur.";
                Toast.ShowError("Erreur de configuration du serveur.");
            }
            else
            {
                errorMessage = $"❌ Erreur: {ex.Message}";
                Toast.ShowError($"Erreur: {ex.Message.Substring(0, Math.Min(50, ex.Message.Length))}...");
            }

            isSaving = false;
            StateHasChanged();
        }
    }

