@page "/catches/add"
@page "/FishingSpot_App/catches/add"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@using Microsoft.JSInterop
@inject ISupabaseService SupabaseService
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Ajouter une prise</PageTitle>

<div class="page-content">
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
        </div>
    }

    <EditForm Model="@newCatch" OnValidSubmit="HandleAddCatch">
        <DataAnnotationsValidator />

        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">🐟 Information du poisson</h3>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label for="fishName" class="form-label">Espèce *</label>
                    <InputText id="fishName" class="form-control" @bind-Value="newCatch.FishName" 
                               placeholder="Ex: Brochet, Truite, Carpe..." required />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="length" class="form-label">📏 Longueur (cm)</label>
                        <InputNumber id="length" class="form-control" @bind-Value="newCatch.Length" 
                                   placeholder="30" step="0.1" />
                    </div>
                    <div class="form-group">
                        <label for="weight" class="form-label">⚖️ Poids (kg)</label>
                        <InputNumber id="weight" class="form-control" @bind-Value="newCatch.Weight" 
                                   placeholder="2.5" step="0.1" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">📍 Lieu et date</h3>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label for="locationName" class="form-label">Lieu</label>
                    <InputText id="locationName" class="form-control" @bind-Value="newCatch.LocationName" 
                               placeholder="Ex: Lac Léman, Rivière Loire..." />
                </div>

                <div class="form-group">
                    <label for="latitude" class="form-label">Coordonnées GPS (optionnel)</label>
                    <div class="gps-fields">
                        <input type="text" id="latitude" class="form-control" @bind="newCatch.Latitude" 
                               placeholder="Latitude" inputmode="decimal" />
                        <input type="text" id="longitude" class="form-control" @bind="newCatch.Longitude" 
                               placeholder="Longitude" inputmode="decimal" />
                        <button type="button" class="btn btn-outline-primary" @onclick="GetCurrentLocation" disabled="@isGettingLocation">
                            @if (isGettingLocation)
                            {
                                <div class="spinner"></div>
                            }
                            else
                            {
                                <span>📍</span>
                            }
                        </button>
                    </div>
                    <small class="text-muted">Cliquez sur 📍 pour remplir automatiquement</small>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="catchDate" class="form-label">Date *</label>
                        <InputDate id="catchDate" class="form-control" @bind-Value="newCatch.CatchDate" required />
                    </div>
                    <div class="form-group">
                        <label for="catchTime" class="form-label">Heure</label>
                        <InputText id="catchTime" class="form-control" @bind-Value="newCatch.CatchTimeString" 
                                 placeholder="14:30" type="time" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">📸 Photo et détails</h3>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label class="form-label">Photo</label>
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-primary" @onclick="OpenGallery" disabled="@isUploadingPhoto">
                            🖼️ Galerie
                        </button>
                        <button type="button" class="btn btn-outline-primary" @onclick="OpenCamera" disabled="@isUploadingPhoto">
                            📷 Caméra
                        </button>
                    </div>

                    <InputFile id="photoFileGallery" style="display: none;" OnChange="HandlePhotoSelected" accept="image/*" />
                    <InputFile id="photoFileCamera" style="display: none;" OnChange="HandlePhotoSelected" accept="image/*" capture="environment" />

                    @if (isUploadingPhoto)
                    {
                        <div class="upload-status">
                            <div class="spinner"></div>
                            <span>Upload en cours...</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(newCatch.PhotoUrl))
                    {
                        <div class="photo-preview">
                            <img src="@newCatch.PhotoUrl" alt="Aperçu" class="preview-img" />
                            <button type="button" class="btn btn-sm btn-danger" @onclick="RemovePhoto">
                                ❌ Supprimer
                            </button>
                        </div>
                    }
                </div>

                <div class="form-group">
                    <label for="notes" class="form-label">Notes</label>
                    <InputTextArea id="notes" class="form-control" rows="4" @bind-Value="newCatch.Notes" 
                                 placeholder="Conditions météo, appât, technique..." />
                </div>

                <div class="form-group">
                    <label for="setupId" class="form-label">Montage utilisé</label>
                    <InputSelect id="setupId" class="form-control" @bind-Value="selectedSetupId">
                        <option value="">-- Aucun montage --</option>
                        @if (availableSetups != null)
                        {
                            @foreach (var setup in availableSetups)
                            {
                                <option value="@setup.Id">
                                    @(setup.IsCurrent ? "✅ " : "")@(setup.IsFavorite ? "⭐ " : "")@(string.IsNullOrEmpty(setup.Description) ? "Montage sans nom" : setup.Description)
                                </option>
                            }
                        }
                    </InputSelect>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">
                Annuler
            </button>
            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                @if (isSaving)
                {
                    <div class="spinner"></div>
                }
                ✅ Enregistrer
            </button>
        </div>
    </EditForm>
</div>

@code {
    private FishCatch newCatch = new FishCatch
    {
        CatchDate = DateTime.Today,
        CatchTimeString = DateTime.Now.ToString("HH:mm")
    };

    private List<FishingSetup>? availableSetups;
    private UserProfile? userProfile;
    private string selectedSetupId = "";
    private string? errorMessage;
    private string? successMessage;
    private bool isSaving;
    private bool isUploadingPhoto;
    private bool isGettingLocation;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        // Load available setups and user profile
        try
        {
            // Charger le profil et les setups en parallèle
            var profileTask = ProfileService.GetProfileAsync();
            var setupsTask = SupabaseService.GetAllSetupsAsync();

            await Task.WhenAll(profileTask, setupsTask);

            userProfile = await profileTask;
            availableSetups = await setupsTask;

            // Pré-sélectionner le montage actuel s'il existe
            var currentSetup = availableSetups?.FirstOrDefault(s => s.IsCurrent);
            if (currentSetup != null)
            {
                selectedSetupId = currentSetup.Id.ToString();
                newCatch.SetupId = currentSetup.Id;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading setups: {ex.Message}");
        }
    }

    private async Task HandlePhotoSelected(InputFileChangeEventArgs e)
    {
        isUploadingPhoto = true;
        errorMessage = null;
        string? tempPhotoUrl = null;

        try
        {
            var file = e.File;
            if (file != null)
            {
                // Vérifier la taille (max 5 MB)
                if (file.Size > 5 * 1024 * 1024)
                {
                    errorMessage = "La photo est trop volumineuse (max 5 MB).";
                    return;
                }

                // Vérifier le type
                if (!file.ContentType.StartsWith("image/"))
                {
                    errorMessage = "Seules les images sont acceptées.";
                    return;
                }

                // Créer un aperçu local IMMÉDIATEMENT avec data URL
                var buffer = new byte[file.Size];
                await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
                var base64 = Convert.ToBase64String(buffer);
                tempPhotoUrl = $"data:{file.ContentType};base64,{base64}";
                newCatch.PhotoUrl = tempPhotoUrl; // Afficher l'aperçu immédiatement
                StateHasChanged();

                // Upload vers Supabase Storage en arrière-plan
                var stream = new MemoryStream(buffer);
                var photoUrl = await SupabaseService.UploadPhotoAsync(stream, file.Name);

                if (!string.IsNullOrEmpty(photoUrl))
                {
                    newCatch.PhotoUrl = photoUrl; // Remplacer par l'URL Supabase
                    successMessage = "✅ Photo uploadée avec succès !";
                    await Task.Delay(2000);
                    successMessage = null;
                }
                else
                {
                    errorMessage = "Erreur lors de l'upload de la photo. Vérifiez que le bucket 'fishing-photos' existe dans Supabase Storage.";
                    newCatch.PhotoUrl = tempPhotoUrl; // Garder l'aperçu local
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error uploading photo: {ex.Message}");
            errorMessage = $"Erreur lors de l'upload: {ex.Message}";
            if (!string.IsNullOrEmpty(tempPhotoUrl))
            {
                newCatch.PhotoUrl = tempPhotoUrl; // Garder l'aperçu local en cas d'erreur
            }
        }
        finally
        {
            isUploadingPhoto = false;
        }
    }

    private async Task OpenGallery()
    {
        // Déclencher le click sur l'input file pour la galerie
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('photoFileGallery').click()");
    }

    private async Task OpenCamera()
    {
        // Utiliser simplement l'input file avec l'attribut capture pour mobile
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('photoFileCamera').click()");
    }

    private void RemovePhoto()
    {
        newCatch.PhotoUrl = null;
    }

    private async Task GetCurrentLocation()
    {
        isGettingLocation = true;
        errorMessage = null;

        try
        {
            // Appeler l'API Geolocation via JavaScript
            var position = await JSRuntime.InvokeAsync<GeolocationPosition>("getCurrentPosition");

            if (position != null)
            {
                newCatch.Latitude = position.Latitude;
                newCatch.Longitude = position.Longitude;

                // Reverse geocoding pour obtenir le nom du lieu
                try
                {
                    var locationName = await JSRuntime.InvokeAsync<string>("reverseGeocode", position.Latitude, position.Longitude);
                    if (!string.IsNullOrEmpty(locationName))
                    {
                        newCatch.LocationName = locationName;
                    }
                    successMessage = "📍 Position et lieu récupérés avec succès !";
                }
                catch
                {
                    successMessage = "📍 Position récupérée (lieu non trouvé)";
                }

                await Task.Delay(2000);
                successMessage = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error getting location: {ex.Message}");
            errorMessage = "Impossible de récupérer votre position. Vérifiez que vous avez autorisé l'accès à la localisation.";
        }
        finally
        {
            isGettingLocation = false;
        }
    }

    private async Task HandleAddCatch()
    {
        errorMessage = null;
        successMessage = null;

        // Vérifier l'authentification
        if (!AuthService.IsAuthenticated || AuthService.CurrentUser == null)
        {
            errorMessage = "❌ Vous devez être connecté pour enregistrer une prise. Veuillez vous reconnecter.";
            Console.WriteLine("User not authenticated - redirecting to login");
            await Task.Delay(2000);
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        // Validation basique
        if (string.IsNullOrWhiteSpace(newCatch.FishName))
        {
            errorMessage = "Le nom de l'espèce est requis.";
            return;
        }

        // Convertir le SetupId sélectionné
        if (!string.IsNullOrEmpty(selectedSetupId) && int.TryParse(selectedSetupId, out int setupId))
        {
            newCatch.SetupId = setupId;
        }
        else
        {
            newCatch.SetupId = null;
        }

        isSaving = true;
        StateHasChanged();

        try
        {
            Console.WriteLine($"User authenticated: {AuthService.CurrentUser.Email}");
            Console.WriteLine($"Access token present: {!string.IsNullOrEmpty(AuthService.AccessToken)}");
            Console.WriteLine($"Saving catch: {newCatch.FishName}, Lat: {newCatch.Latitude}, Lon: {newCatch.Longitude}");

            var catchId = await SupabaseService.AddCatchAsync(newCatch);
            Console.WriteLine($"Catch saved with ID: {catchId}");

            if (catchId > 0)
            {
                // Redirection immédiate vers la liste sans attendre
                Navigation.NavigateTo("/FishingSpot_App/catches", forceLoad: true);
            }
            else
            {
                errorMessage = "❌ Erreur lors de la sauvegarde. Le serveur n'a pas retourné d'ID. Vérifiez votre connexion et que vous êtes connecté.";
                isSaving = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error adding catch: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");

            if (ex.Message.Contains("401") || ex.Message.Contains("Unauthorized"))
            {
                errorMessage = "❌ Session expirée. Veuillez vous reconnecter.";
                await Task.Delay(2000);
                Navigation.NavigateTo("/FishingSpot_App/login");
            }
            else
            {
                errorMessage = $"❌ Erreur: {ex.Message}";
            }

            isSaving = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/FishingSpot_App/catches");
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/FishingSpot_App/");
    }
}
