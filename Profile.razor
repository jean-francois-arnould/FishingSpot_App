@page "/profile"
@page "/FishingSpot_App/profile"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject NavigationManager Navigation

<PageTitle>Mon Profil</PageTitle>

<AuthorizeView>
    <div class="page-content">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">
                @errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">
                @successMessage
            </div>
        }

        @if (isLoading)
        {
            <div class="empty-state">
                <div class="spinner"></div>
                <p class="mt-3">Chargement du profil...</p>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-header">
                    <h3 class="mb-0">👤 Mon profil</h3>
                    <p class="text-muted mb-0">@AuthService.CurrentUser?.Email</p>
                </div>
                <div class="card-body">
                    <EditForm Model="@profile" OnValidSubmit="HandleSaveProfile">
                        <div class="form-group">
                            <label for="displayName" class="form-label">👤 Nom d'affichage</label>
                            <InputText id="displayName" class="form-control" @bind-Value="profile.DisplayName" placeholder="Jean Dupont" />
                            <small class="text-muted">Ce nom sera visible par les autres utilisateurs</small>
                        </div>

                        <div class="form-group">
                            <label for="avatarUrl" class="form-label">🖼️ URL de l'avatar</label>
                            <InputText id="avatarUrl" class="form-control" @bind-Value="profile.AvatarUrl" placeholder="https://..." />
                            <small class="text-muted">URL de votre photo de profil</small>
                        </div>

                        @if (!string.IsNullOrEmpty(profile.AvatarUrl))
                        {
                            <div class="mb-3">
                                <img src="@profile.AvatarUrl" alt="Avatar" style="max-width: 150px; border-radius: 50%;" />
                            </div>
                        }

                        <button type="submit" class="btn btn-primary btn-block" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <div class="spinner"></div>
                            }
                            💾 Enregistrer
                        </button>
                    </EditForm>
                </div>
            </div>

            <div class="card card-danger">
                <div class="card-header">
                    <h3 class="mb-0">⚠️ Zone dangereuse</h3>
                </div>
                <div class="card-body">
                    <div class="list-item" @onclick="HandleLogout">
                        <div class="list-item-icon">🚪</div>
                        <div class="list-item-content">
                            <div class="list-item-title">Se déconnecter</div>
                            <div class="list-item-subtitle">Déconnexion de votre compte</div>
                        </div>
                        <div class="list-item-action">›</div>
                    </div>

                    <hr class="my-3" />

                    <h4 class="text-danger">Supprimer mon compte</h4>
                    <p class="text-muted">Cette action est irréversible. Toutes vos données seront définitivement supprimées.</p>

                    @if (showDeleteConfirmation)
                    {
                        <div class="alert alert-danger">
                            <p class="mb-2"><strong>Êtes-vous vraiment sûr(e)?</strong></p>
                            <p class="mb-3">Cette action supprimera:</p>
                            <ul>
                                <li>Votre profil utilisateur</li>
                                <li>Toutes vos prises de pêche</li>
                                <li>Toutes vos données associées</li>
                            </ul>
                            <p class="text-danger"><strong>Cette action est définitive et ne peut pas être annulée!</strong></p>
                            <div class="btn-group">
                                <button class="btn btn-danger" @onclick="ConfirmDeleteAccount" disabled="@isDeleting">
                                    @if (isDeleting)
                                    {
                                        <div class="spinner"></div>
                                    }
                                    Oui, supprimer définitivement
                                </button>
                                <button class="btn btn-outline-secondary" @onclick="CancelDelete">Annuler</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-danger btn-block" @onclick="ShowDeleteConfirmation">
                            🗑️ Supprimer mon compte
                        </button>
                    }
                </div>
            </div>
        }
    </div>
</AuthorizeView>

@code {
    private UserProfile profile = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading = true;
    private bool isSaving = false;
    private bool showDeleteConfirmation = false;
    private bool isDeleting = false;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        try
        {
            var existingProfile = await ProfileService.GetProfileAsync();
            if (existingProfile != null)
            {
                profile = existingProfile;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement du profil: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSaveProfile()
    {
        errorMessage = null;
        successMessage = null;
        isSaving = true;

        try
        {
            Console.WriteLine($"💾 Saving profile: DisplayName='{profile.DisplayName}', AvatarUrl='{profile.AvatarUrl}'");

            var success = await ProfileService.CreateOrUpdateProfileAsync(profile);

            if (success)
            {
                successMessage = "Profil enregistré avec succès!";

                // Recharger le profil pour confirmer la sauvegarde
                await Task.Delay(500);
                var updatedProfile = await ProfileService.GetProfileAsync();
                if (updatedProfile != null)
                {
                    profile = updatedProfile;
                    Console.WriteLine($"✅ Profile reloaded: DisplayName='{profile.DisplayName}'");
                }
            }
            else
            {
                errorMessage = "Erreur lors de l'enregistrement du profil.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
            Console.WriteLine($"❌ Error saving profile: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/FishingSpot_App/");
    }

    private void ShowDeleteConfirmation()
    {
        showDeleteConfirmation = true;
        errorMessage = null;
        successMessage = null;
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
    }

    private async Task ConfirmDeleteAccount()
    {
        errorMessage = null;
        successMessage = null;
        isDeleting = true;

        try
        {
            var success = await ProfileService.DeleteAccountAsync();

            if (success)
            {
                Navigation.NavigateTo("/FishingSpot_App/");
            }
            else
            {
                errorMessage = "Erreur lors de la suppression du compte.";
                showDeleteConfirmation = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
            showDeleteConfirmation = false;
        }
        finally
        {
            isDeleting = false;
        }
    }
}
