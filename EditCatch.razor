@page "/catches/edit/{CatchId:int}"
@page "/FishingSpot_App/catches/edit/{CatchId:int}"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@using Microsoft.JSInterop
@inject ISupabaseService SupabaseService
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Modifier la prise</PageTitle>

<div class="page-content">
    @if (isLoading)
    {
        <div class="empty-state">
            <div class="spinner"></div>
            <p class="mt-3">Chargement...</p>
        </div>
    }
    else if (catchToEdit == null)
    {
        <div class="empty-state">
            <div class="empty-state-icon">❌</div>
            <h3>Prise introuvable</h3>
            <p class="text-muted">Cette prise n'existe pas ou vous n'avez pas l'autorisation de la modifier.</p>
            <button class="btn btn-primary" @onclick="Cancel">
                Retour aux prises
            </button>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">
                @errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">
                @successMessage
            </div>
        }

        <EditForm Model="@catchToEdit" OnValidSubmit="HandleUpdateCatch">
            <DataAnnotationsValidator />

            <div class="card">
                <div class="card-header">
                    <h3 class="mb-0">🐟 Information du poisson</h3>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label for="fishName" class="form-label">Espèce *</label>
                        <InputText id="fishName" class="form-control" @bind-Value="catchToEdit.FishName" 
                                   placeholder="Ex: Brochet, Truite, Carpe..." required />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="length" class="form-label">📏 Longueur (cm)</label>
                            <InputNumber id="length" class="form-control" @bind-Value="catchToEdit.Length" 
                                       placeholder="30" step="0.1" />
                        </div>
                        <div class="form-group">
                            <label for="weight" class="form-label">⚖️ Poids (kg)</label>
                            <InputNumber id="weight" class="form-control" @bind-Value="catchToEdit.Weight" 
                                       placeholder="2.5" step="0.1" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="mb-0">📍 Lieu et date</h3>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label for="locationName" class="form-label">Lieu</label>
                        <InputText id="locationName" class="form-control" @bind-Value="catchToEdit.LocationName" 
                                   placeholder="Ex: Lac Léman, Rivière Loire..." />
                    </div>

                    <div class="form-group">
                        <label for="latitude" class="form-label">Coordonnées GPS</label>
                        <div class="gps-fields">
                            <input type="number" id="latitude" class="form-control" @bind="catchToEdit.Latitude" 
                                   placeholder="Latitude" step="0.000001" inputmode="decimal" />
                            <input type="number" id="longitude" class="form-control" @bind="catchToEdit.Longitude" 
                                   placeholder="Longitude" step="0.000001" inputmode="decimal" />
                            <button type="button" class="btn btn-outline-primary" @onclick="GetCurrentLocation" disabled="@isGettingLocation">
                                @if (isGettingLocation)
                                {
                                    <div class="spinner"></div>
                                }
                                else
                                {
                                    <span>📍</span>
                                }
                            </button>
                        </div>
                        <small class="text-muted">Les coordonnées GPS sont optionnelles</small>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="catchDate" class="form-label">Date *</label>
                            <InputDate id="catchDate" class="form-control" @bind-Value="catchToEdit.CatchDate" required />
                        </div>
                        <div class="form-group">
                            <label for="catchTime" class="form-label">Heure</label>
                            <InputText id="catchTime" class="form-control" @bind-Value="catchToEdit.CatchTimeString"
                                     placeholder="14:30" type="time" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3 class="mb-0">📸 Photo et détails</h3>
                </div>
                <div class="card-body">
                    <div class="form-group">
                        <label class="form-label">Photo</label>
                        <div class="btn-group">
                            <button type="button" class="btn btn-outline-primary" @onclick="OpenGallery" disabled="@isUploadingPhoto">
                                🖼️ Galerie
                            </button>
                            <button type="button" class="btn btn-outline-primary" @onclick="OpenCamera" disabled="@isUploadingPhoto">
                                📷 Caméra
                            </button>
                        </div>

                        <InputFile id="photoFileGallery" style="display: none;" OnChange="HandlePhotoSelected" accept="image/*" />
                        <InputFile id="photoFileCamera" style="display: none;" OnChange="HandlePhotoSelected" accept="image/*" capture="environment" />

                        @if (isUploadingPhoto)
                        {
                            <div class="upload-status">
                                <div class="spinner"></div>
                                <span>Upload en cours...</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(catchToEdit.PhotoUrl))
                        {
                            <div class="photo-preview">
                                <img src="@catchToEdit.PhotoUrl" alt="Aperçu" class="preview-img" />
                                <button type="button" class="btn btn-sm btn-danger" @onclick="RemovePhoto">
                                    ❌ Supprimer
                                </button>
                            </div>
                        }
                    </div>

                    <div class="form-group">
                        <label for="notes" class="form-label">Notes</label>
                        <InputTextArea id="notes" class="form-control" rows="4" @bind-Value="catchToEdit.Notes" 
                                     placeholder="Conditions météo, appât, technique..." />
                    </div>

                    <div class="form-group">
                        <label for="setupId" class="form-label">Montage utilisé</label>
                        <InputSelect id="setupId" class="form-control" @bind-Value="selectedSetupId">
                            <option value="">-- Aucun montage --</option>
                            @if (availableSetups != null)
                            {
                                @foreach (var setup in availableSetups)
                                {
                                    <option value="@setup.Id">
                                        @(setup.IsCurrent ? "✅ " : "")@(setup.IsFavorite ? "⭐ " : "")@(string.IsNullOrEmpty(setup.Description) ? "Montage sans nom" : setup.Description)
                                    </option>
                                }
                            }
                        </InputSelect>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">
                    Annuler
                </button>
                <div>
                    <button type="button" class="btn btn-danger" @onclick="ShowDeleteConfirmation">
                        🗑️ Supprimer
                    </button>
                    <button type="submit" class="btn btn-primary" disabled="@isSaving" style="margin-left: 8px;">
                        @if (isSaving)
                        {
                            <div class="spinner"></div>
                        }
                        ✅ Enregistrer
                    </button>
                </div>
            </div>
        </EditForm>

        @if (showDeleteConfirm)
        {
            <div class="modal-overlay" @onclick="CancelDelete">
                <div class="modal" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h3>⚠️ Confirmer la suppression</h3>
                        <button type="button" class="modal-close" @onclick="CancelDelete">&times;</button>
                    </div>
                    <div class="modal-body">
                        <p>Êtes-vous sûr de vouloir supprimer cette prise?</p>
                        <p><strong>@catchToEdit.FishName</strong> pêché à <strong>@catchToEdit.LocationName</strong></p>
                        <p class="text-danger">Cette action est irréversible.</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">Annuler</button>
                        <button type="button" class="btn btn-danger" @onclick="HandleDeleteCatch" disabled="@isDeleting">
                            @if (isDeleting)
                            {
                                <div class="spinner"></div>
                            }
                            Supprimer
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public int CatchId { get; set; }

    private FishCatch? catchToEdit;
    private List<FishingSetup>? availableSetups;
    private UserProfile? userProfile;
    private string selectedSetupId = "";
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading = true;
    private bool isSaving;
    private bool isDeleting;
    private bool showDeleteConfirm;
    private bool isUploadingPhoto;
    private bool isGettingLocation;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/login");
            return;
        }

        try
        {
            // Charger le profil, la prise et les setups en parallèle
            var profileTask = ProfileService.GetProfileAsync();
            var catchTask = SupabaseService.GetCatchByIdAsync(CatchId);
            var setupsTask = SupabaseService.GetAllSetupsAsync();

            await Task.WhenAll(profileTask, catchTask, setupsTask);

            userProfile = await profileTask;
            catchToEdit = await catchTask;
            availableSetups = await setupsTask;

            // Pré-remplir le montage sélectionné
            if (catchToEdit?.SetupId.HasValue ?? false)
            {
                selectedSetupId = catchToEdit.SetupId.Value.ToString();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading catch: {ex.Message}");
            errorMessage = $"Error loading catch: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandlePhotoSelected(InputFileChangeEventArgs e)
    {
        if (catchToEdit == null) return;

        isUploadingPhoto = true;
        errorMessage = null;
        string? tempPhotoUrl = null;

        try
        {
            var file = e.File;
            if (file != null)
            {
                if (file.Size > 5 * 1024 * 1024)
                {
                    errorMessage = "La photo est trop volumineuse (max 5 MB).";
                    return;
                }

                if (!file.ContentType.StartsWith("image/"))
                {
                    errorMessage = "Seules les images sont acceptées.";
                    return;
                }

                // Créer un aperçu local IMMÉDIATEMENT avec data URL
                var buffer = new byte[file.Size];
                await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
                var base64 = Convert.ToBase64String(buffer);
                tempPhotoUrl = $"data:{file.ContentType};base64,{base64}";
                catchToEdit.PhotoUrl = tempPhotoUrl; // Afficher l'aperçu immédiatement
                StateHasChanged();

                // Upload vers Supabase Storage en arrière-plan
                var stream = new MemoryStream(buffer);
                var photoUrl = await SupabaseService.UploadPhotoAsync(stream, file.Name);

                if (!string.IsNullOrEmpty(photoUrl))
                {
                    catchToEdit.PhotoUrl = photoUrl; // Remplacer par l'URL Supabase
                    successMessage = "✅ Photo uploadée avec succès !";
                    await Task.Delay(2000);
                    successMessage = null;
                }
                else
                {
                    errorMessage = "Erreur lors de l'upload de la photo.";
                    catchToEdit.PhotoUrl = tempPhotoUrl; // Garder l'aperçu local
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error uploading photo: {ex.Message}");
            errorMessage = $"Erreur lors de l'upload: {ex.Message}";
            if (!string.IsNullOrEmpty(tempPhotoUrl))
            {
                catchToEdit.PhotoUrl = tempPhotoUrl; // Garder l'aperçu local en cas d'erreur
            }
        }
        finally
        {
            isUploadingPhoto = false;
        }
    }

    private async Task OpenGallery()
    {
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('photoFileGallery').click()");
    }

    private async Task OpenCamera()
    {
        // Utiliser simplement l'input file avec l'attribut capture pour mobile
        await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('photoFileCamera').click()");
    }

    private void RemovePhoto()
    {
        if (catchToEdit != null)
        {
            catchToEdit.PhotoUrl = null;
        }
    }

    private async Task GetCurrentLocation()
    {
        if (catchToEdit == null) return;

        isGettingLocation = true;
        errorMessage = null;

        try
        {
            // Appeler l'API Geolocation via JavaScript
            var position = await JSRuntime.InvokeAsync<GeolocationPosition>("getCurrentPosition");

            if (position != null)
            {
                catchToEdit.Latitude = position.Latitude;
                catchToEdit.Longitude = position.Longitude;

                // Reverse geocoding pour obtenir le nom du lieu
                try
                {
                    var locationName = await JSRuntime.InvokeAsync<string>("reverseGeocode", position.Latitude, position.Longitude);
                    if (!string.IsNullOrEmpty(locationName))
                    {
                        catchToEdit.LocationName = locationName;
                    }
                    successMessage = "📍 Position et lieu récupérés avec succès !";
                }
                catch
                {
                    successMessage = "📍 Position récupérée (lieu non trouvé)";
                }

                await Task.Delay(2000);
                successMessage = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error getting location: {ex.Message}");
            errorMessage = "Impossible de récupérer votre position. Vérifiez que vous avez autorisé l'accès à la localisation.";
        }
        finally
        {
            isGettingLocation = false;
        }
    }

    private async Task HandleUpdateCatch()
    {
        if (catchToEdit == null) return;

        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(catchToEdit.FishName))
        {
            errorMessage = "Le nom de l'espèce est requis.";
            return;
        }

        // Le lieu n'est plus obligatoire

        // Convertir le SetupId sélectionné
        if (!string.IsNullOrEmpty(selectedSetupId) && int.TryParse(selectedSetupId, out int setupId))
        {
            catchToEdit.SetupId = setupId;
        }
        else
        {
            catchToEdit.SetupId = null;
        }

        isSaving = true;

        try
        {
            var success = await SupabaseService.UpdateCatchAsync(catchToEdit);

            if (success)
            {
                successMessage = "✅ Catch updated successfully!";
                await Task.Delay(1500);
                Navigation.NavigateTo("/FishingSpot_App/catches");
            }
            else
            {
                errorMessage = "Failed to update catch. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating catch: {ex.Message}");
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ShowDeleteConfirmation()
    {
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
    }

    private async Task HandleDeleteCatch()
    {
        if (catchToEdit == null) return;

        isDeleting = true;

        try
        {
            var success = await SupabaseService.DeleteCatchAsync(catchToEdit.Id);

            if (success)
            {
                Navigation.NavigateTo("/FishingSpot_App/catches");
            }
            else
            {
                errorMessage = "Failed to delete catch. Please try again.";
                showDeleteConfirm = false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting catch: {ex.Message}");
            errorMessage = $"Error: {ex.Message}";
            showDeleteConfirm = false;
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/FishingSpot_App/catches");
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/FishingSpot_App/");
    }
}
