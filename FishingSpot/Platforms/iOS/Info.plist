<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<integer>2</integer>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>XSAppIconAssets</key>
	<string>Assets.xcassets/appicon.appiconset</string>

	<!-- Permissions pour la caméra -->
	<key>NSCameraUsageDescription</key>
	<string>L'application a besoin d'accéder à votre appareil photo pour prendre des photos de vos prises de pêche.</string>

	<!-- Permissions pour la localisation -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>L'application a besoin d'accéder à votre localisation pour enregistrer le lieu de vos prises de pêche.</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>L'application a besoin d'accéder à votre localisation pour enregistrer le lieu de vos prises de pêche.</string>

	<!-- Permissions pour les photos -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>L'application a besoin d'accéder à vos photos pour enregistrer les images de vos prises de pêche.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>L'application a besoin d'ajouter des photos à votre bibliothèque.</string>
</dict>
</plist>
