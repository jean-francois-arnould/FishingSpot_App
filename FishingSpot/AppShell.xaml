<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FishingSpot.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FishingSpot"
    xmlns:views="clr-namespace:FishingSpot.Views"
    Title="FishingSpot">

    <TabBar>
        <ShellContent
            Title="Mon Materiel"
            Icon="toolbox.png"
            ContentTemplate="{DataTemplate views:MaterialManagementPage}"
            Route="MaterialManagementPage" />

        <ShellContent
            Title="Mes Poissons"
            Icon="fish.png"
            ContentTemplate="{DataTemplate views:MyCatchesPage}"
            Route="MyCatchesPage" />

        <ShellContent
            Title="Calendrier"
            Icon="calendar.png"
            ContentTemplate="{DataTemplate views:CalendarPage}"
            Route="CalendarPage" />

        <ShellContent
            Title="Statistiques"
            Icon="chart.png"
            ContentTemplate="{DataTemplate views:StatisticsPage}"
            Route="StatisticsPage" />
    </TabBar>

</Shell>
