<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Thème Aquatique Moderne pour FishingSpot -->

    <!-- Couleurs principales (Bleu océan) -->
    <Color x:Key="Primary">#0891B2</Color>
    <Color x:Key="PrimaryDark">#0E7490</Color>
    <Color x:Key="PrimaryLight">#06B6D4</Color>
    <Color x:Key="PrimaryLighter">#22D3EE</Color>
    <Color x:Key="PrimaryDarkText">#1F1F1F</Color>
    <!-- Couleurs secondaires (Vert nature) -->
    <Color x:Key="Secondary">#10B981</Color>
    <Color x:Key="SecondaryDark">#059669</Color>
    <Color x:Key="SecondaryLight">#34D399</Color>
    <Color x:Key="SecondaryDarkText">#E5E7EB</Color>

    <!-- Couleurs tertiaires (Orange/Corail) -->
    <Color x:Key="Tertiary">#F59E0B</Color>
    <Color x:Key="TertiaryDark">#D97706</Color>
    <Color x:Key="TertiaryLight">#FBBF24</Color>

    <!-- Couleurs d'accent -->
    <Color x:Key="Accent">#8B5CF6</Color>
    <Color x:Key="AccentLight">#A78BFA</Color>
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Info">#3B82F6</Color>
    <Color x:Key="MidnightBlue">#191970</Color>

    <!-- Couleurs de fond -->
    <Color x:Key="Background">#F8FAFC</Color>
    <Color x:Key="BackgroundDark">#F1F5F9</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceDark">#F8FAFC</Color>

    <!-- Couleurs de texte -->
    <Color x:Key="TextPrimary">#0F172A</Color>
    <Color x:Key="TextSecondary">#475569</Color>
    <Color x:Key="TextTertiary">#94A3B8</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>

    <!-- Couleurs de bordure/ombre -->
    <Color x:Key="Border">#E2E8F0</Color>
    <Color x:Key="BorderDark">#CBD5E1</Color>
    <Color x:Key="Shadow">#1E293B</Color>

    <!-- Couleurs spécifiques pour les cartes -->
    <Color x:Key="CardCanne">#FFF7ED</Color>
    <Color x:Key="CardFil">#F0FDF4</Color>
    <Color x:Key="CardBasLigne">#EFF6FF</Color>
    <Color x:Key="CardAppat">#FAF5FF</Color>
    <Color x:Key="CardSetup">#FEF3C7</Color>
    <Color x:Key="CardFish">#DBEAFE</Color>

    <!-- Anciennes couleurs pour compatibilité -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="OffBlack">#1F1F1F</Color>
    <Color x:Key="Magenta">#D946EF</Color>
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray900">#111827</Color>
    <Color x:Key="Gray950">#030712</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <!-- Gradients -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
        <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SecondaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Secondary}" Offset="0.0" />
        <GradientStop Color="{StaticResource SecondaryDark}" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SunsetGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F59E0B" Offset="0.0" />
        <GradientStop Color="#EF4444" Offset="0.5" />
        <GradientStop Color="#EC4899" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OceanGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#06B6D4" Offset="0.0" />
        <GradientStop Color="#0891B2" Offset="0.5" />
        <GradientStop Color="#0E7490" Offset="1.0" />
    </LinearGradientBrush>
</ResourceDictionary>