<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FishingSpot.Views.CalendarPage"
             Title="Calendrier de Pêche">

    <Grid RowDefinitions="Auto,*">

        <!-- En-tête avec navigation mois -->
        <Grid Grid.Row="0" 
              Padding="20,10" 
              ColumnDefinitions="Auto,*,Auto" 
              BackgroundColor="{StaticResource Primary}">
            <Button Grid.Column="0" 
                    Text="◀" 
                    Clicked="OnPreviousMonthClicked"
                    BackgroundColor="Transparent"
                    TextColor="White"/>
            <Label Grid.Column="1" 
                   x:Name="MonthYearLabel"
                   Text="Janvier 2024"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   TextColor="White"/>
            <Button Grid.Column="2" 
                    Text="▶" 
                    Clicked="OnNextMonthClicked"
                    BackgroundColor="Transparent"
                    TextColor="White"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="10" Spacing="10">

                <!-- Jours de la semaine -->
                <Grid ColumnDefinitions="*,*,*,*,*,*,*" Padding="5">
                    <Label Grid.Column="0" Text="Lun" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                    <Label Grid.Column="1" Text="Mar" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                    <Label Grid.Column="2" Text="Mer" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                    <Label Grid.Column="3" Text="Jeu" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                    <Label Grid.Column="4" Text="Ven" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                    <Label Grid.Column="5" Text="Sam" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                    <Label Grid.Column="6" Text="Dim" HorizontalTextAlignment="Center" FontAttributes="Bold"/>
                </Grid>

                <!-- Grille calendrier -->
                <Grid x:Name="CalendarGrid" 
                      RowDefinitions="*,*,*,*,*,*" 
                      ColumnDefinitions="*,*,*,*,*,*,*"
                      RowSpacing="5"
                      ColumnSpacing="5"/>

                <!-- Liste des captures du jour sélectionné -->
                <Frame BorderColor="{StaticResource Primary}" 
                       CornerRadius="10" 
                       Padding="15"
                       IsVisible="False"
                       x:Name="CatchesFrame">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="SelectedDateLabel" 
                               Text="Captures du jour" 
                               FontSize="18" 
                               FontAttributes="Bold"/>
                        <CollectionView x:Name="DailyCatchesCollectionView">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame Padding="10" 
                                           Margin="0,5" 
                                           BorderColor="{StaticResource Primary}"
                                           CornerRadius="5">
                                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                            <Label Grid.Row="0" Grid.Column="0" 
                                                   Text="{Binding FishName}" 
                                                   FontAttributes="Bold" 
                                                   FontSize="16"/>
                                            <Label Grid.Row="0" Grid.Column="1" 
                                                   Text="{Binding CatchTime}" 
                                                   FontSize="14"/>
                                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                   Text="{Binding LocationName}"/>
                                            <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="Taille: "/>
                                                        <Span Text="{Binding Length}" FontAttributes="Bold"/>
                                                        <Span Text=" cm - Poids: "/>
                                                        <Span Text="{Binding Weight}" FontAttributes="Bold"/>
                                                        <Span Text=" kg"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- Statistiques du mois -->
                <Frame BorderColor="{StaticResource Primary}" CornerRadius="10" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Statistiques du Mois" 
                               FontSize="18" 
                               FontAttributes="Bold"/>
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                            <Label Grid.Row="0" Grid.Column="0" Text="Total captures:"/>
                            <Label Grid.Row="0" Grid.Column="1" x:Name="MonthTotalLabel" 
                                   Text="0" FontAttributes="Bold"/>
                            <Label Grid.Row="1" Grid.Column="0" Text="Jours de pêche:"/>
                            <Label Grid.Row="1" Grid.Column="1" x:Name="FishingDaysLabel" 
                                   Text="0" FontAttributes="Bold"/>
                            <Label Grid.Row="2" Grid.Column="0" Text="Moyenne par jour:"/>
                            <Label Grid.Row="2" Grid.Column="1" x:Name="AveragePerDayLabel" 
                                   Text="0" FontAttributes="Bold"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
