<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FishingSpot.Views.AddSetupPage"
             Title="Nouveau Setup">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="✕"
                     Order="Primary"
                     Priority="0"
                     Clicked="OnCancelClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- Section : Informations générales -->
                <Frame BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2C2C2E}"
                       BorderColor="Transparent"
                       Padding="15"
                       CornerRadius="10">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="📋 Informations générales"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1976D2, Dark=#64B5F6}"/>

                        <BoxView HeightRequest="1" 
                                 Color="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                                 Margin="0,0,0,8"/>

                        <Label Text="Nom du setup *"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}"/>
                        <Entry x:Name="NameEntry"
                               Placeholder="ex: Setup Carnassiers"
                               PlaceholderColor="Gray"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#3C3C3E}"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

                        <Label Text="Description"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}"
                               Margin="0,8,0,0"/>
                        <Editor x:Name="DescriptionEditor"
                                Placeholder="Décrivez votre setup (optionnel)"
                                HeightRequest="80"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#3C3C3E}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                AutoSize="TextChanges"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Section : Composition du Setup -->
                <Frame BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2C2C2E}"
                       BorderColor="Transparent"
                       Padding="15"
                       CornerRadius="10">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="🎣 Composition du setup"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1976D2, Dark=#64B5F6}"/>

                        <BoxView HeightRequest="1" 
                                 Color="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                                 Margin="0,0,0,8"/>

                        <Label Text="Canne à pêche"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}"/>
                        <Picker x:Name="CannePicker"
                                Title="Sélectionnez une canne"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#3C3C3E}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

                        <Label Text="Fil de pêche"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}"
                               Margin="0,8,0,0"/>
                        <Picker x:Name="FilPicker"
                                Title="Sélectionnez un fil"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#3C3C3E}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

                        <Label Text="Bas de ligne"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}"
                               Margin="0,8,0,0"/>
                        <Picker x:Name="BasDeLignePicker"
                                Title="Sélectionnez un bas de ligne"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#3C3C3E}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

                        <Label Text="Appât ou Leurre"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}"
                               Margin="0,8,0,0"/>
                        <Picker x:Name="AppAtPicker"
                                Title="Sélectionnez un appât/leurre"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#3C3C3E}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Section : Notes et Options -->
                <Frame BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2C2C2E}"
                       BorderColor="Transparent"
                       Padding="15"
                       CornerRadius="10">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="📝 Notes et options"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1976D2, Dark=#64B5F6}"/>

                        <BoxView HeightRequest="1" 
                                 Color="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                                 Margin="0,0,0,8"/>

                        <Label Text="Notes personnelles"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}"/>
                        <Editor x:Name="NotesEditor"
                                Placeholder="Ajoutez vos observations, conditions d'utilisation, résultats..."
                                HeightRequest="100"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#3C3C3E}"
                                TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                AutoSize="TextChanges"/>

                        <!-- Setup actif -->
                        <Frame BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1565C0}"
                               BorderColor="{AppThemeBinding Light=#2196F3, Dark=#64B5F6}"
                               Padding="12"
                               CornerRadius="8"
                               Margin="0,8,0,0">
                            <HorizontalStackLayout Spacing="12">
                                <CheckBox x:Name="IsActiveCheckBox"
                                          IsChecked="False"
                                          Color="{AppThemeBinding Light=#1976D2, Dark=#64B5F6}"/>
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="✅ Définir comme setup actif"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#1565C0, Dark=White}"/>
                                    <Label Text="Ce setup sera utilisé par défaut lors de vos sorties"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light=#1976D2, Dark=#B3E5FC}"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Boutons d'action en bas -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="10"
              Padding="20,10"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">

            <Button Grid.Column="0"
                    Text="❌ Annuler"
                    Clicked="OnCancelClicked"
                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                    TextColor="{AppThemeBinding Light=#424242, Dark=White}"
                    CornerRadius="10"
                    HeightRequest="50"
                    FontSize="16"
                    FontAttributes="Bold"/>

            <Button Grid.Column="1"
                    Text="💾 Enregistrer"
                    Clicked="OnSaveClicked"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"
                    FontSize="16"
                    FontAttributes="Bold"/>
        </Grid>
    </Grid>

</ContentPage>
