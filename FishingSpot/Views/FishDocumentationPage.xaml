<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FishingSpot.Views.FishDocumentationPage"
             Title="Documentation">

    <Grid>
        <CollectionView x:Name="FishCollectionView"
                        Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5"
                           Padding="10"
                           CornerRadius="10"
                           HasShadow="True"
                           BackgroundColor="{AppThemeBinding Light=White, Dark=#2B2B2B}">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="5">

                            <Label Grid.Row="0"
                                   Text="{Binding Name}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#2196F3"/>

                            <Label Grid.Row="1"
                                   Text="{Binding ScientificName}"
                                   FontSize="14"
                                   FontAttributes="Italic"
                                   TextColor="Gray"/>

                            <Label Grid.Row="2"
                                   Text="{Binding Description}"
                                   FontSize="14"
                                   Margin="0,5,0,0"/>

                            <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       Text="Habitat:"
                                       FontSize="12"
                                       FontAttributes="Bold"/>
                                <Label Grid.Column="1"
                                       Text="{Binding Habitat}"
                                       FontSize="12"/>
                            </Grid>

                            <Grid Grid.Row="4" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       Text="Appats:"
                                       FontSize="12"
                                       FontAttributes="Bold"/>
                                <Label Grid.Column="1"
                                       Text="{Binding BestBait}"
                                       FontSize="12"/>
                            </Grid>

                            <HorizontalStackLayout Grid.Row="5" Spacing="10" Margin="0,5,0,0">
                                <Label Text="Taille moyenne:"
                                       FontSize="12"
                                       FontAttributes="Bold"/>
                                <Label FontSize="12">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0:F0} cm (max {1:F0} cm)">
                                            <Binding Path="AverageSize" />
                                            <Binding Path="MaxSize" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
