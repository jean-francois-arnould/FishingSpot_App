<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FishingSpot.Views.AddMaterialPage"
             Title="Nouveau Materiel">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="✕"
                     Order="Primary"
                     Priority="0"
                     Clicked="OnCancelClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="15">

                <!-- Type de matériel -->
                <Label Text="Type de materiel"
                       FontSize="16"
                       FontAttributes="Bold"/>
                <Picker x:Name="TypePicker"
                        Title="Choisir un type"
                        SelectedIndexChanged="OnTypeChanged">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Canne</x:String>
                            <x:String>Fil</x:String>
                            <x:String>Bas de ligne</x:String>
                            <x:String>Appat ou leurre</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </Picker>

                <!-- Nom -->
                <Label Text="Nom"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,10,0,0"/>
                <Entry x:Name="NameEntry"
                       Placeholder="Nom du materiel (obligatoire)"/>

                <!-- Marque -->
                <Label Text="Marque"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,10,0,0"/>
                <Entry x:Name="BrandEntry"
                       Placeholder="Marque (optionnel)"/>

                <!-- Champs spécifiques selon le type -->
                <VerticalStackLayout x:Name="CanneFields" IsVisible="False" Spacing="10">
                    <Label Text="Longueur"
                           FontSize="14"
                           FontAttributes="Bold"/>
                    <Entry x:Name="LengthEntry"
                           Placeholder="ex: 2.40 m"/>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="FilFields" IsVisible="False" Spacing="10">
                    <Label Text="Resistance"
                           FontSize="14"
                           FontAttributes="Bold"/>
                    <Entry x:Name="StrengthEntry"
                           Placeholder="ex: 0.15 mm - 10 kg"/>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="BasDeLigneFields" IsVisible="False" Spacing="10">
                    <Label Text="Resistance"
                           FontSize="14"
                           FontAttributes="Bold"/>
                    <Entry x:Name="StrengthEntry2"
                           Placeholder="ex: 0.30 mm - 6 kg"/>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="AppAtFields" IsVisible="False" Spacing="10">
                    <Label Text="Couleur"
                           FontSize="14"
                           FontAttributes="Bold"/>
                    <Entry x:Name="ColorEntry"
                           Placeholder="ex: Perche, Rouge, etc."/>
                </VerticalStackLayout>

                <!-- Description -->
                <Label Text="Description"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,10,0,0"/>
                <Editor x:Name="DescriptionEditor"
                        Placeholder="Description (optionnel)"
                        HeightRequest="80"
                        AutoSize="TextChanges"/>

                <!-- Date d'achat -->
                <Label Text="Date d'achat"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,10,0,0"/>
                <DatePicker x:Name="PurchaseDatePicker"
                            Format="dd/MM/yyyy"/>

                <!-- Notes -->
                <Label Text="Notes"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,10,0,0"/>
                <Editor x:Name="NotesEditor"
                        Placeholder="Notes supplementaires (optionnel)"
                        HeightRequest="80"
                        AutoSize="TextChanges"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Boutons -->
        <Grid Grid.Row="1" 
              ColumnDefinitions="*,*" 
              ColumnSpacing="10"
              Padding="20,10">
            <Button Grid.Column="0"
                    Text="Cancel"
                    Clicked="OnCancelClicked"
                    BackgroundColor="#E0E0E0"
                    TextColor="Black"
                    CornerRadius="8"
                    HeightRequest="50"/>
            <Button Grid.Column="1"
                    Text="Save"
                    Clicked="OnSaveClicked"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50"/>
        </Grid>
    </Grid>

</ContentPage>
