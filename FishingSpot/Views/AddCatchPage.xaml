<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FishingSpot.Views.AddCatchPage"
             Title="Nouvelle Capture">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="✕"
                     Order="Primary"
                     Priority="0"
                     Clicked="OnCancelClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="15">

                <Label Text="Photo du Poisson"
                       FontSize="16"
                       FontAttributes="Bold"/>

                <Frame Padding="0"
                       CornerRadius="10"
                       IsClippedToBounds="True"
                       HasShadow="True"
                       HeightRequest="200"
                       BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#3A3A3A}">
                    <Grid>
                        <Label x:Name="PhotoPlaceholder"
                               Text="Appuyez pour prendre une photo"
                               FontSize="18"
                               TextColor="Gray"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Image x:Name="PhotoImage"
                               IsVisible="False"
                               Aspect="AspectFill"/>
                    </Grid>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTakePhotoClicked"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <Label Text="Informations du Poisson"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,10,0,0"/>

                <Entry x:Name="FishNameEntry"
                       Placeholder="Nom du poisson (obligatoire)"
                       PlaceholderColor="Gray"/>

                <Label Text="Mesures"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,10,0,0"/>

                <!-- Taille et Poids sur la même ligne -->
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="15" RowSpacing="10">

                    <!-- TAILLE (Longueur) -->
                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="5">
                        <Label Text="Longueur"
                               FontSize="14"
                               FontAttributes="Bold"/>
                        <Grid ColumnDefinitions="*,Auto,*,Auto" ColumnSpacing="5">
                            <Entry Grid.Column="0"
                                   x:Name="LengthMetersEntry"
                                   Placeholder="0"
                                   Keyboard="Numeric"
                                   HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="1"
                                   Text="M"
                                   VerticalOptions="Center"
                                   FontSize="12"
                                   Margin="2,0"/>

                            <Entry Grid.Column="2"
                                   x:Name="LengthCentimetersEntry"
                                   Placeholder="0"
                                   Keyboard="Numeric"
                                   HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="3"
                                   Text="CM"
                                   VerticalOptions="Center"
                                   FontSize="12"
                                   Margin="2,0"/>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- POIDS -->
                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5">
                        <Label Text="Poids"
                               FontSize="14"
                               FontAttributes="Bold"/>
                        <Grid ColumnDefinitions="*,Auto,*,Auto" ColumnSpacing="5">
                            <Entry Grid.Column="0"
                                   x:Name="WeightKilogramsEntry"
                                   Placeholder="0"
                                   Keyboard="Numeric"
                                   HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="1"
                                   Text="KG"
                                   VerticalOptions="Center"
                                   FontSize="12"
                                   Margin="2,0"/>

                            <Entry Grid.Column="2"
                                   x:Name="WeightGramsEntry"
                                   Placeholder="0"
                                   Keyboard="Numeric"
                                   HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="3"
                                   Text="GR"
                                   VerticalOptions="Center"
                                   FontSize="12"
                                   Margin="2,0"/>
                        </Grid>
                    </VerticalStackLayout>
                </Grid>

                <Label Text="Localisation"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,10,0,0"/>

                <Entry x:Name="LocationEntry"
                       Placeholder="Nom du lieu (optionnel)"/>

                <Button Text="Utiliser ma position actuelle"
                        Clicked="OnGetLocationClicked"
                        BackgroundColor="#2196F3"
                        TextColor="White"
                        CornerRadius="8"/>

                <Label x:Name="CoordinatesLabel"
                       Text="Coordonnees GPS: Non definie"
                       FontSize="12"
                       TextColor="Gray"
                       HorizontalTextAlignment="Center"/>

                <Label Text="Date et Heure"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,10,0,0"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Text="Date"/>
                        <DatePicker x:Name="CatchDatePicker"
                                    Format="dd/MM/yyyy"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label Text="Heure"/>
                        <TimePicker x:Name="CatchTimePicker"/>
                    </VerticalStackLayout>
                </Grid>

                <Label Text="Notes (optionnel)"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,10,0,0"/>

                <Editor x:Name="NotesEditor"
                        Placeholder="Conditions meteo, appat utilise, etc..."
                        HeightRequest="100"
                        AutoSize="TextChanges"/>

                <Label Text="Setup utilise"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,10,0,0"/>

                <Picker x:Name="SetupPicker"
                        Title="Choisir un setup (optionnel)"/>

                <Label x:Name="SetupDetailsLabel"
                       FontSize="13"
                       TextColor="Gray"
                       Margin="0,5,0,0"
                       IsVisible="False"
                       LineBreakMode="WordWrap"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Boutons Cancel et Save en bas -->
        <Grid Grid.Row="1" 
              ColumnDefinitions="*,*" 
              ColumnSpacing="10"
              Padding="20,10"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">

            <Button Grid.Column="0"
                    Text="Cancel"
                    Clicked="OnCancelClicked"
                    BackgroundColor="#E0E0E0"
                    TextColor="Black"
                    CornerRadius="8"
                    HeightRequest="50"/>

            <Button Grid.Column="1"
                    Text="Save"
                    Clicked="OnSaveCatchClicked"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="50"/>
        </Grid>
    </Grid>

</ContentPage>
