<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FishingSpot.Views.FishCardDetailPage"
             Title=""
             BackgroundColor="#F0F0F0">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="✕"
                     Order="Primary"
                     Priority="0"
                     Clicked="OnCloseClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Carte Pokemon Style -->
            <Frame Padding="0"
                   CornerRadius="20"
                   HasShadow="True"
                   BorderColor="#FFD700"
                   BackgroundColor="White">

                <Grid RowDefinitions="Auto,200,Auto,Auto,Auto,Auto,Auto,Auto">

                    <!-- Header avec nom et type -->
                    <Grid Grid.Row="0" 
                          Padding="20,15"
                          BackgroundColor="#4A90E2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Column="0"
                               x:Name="FishNameLabel"
                               Text="Brochet"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center"/>

                        <Frame Grid.Column="1"
                               Padding="10,5"
                               CornerRadius="15"
                               BackgroundColor="#FFD700"
                               HasShadow="False">
                            <Label Text="RARE"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="#4A90E2"/>
                        </Frame>
                    </Grid>

                    <!-- Image du poisson -->
                    <Frame Grid.Row="1"
                           Margin="20,10,20,0"
                           Padding="0"
                           CornerRadius="15"
                           IsClippedToBounds="True"
                           HasShadow="False"
                           BackgroundColor="#E8F4F8">
                        <Grid>
                            <Label x:Name="PhotoPlaceholder"
                                   Text="Poisson"
                                   FontSize="60"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   TextColor="#4A90E2"/>
                            <Image x:Name="PhotoImage"
                                   IsVisible="False"
                                   Aspect="AspectFill"/>
                        </Grid>
                    </Frame>

                    <!-- Stats principales -->
                    <Grid Grid.Row="2"
                          Padding="20,15"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="10">

                        <!-- Taille -->
                        <Frame Grid.Column="0"
                               Padding="15,10"
                               CornerRadius="12"
                               BackgroundColor="#FFE8A3"
                               HasShadow="False">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="TAILLE"
                                       FontSize="11"
                                       TextColor="#8B7355"
                                       HorizontalOptions="Center"
                                       FontAttributes="Bold"/>
                                <Label x:Name="LengthLabel"
                                       Text="45.0 cm"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#D4A574"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Poids -->
                        <Frame Grid.Column="1"
                               Padding="15,10"
                               CornerRadius="12"
                               BackgroundColor="#FFB3BA"
                               HasShadow="False">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="POIDS"
                                       FontSize="11"
                                       TextColor="#8B4555"
                                       HorizontalOptions="Center"
                                       FontAttributes="Bold"/>
                                <Label x:Name="WeightLabel"
                                       Text="2.5 kg"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="#D4747A"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                    <!-- Informations -->
                    <VerticalStackLayout Grid.Row="3" Padding="20,10" Spacing="12">

                        <!-- Lieu -->
                        <Frame Padding="12"
                               CornerRadius="10"
                               BackgroundColor="#E3F2E1"
                               HasShadow="False">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       Text="Lieu:"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#4A7C59"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="1"
                                       x:Name="LocationLabel"
                                       Text="Lac de Sainte-Croix"
                                       FontSize="14"
                                       TextColor="#2D5A3D"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>

                        <!-- Date -->
                        <Frame Padding="12"
                               CornerRadius="10"
                               BackgroundColor="#E1E8F2"
                               HasShadow="False">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       Text="Date:"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#3D5A7C"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="1"
                                       x:Name="DateLabel"
                                       Text="13/03/2026 a 15:30"
                                       FontSize="14"
                                       TextColor="#2D4A5A"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>

                        <!-- GPS -->
                        <Frame Padding="12"
                               CornerRadius="10"
                               BackgroundColor="#F2E1F2"
                               HasShadow="False">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Grid.Column="0"
                                       Text="GPS:"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#7C3D7C"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="1"
                                       x:Name="GPSLabel"
                                       Text="43.2965, 5.3698"
                                       FontSize="12"
                                       TextColor="#5A2D5A"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Notes -->
                    <VerticalStackLayout Grid.Row="4" 
                                         Padding="20,0,20,10" 
                                         Spacing="8"
                                         x:Name="NotesSection">
                        <Label Text="NOTES"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#666"/>
                        <Frame Padding="12"
                               CornerRadius="10"
                               BackgroundColor="#F9F9F9"
                               HasShadow="False">
                            <Label x:Name="NotesLabel"
                                   Text="Belle prise ! Temps ensoleille, appat: ver de terre"
                                   FontSize="13"
                                   TextColor="#555"
                                   LineBreakMode="WordWrap"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Footer -->
                    <Grid Grid.Row="5"
                          Padding="20,15"
                          BackgroundColor="#F5F5F5">
                        <Label Text="Collection FishingSpot"
                               FontSize="10"
                               TextColor="#999"
                               HorizontalOptions="Center"
                               FontAttributes="Italic"/>
                    </Grid>

                    <!-- Boutons -->
                    <Grid Grid.Row="7"
                          Padding="15"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="Modifier"
                                Clicked="OnEditClicked"
                                BackgroundColor="#4A90E2"
                                TextColor="White"
                                CornerRadius="10"/>
                        <Button Grid.Column="1"
                                Text="Supprimer"
                                Clicked="OnDeleteClicked"
                                BackgroundColor="#E74C3C"
                                TextColor="White"
                                CornerRadius="10"/>
                    </Grid>
                </Grid>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
