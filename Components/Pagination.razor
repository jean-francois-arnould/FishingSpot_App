@typeparam TItem
@using FishingSpot.PWA.Models

<div class="pagination-container">
    @if (PagedResult != null && PagedResult.TotalPages > 1)
    {
        <div class="pagination">
            <button class="pagination-btn" 
                    @onclick="@(() => OnPageChanged(1))" 
                    disabled="@(!PagedResult.HasPreviousPage)">
                ⏮️
            </button>

            <button class="pagination-btn" 
                    @onclick="@(() => OnPageChanged(PagedResult.Page - 1))" 
                    disabled="@(!PagedResult.HasPreviousPage)">
                ◀️
            </button>

            <span class="pagination-info">
                Page @PagedResult.Page sur @PagedResult.TotalPages
            </span>

            <button class="pagination-btn" 
                    @onclick="@(() => OnPageChanged(PagedResult.Page + 1))" 
                    disabled="@(!PagedResult.HasNextPage)">
                ▶️
            </button>

            <button class="pagination-btn" 
                    @onclick="@(() => OnPageChanged(PagedResult.TotalPages))" 
                    disabled="@(!PagedResult.HasNextPage)">
                ⏭️
            </button>
        </div>

        <div class="pagination-summary">
            Affichage de @GetStartIndex() à @GetEndIndex() sur @PagedResult.TotalCount résultats
        </div>
    }
</div>

@code {
    [Parameter]
    public PagedResult<TItem>? PagedResult { get; set; }

    [Parameter]
    public EventCallback<int> OnPageChange { get; set; }

    private async Task OnPageChanged(int newPage)
    {
        if (newPage != PagedResult?.Page)
        {
            await OnPageChange.InvokeAsync(newPage);
        }
    }

    private int GetStartIndex()
    {
        if (PagedResult == null || PagedResult.Items.Count == 0)
            return 0;
        return ((PagedResult.Page - 1) * PagedResult.PageSize) + 1;
    }

    private int GetEndIndex()
    {
        if (PagedResult == null)
            return 0;
        return Math.Min(PagedResult.Page * PagedResult.PageSize, PagedResult.TotalCount);
    }
}
