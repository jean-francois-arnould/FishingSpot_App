@page "/FishingSpot_App/catches/{id}"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@inject SupabaseService SupabaseService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Détail de la prise</PageTitle>

<div class="catch-detail-container">
    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Chargement...</span>
            </div>
            <p class="mt-2">Chargement des détails...</p>
        </div>
    }
    else if (fishCatch == null)
    {
        <div class="error-container">
            <h3>❌ Prise non trouvée</h3>
            <p>Cette prise n'existe pas ou a été supprimée.</p>
            <button class="btn btn-primary" @onclick="GoToCatchesList">
                ← Retour à la liste
            </button>
        </div>
    }
    else
    {
        <!-- En-tête avec photo -->
        @if (!string.IsNullOrEmpty(fishCatch.PhotoUrl))
        {
            <div class="detail-photo-container">
                <img src="@fishCatch.PhotoUrl" alt="@fishCatch.FishName" class="detail-photo" />
            </div>
        }

        <!-- Informations principales -->
        <div class="detail-card">
            <div class="detail-header">
                <h1 class="fish-name">@fishCatch.FishName</h1>
            </div>

            <!-- Date et heure -->
            <div class="detail-section">
                <div class="section-icon">📅</div>
                <div class="section-content">
                    <h3>Date et heure</h3>
                    <p class="detail-value">@fishCatch.CatchDate.ToString("dddd d MMMM yyyy à HH:mm")</p>
                </div>
            </div>

            <!-- Localisation -->
            @if (!string.IsNullOrEmpty(fishCatch.LocationName) || !string.IsNullOrEmpty(fishCatch.Latitude))
            {
                <div class="detail-section">
                    <div class="section-icon">📍</div>
                    <div class="section-content">
                        <h3>Localisation</h3>
                        @if (!string.IsNullOrEmpty(fishCatch.LocationName))
                        {
                            <p class="detail-value">@fishCatch.LocationName</p>
                        }
                        @if (!string.IsNullOrEmpty(fishCatch.Latitude) && !string.IsNullOrEmpty(fishCatch.Longitude))
                        {
                            <p class="coordinates">
                                <small>
                                    Lat: @fishCatch.Latitude, Lon: @fishCatch.Longitude
                                    <a href="https://www.google.com/maps?q=@fishCatch.Latitude,@fishCatch.Longitude" 
                                       target="_blank" 
                                       class="map-link">
                                        🗺️ Voir sur la carte
                                    </a>
                                </small>
                            </p>
                        }
                    </div>
                </div>
            }

            <!-- Dimensions -->
            @if (fishCatch.Length > 0 || fishCatch.Weight > 0)
            {
                <div class="detail-section">
                    <div class="section-icon">📏</div>
                    <div class="section-content">
                        <h3>Dimensions</h3>
                        <div class="dimensions-grid">
                            @if (fishCatch.Length > 0)
                            {
                                <div class="dimension-item">
                                    <span class="dimension-label">Longueur</span>
                                    <span class="dimension-value">@fishCatch.Length cm</span>
                                </div>
                            }
                            @if (fishCatch.Weight > 0)
                            {
                                <div class="dimension-item">
                                    <span class="dimension-label">Poids</span>
                                    <span class="dimension-value">@fishCatch.Weight kg</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Notes -->
            @if (!string.IsNullOrEmpty(fishCatch.Notes))
            {
                <div class="detail-section">
                    <div class="section-icon">📝</div>
                    <div class="section-content">
                        <h3>Notes</h3>
                        <p class="detail-value">@fishCatch.Notes</p>
                    </div>
                </div>
            }
        </div>

        <!-- Boutons d'action -->
        <div class="detail-actions">
            <button class="btn btn-secondary btn-lg" @onclick="GoToCatchesList">
                ← Fermer
            </button>
            <button class="btn btn-primary btn-lg" @onclick="EditCatch">
                ✏️ Modifier
            </button>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private FishCatch? fishCatch;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadCatch();
    }

    private async Task LoadCatch()
    {
        isLoading = true;
        try
        {
            var catches = await SupabaseService.GetAllCatchesAsync();
            fishCatch = catches.FirstOrDefault(c => c.Id == Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement de la prise: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToCatchesList()
    {
        Navigation.NavigateTo("/FishingSpot_App/catches", forceLoad: true);
    }

    private void EditCatch()
    {
        Navigation.NavigateTo($"/FishingSpot_App/edit-catch/{Id}");
    }
}
