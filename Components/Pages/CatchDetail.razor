@page "/catches/{id:int}"
@page "/FishingSpot_App/catches/{id:int}"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@inject ISupabaseService SupabaseService
@inject IAuthService AuthService
@inject IShareService ShareService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Détail de la prise</PageTitle>

<div class="catch-detail-page">
    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Chargement des détails...</p>
        </div>
    }
    else if (fishCatch == null)
    {
        <div class="empty-state">
            <div class="empty-state-icon">❌</div>
            <h3>Prise non trouvée</h3>
            <p class="text-muted">Cette prise n'existe pas ou a été supprimée.</p>
            <button class="btn btn-primary" @onclick="GoToCatchesList">
                ← Retour à la liste
            </button>
        </div>
    }
    else
    {
        <!-- Photo en plein écran -->
        @if (!string.IsNullOrEmpty(fishCatch.PhotoUrl))
        {
            <div class="detail-photo-hero">
                <img src="@fishCatch.PhotoUrl" alt="@fishCatch.FishName" />
            </div>
        }

        <!-- Carte principale avec le nom du poisson -->
        <div class="detail-content">
            <div class="card fish-card">
                <h1 class="fish-name">@fishCatch.FishName</h1>
            </div>

            <!-- Carte Date et Heure -->
            <div class="card detail-card">
                <div class="card-icon">📅</div>
                <div class="card-content">
                    <h3 class="card-title">DATE ET HEURE</h3>
                    <p class="card-value">@fishCatch.CatchDate.ToString("dddd d MMMM yyyy à HH:mm")</p>
                </div>
            </div>

            <!-- Carte Localisation -->
            @if (!string.IsNullOrEmpty(fishCatch.LocationName) || !string.IsNullOrEmpty(fishCatch.Latitude))
            {
                <div class="card detail-card">
                    <div class="card-icon">📍</div>
                    <div class="card-content">
                        <h3 class="card-title">LOCALISATION</h3>
                        @if (!string.IsNullOrEmpty(fishCatch.LocationName))
                        {
                            <p class="card-value">@fishCatch.LocationName</p>
                        }
                        @if (!string.IsNullOrEmpty(fishCatch.Latitude) && !string.IsNullOrEmpty(fishCatch.Longitude))
                        {
                            <p class="card-coordinates">
                                Lat: @fishCatch.Latitude, Lon: @fishCatch.Longitude
                            </p>
                            <a href="https://www.google.com/maps?q=@fishCatch.Latitude,@fishCatch.Longitude" 
                               target="_blank" 
                               class="btn btn-outline-primary btn-sm">
                                🗺️ Voir sur la carte
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- Carte Météo -->
            @if (fishCatch.WeatherTemperature.HasValue || !string.IsNullOrEmpty(fishCatch.WeatherCondition))
            {
                <div class="card detail-card">
                    <div class="card-icon">🌤️</div>
                    <div class="card-content">
                        <h3 class="card-title">CONDITIONS MÉTÉO</h3>
                        <div class="weather-detail-info">
                            @if (fishCatch.WeatherTemperature.HasValue)
                            {
                                <div class="weather-detail-item">
                                    <span class="weather-detail-icon">@GetWeatherEmoji(fishCatch.WeatherCode ?? 0)</span>
                                    <div class="weather-detail-text">
                                        <span class="weather-detail-temp">@fishCatch.WeatherTemperature.Value.ToString("F1")°C</span>
                                        @if (!string.IsNullOrEmpty(fishCatch.WeatherCondition))
                                        {
                                            <span class="weather-detail-condition">@fishCatch.WeatherCondition</span>
                                        }
                                    </div>
                                </div>
                            }
                            @if (fishCatch.WindSpeed.HasValue || fishCatch.Humidity.HasValue)
                            {
                                <div class="weather-detail-extras">
                                    @if (fishCatch.WindSpeed.HasValue)
                                    {
                                        <span class="weather-extra-item">💨 @fishCatch.WindSpeed.Value.ToString("F1") km/h</span>
                                    }
                                    @if (fishCatch.Humidity.HasValue)
                                    {
                                        <span class="weather-extra-item">💧 @fishCatch.Humidity%</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Carte Dimensions -->
            @if (fishCatch.Length > 0 || fishCatch.Weight > 0)
            {
                <div class="card detail-card">
                    <div class="card-icon">📏</div>
                    <div class="card-content">
                        <h3 class="card-title">DIMENSIONS</h3>
                        <div class="dimensions-grid">
                            @if (fishCatch.Length > 0)
                            {
                                <div class="dimension-box">
                                    <span class="dimension-label">Longueur</span>
                                    <span class="dimension-value">@GetFormattedLength()</span>
                                </div>
                            }
                            @if (fishCatch.Weight > 0)
                            {
                                <div class="dimension-box">
                                    <span class="dimension-label">Poids</span>
                                    <span class="dimension-value">@GetFormattedWeight()</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Carte Notes -->
            @if (!string.IsNullOrEmpty(fishCatch.Notes))
            {
                <div class="card detail-card">
                    <div class="card-icon">📝</div>
                    <div class="card-content">
                        <h3 class="card-title">NOTES</h3>
                        <p class="card-value notes-text">@fishCatch.Notes</p>
                    </div>
                </div>
            }

            <!-- Carte Partage -->
            <div class="card detail-card share-card">
                <div class="card-icon">📤</div>
                <div class="card-content">
                    <h3 class="card-title">PARTAGER</h3>
                    <p class="text-muted mb-3">Partagez votre prise avec vos amis</p>

                    <div class="share-buttons-grid">
                        <button class="btn btn-share btn-share-image" @onclick="ShareAsImage" disabled="@isSharing">
                            @if (isSharing && sharingType == "image")
                            {
                                <div class="spinner-small"></div>
                            }
                            else
                            {
                                <span class="share-icon">🖼️</span>
                            }
                            <span class="share-label">Image</span>
                        </button>

                        <button class="btn btn-share btn-share-whatsapp" @onclick="ShareToWhatsApp" disabled="@isSharing">
                            @if (isSharing && sharingType == "whatsapp")
                            {
                                <div class="spinner-small"></div>
                            }
                            else
                            {
                                <span class="share-icon">💬</span>
                            }
                            <span class="share-label">WhatsApp</span>
                        </button>

                        <button class="btn btn-share btn-share-facebook" @onclick="ShareToFacebook" disabled="@isSharing">
                            @if (isSharing && sharingType == "facebook")
                            {
                                <div class="spinner-small"></div>
                            }
                            else
                            {
                                <span class="share-icon">📘</span>
                            }
                            <span class="share-label">Facebook</span>
                        </button>

                        <button class="btn btn-share btn-share-instagram" @onclick="ShareToInstagram" disabled="@isSharing">
                            @if (isSharing && sharingType == "instagram")
                            {
                                <div class="spinner-small"></div>
                            }
                            else
                            {
                                <span class="share-icon">📷</span>
                            }
                            <span class="share-label">Instagram</span>
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(shareMessage))
                    {
                        <div class="share-message @shareMessageType">
                            @shareMessage
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Boutons d'action fixés en bas -->
        <div class="detail-actions-fixed">
            <button class="btn btn-secondary" @onclick="GoToCatchesList">
                ← Fermer
            </button>
            <button class="btn btn-primary" @onclick="EditCatch">
                ✏️ Modifier
            </button>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private FishCatch? fishCatch;
    private bool isLoading = true;

    // Variables pour le partage
    private bool isSharing = false;
    private string sharingType = "";
    private string? shareMessage = null;
    private string shareMessageType = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadCatch();
    }

    private async Task LoadCatch()
    {
        isLoading = true;
        try
        {
            Console.WriteLine($"🔍 Loading catch with ID: {Id}");
            fishCatch = await SupabaseService.GetCatchByIdAsync(Id);

            if (fishCatch == null)
            {
                Console.WriteLine($"❌ Catch {Id} not found");
            }
            else
            {
                Console.WriteLine($"✅ Catch loaded: {fishCatch.FishName}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Erreur lors du chargement de la prise: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToCatchesList()
    {
        Navigation.NavigateTo("/FishingSpot_App/catches");
    }

    private void EditCatch()
    {
        Console.WriteLine($"🔀 Navigation vers édition de la prise {Id}");
        Navigation.NavigateTo($"/FishingSpot_App/catches/edit/{Id}");
    }

    // ============================================
    // MÉTHODES DE PARTAGE
    // ============================================

    private async Task ShareAsImage()
    {
        if (fishCatch == null || isSharing) return;

        isSharing = true;
        sharingType = "image";
        shareMessage = null;
        StateHasChanged();

        try
        {
            Console.WriteLine($"📤 Génération de l'image de partage pour {fishCatch.FishName}...");
            var success = await ShareService.ShareCatchImageAsync(fishCatch);

            if (success)
            {
                shareMessage = "✅ Image générée et partagée !";
                shareMessageType = "success";
                Console.WriteLine("✅ Image partagée avec succès");
            }
            else
            {
                shareMessage = "❌ Impossible de partager l'image";
                shareMessageType = "error";
                Console.WriteLine("❌ Échec du partage");
            }
        }
        catch (Exception ex)
        {
            shareMessage = $"❌ Erreur: {ex.Message}";
            shareMessageType = "error";
            Console.WriteLine($"❌ Erreur lors du partage: {ex.Message}");
        }
        finally
        {
            isSharing = false;
            StateHasChanged();

            // Effacer le message après 3 secondes
            await Task.Delay(3000);
            shareMessage = null;
            StateHasChanged();
        }
    }

    private async Task ShareToWhatsApp()
    {
        if (fishCatch == null || isSharing) return;

        isSharing = true;
        sharingType = "whatsapp";
        shareMessage = null;
        StateHasChanged();

        try
        {
            Console.WriteLine($"📤 Partage sur WhatsApp pour {fishCatch.FishName}...");
            var success = await ShareService.ShareCatchToWhatsAppAsync(fishCatch);

            if (success)
            {
                shareMessage = "✅ Ouverture de WhatsApp...";
                shareMessageType = "success";
                Console.WriteLine("✅ WhatsApp ouvert");
            }
            else
            {
                shareMessage = "❌ Impossible d'ouvrir WhatsApp";
                shareMessageType = "error";
                Console.WriteLine("❌ Échec de l'ouverture de WhatsApp");
            }
        }
        catch (Exception ex)
        {
            shareMessage = $"❌ Erreur: {ex.Message}";
            shareMessageType = "error";
            Console.WriteLine($"❌ Erreur lors du partage: {ex.Message}");
        }
        finally
        {
            isSharing = false;
            StateHasChanged();

            await Task.Delay(3000);
            shareMessage = null;
            StateHasChanged();
        }
    }

    private async Task ShareToFacebook()
    {
        if (fishCatch == null || isSharing) return;

        isSharing = true;
        sharingType = "facebook";
        shareMessage = null;
        StateHasChanged();

        try
        {
            Console.WriteLine($"📤 Partage sur Facebook pour {fishCatch.FishName}...");
            var success = await ShareService.ShareCatchToFacebookAsync(fishCatch);

            if (success)
            {
                shareMessage = "✅ Image générée pour Facebook !";
                shareMessageType = "success";
                Console.WriteLine("✅ Image partagée sur Facebook");
            }
            else
            {
                shareMessage = "❌ Impossible de partager sur Facebook";
                shareMessageType = "error";
                Console.WriteLine("❌ Échec du partage sur Facebook");
            }
        }
        catch (Exception ex)
        {
            shareMessage = $"❌ Erreur: {ex.Message}";
            shareMessageType = "error";
            Console.WriteLine($"❌ Erreur lors du partage: {ex.Message}");
        }
        finally
        {
            isSharing = false;
            StateHasChanged();

            await Task.Delay(3000);
            shareMessage = null;
            StateHasChanged();
        }
    }

    private async Task ShareToInstagram()
    {
        if (fishCatch == null || isSharing) return;

        isSharing = true;
        sharingType = "instagram";
        shareMessage = null;
        StateHasChanged();

        try
        {
            Console.WriteLine($"📤 Partage sur Instagram pour {fishCatch.FishName}...");
            var success = await ShareService.ShareCatchToInstagramAsync(fishCatch);

            if (success)
            {
                shareMessage = "✅ Image générée pour Instagram !";
                shareMessageType = "success";
                Console.WriteLine("✅ Image partagée sur Instagram");
            }
            else
            {
                shareMessage = "❌ Impossible de partager sur Instagram";
                shareMessageType = "error";
                Console.WriteLine("❌ Échec du partage sur Instagram");
            }
        }
        catch (Exception ex)
        {
            shareMessage = $"❌ Erreur: {ex.Message}";
            shareMessageType = "error";
            Console.WriteLine($"❌ Erreur lors du partage: {ex.Message}");
        }
        finally
        {
            isSharing = false;
            StateHasChanged();

            await Task.Delay(3000);
            shareMessage = null;
            StateHasChanged();
        }
    }

    private string GetFormattedLength()
    {
        if (fishCatch == null) return "";

        var meters = (int)(fishCatch.Length / 100);
        var centimeters = (int)(fishCatch.Length % 100);

        if (meters > 0)
        {
            return $"{meters} m {centimeters} cm";
        }
        return $"{centimeters} cm";
    }

    private string GetFormattedWeight()
    {
        if (fishCatch == null) return "";

        var kilograms = (int)(fishCatch.Weight / 1000);
        var grams = (int)(fishCatch.Weight % 1000);

        if (kilograms > 0)
        {
            return $"{kilograms} kg {grams} g";
        }
        return $"{grams} g";
    }

    private string GetWeatherEmoji(int code)
    {
        return code switch
        {
            0 => "☀️",
            1 => "🌤️",
            2 => "⛅",
            3 => "☁️",
            45 or 48 => "🌫️",
            51 or 53 or 55 => "🌦️",
            61 or 63 or 65 => "🌧️",
            71 or 73 or 75 => "🌨️",
            77 => "🌨️",
            80 or 81 or 82 => "🌧️",
            85 or 86 => "🌨️",
            95 => "⛈️",
            96 or 99 => "⛈️",
            _ => "🌡️"
        };
    }
}
