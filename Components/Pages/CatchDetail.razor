@page "/catches/{id:int}"
@page "/FishingSpot_App/catches/{id:int}"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Services
@inject ISupabaseService SupabaseService
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Détail de la prise</PageTitle>

<div class="catch-detail-page">
    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Chargement des détails...</p>
        </div>
    }
    else if (fishCatch == null)
    {
        <div class="empty-state">
            <div class="empty-state-icon">❌</div>
            <h3>Prise non trouvée</h3>
            <p class="text-muted">Cette prise n'existe pas ou a été supprimée.</p>
            <button class="btn btn-primary" @onclick="GoToCatchesList">
                ← Retour à la liste
            </button>
        </div>
    }
    else
    {
        <!-- Photo en plein écran -->
        @if (!string.IsNullOrEmpty(fishCatch.PhotoUrl))
        {
            <div class="detail-photo-hero">
                <img src="@fishCatch.PhotoUrl" alt="@fishCatch.FishName" />
            </div>
        }

        <!-- Carte principale avec le nom du poisson -->
        <div class="detail-content">
            <div class="card fish-card">
                <h1 class="fish-name">@fishCatch.FishName</h1>
            </div>

            <!-- Carte Date et Heure -->
            <div class="card detail-card">
                <div class="card-icon">📅</div>
                <div class="card-content">
                    <h3 class="card-title">DATE ET HEURE</h3>
                    <p class="card-value">@fishCatch.CatchDate.ToString("dddd d MMMM yyyy à HH:mm")</p>
                </div>
            </div>

            <!-- Carte Localisation -->
            @if (!string.IsNullOrEmpty(fishCatch.LocationName) || !string.IsNullOrEmpty(fishCatch.Latitude))
            {
                <div class="card detail-card">
                    <div class="card-icon">📍</div>
                    <div class="card-content">
                        <h3 class="card-title">LOCALISATION</h3>
                        @if (!string.IsNullOrEmpty(fishCatch.LocationName))
                        {
                            <p class="card-value">@fishCatch.LocationName</p>
                        }
                        @if (!string.IsNullOrEmpty(fishCatch.Latitude) && !string.IsNullOrEmpty(fishCatch.Longitude))
                        {
                            <p class="card-coordinates">
                                Lat: @fishCatch.Latitude, Lon: @fishCatch.Longitude
                            </p>
                            <a href="https://www.google.com/maps?q=@fishCatch.Latitude,@fishCatch.Longitude" 
                               target="_blank" 
                               class="btn btn-outline-primary btn-sm">
                                🗺️ Voir sur la carte
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- Carte Dimensions -->
            @if (fishCatch.Length > 0 || fishCatch.Weight > 0)
            {
                <div class="card detail-card">
                    <div class="card-icon">📏</div>
                    <div class="card-content">
                        <h3 class="card-title">DIMENSIONS</h3>
                        <div class="dimensions-grid">
                            @if (fishCatch.Length > 0)
                            {
                                <div class="dimension-box">
                                    <span class="dimension-label">Longueur</span>
                                    <span class="dimension-value">@GetFormattedLength()</span>
                                </div>
                            }
                            @if (fishCatch.Weight > 0)
                            {
                                <div class="dimension-box">
                                    <span class="dimension-label">Poids</span>
                                    <span class="dimension-value">@GetFormattedWeight()</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Carte Notes -->
            @if (!string.IsNullOrEmpty(fishCatch.Notes))
            {
                <div class="card detail-card">
                    <div class="card-icon">📝</div>
                    <div class="card-content">
                        <h3 class="card-title">NOTES</h3>
                        <p class="card-value notes-text">@fishCatch.Notes</p>
                    </div>
                </div>
            }
        </div>

        <!-- Boutons d'action fixés en bas -->
        <div class="detail-actions-fixed">
            <button class="btn btn-secondary" @onclick="GoToCatchesList">
                ← Fermer
            </button>
            <button class="btn btn-primary" @onclick="EditCatch">
                ✏️ Modifier
            </button>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private FishCatch? fishCatch;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadCatch();
    }

    private async Task LoadCatch()
    {
        isLoading = true;
        try
        {
            Console.WriteLine($"🔍 Loading catch with ID: {Id}");
            fishCatch = await SupabaseService.GetCatchByIdAsync(Id);

            if (fishCatch == null)
            {
                Console.WriteLine($"❌ Catch {Id} not found");
            }
            else
            {
                Console.WriteLine($"✅ Catch loaded: {fishCatch.FishName}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Erreur lors du chargement de la prise: {ex.Message}");
            Console.WriteLine($"Stack trace: {ex.StackTrace}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToCatchesList()
    {
        Navigation.NavigateTo("/FishingSpot_App/catches");
    }

    private void EditCatch()
    {
        Navigation.NavigateTo($"/FishingSpot_App/edit-catch/{Id}");
    }

    private string GetFormattedLength()
    {
        if (fishCatch == null) return "";

        var meters = (int)(fishCatch.Length / 100);
        var centimeters = (int)(fishCatch.Length % 100);

        if (meters > 0)
        {
            return $"{meters} m {centimeters} cm";
        }
        return $"{centimeters} cm";
    }

    private string GetFormattedWeight()
    {
        if (fishCatch == null) return "";

        var kilograms = (int)(fishCatch.Weight / 1000);
        var grams = (int)(fishCatch.Weight % 1000);

        if (kilograms > 0)
        {
            return $"{kilograms} kg {grams} g";
        }
        return $"{grams} g";
    }
}
