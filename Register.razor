@page "/register"
@page "/FishingSpot_App/register"
@using FishingSpot.PWA.Services
@using FishingSpot.PWA.Models
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject NavigationManager Navigation

<PageTitle>Register</PageTitle>

<div class="container" style="max-width: 600px; margin-top: 50px;">
    <div class="card">
        <div class="card-body">
            <h3 class="card-title text-center mb-4">🎣 Créer un compte</h3>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @errorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success" role="alert">
                    @successMessage
                </div>
            }

            <EditForm Model="@registerModel" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <!-- Section Connexion -->
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">🔐 Informations de connexion</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="email" class="form-label">Email *</label>
                            <InputText id="email" class="form-control" @bind-Value="registerModel.Email" placeholder="votre@email.com" required />
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Mot de passe *</label>
                            <InputText id="password" type="password" class="form-control" @bind-Value="registerModel.Password" placeholder="••••••••" required />
                            <small class="form-text text-muted">Minimum 6 caractères</small>
                        </div>

                        <div class="mb-3">
                            <label for="confirmPassword" class="form-label">Confirmer le mot de passe *</label>
                            <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="registerModel.ConfirmPassword" placeholder="••••••••" required />
                        </div>
                    </div>
                </div>

                <!-- Section Profil -->
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">👤 Informations personnelles</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="displayName" class="form-label">Nom d'affichage *</label>
                            <InputText id="displayName" class="form-control" @bind-Value="registerModel.DisplayName" placeholder="Jean Dupont" required />
                            <small class="form-text text-muted">Ce nom sera visible par les autres utilisateurs</small>
                        </div>

                        <div class="mb-3">
                            <label for="avatarUrl" class="form-label">URL de l'avatar</label>
                            <InputText id="avatarUrl" class="form-control" @bind-Value="registerModel.AvatarUrl" placeholder="https://..." />
                            <small class="form-text text-muted">Optionnel : lien vers votre photo de profil</small>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-success w-100" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Créer mon compte
                </button>
            </EditForm>

            <hr class="my-4" />

            <div class="text-center">
                <p class="mb-0">Déjà un compte?</p>
                <a href="/FishingSpot_App/login" class="btn btn-outline-primary mt-2">Se connecter</a>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/");
        }
    }

    private async Task HandleRegister()
    {
        errorMessage = null;
        successMessage = null;

        // Validation des mots de passe
        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            errorMessage = "Les mots de passe ne correspondent pas.";
            return;
        }

        if (registerModel.Password.Length < 6)
        {
            errorMessage = "Le mot de passe doit contenir au moins 6 caractères.";
            return;
        }

        // Validation des champs obligatoires
        if (string.IsNullOrWhiteSpace(registerModel.DisplayName))
        {
            errorMessage = "Le nom d'affichage est obligatoire.";
            return;
        }

        isLoading = true;

        try
        {
            // 1. Créer le compte utilisateur
            var (success, message) = await AuthService.SignUpAsync(registerModel.Email, registerModel.Password);

            if (success)
            {
                successMessage = "Compte créé avec succès ! Connexion en cours...";

                // 2. Se connecter automatiquement
                var (loginSuccess, loginMessage) = await AuthService.SignInAsync(registerModel.Email, registerModel.Password);

                if (loginSuccess)
                {
                    // 3. Créer le profil utilisateur avec le DisplayName
                    var profile = new UserProfile
                    {
                        DisplayName = registerModel.DisplayName.Trim(),
                        AvatarUrl = registerModel.AvatarUrl?.Trim() ?? string.Empty
                    };

                    var profileCreated = await ProfileService.CreateOrUpdateProfileAsync(profile);

                    if (profileCreated)
                    {
                        successMessage = "✅ Compte et profil créés avec succès ! Redirection...";
                        await Task.Delay(1500);
                        Navigation.NavigateTo("/FishingSpot_App/");
                    }
                    else
                    {
                        errorMessage = "Compte créé mais erreur lors de la création du profil. Vous pouvez le compléter dans 'Mon Compte'.";
                        await Task.Delay(3000);
                        Navigation.NavigateTo("/FishingSpot_App/");
                    }
                }
                else
                {
                    successMessage = "Compte créé ! Veuillez vous connecter.";
                    await Task.Delay(2000);
                    Navigation.NavigateTo("/FishingSpot_App/login");
                }
            }
            else
            {
                errorMessage = message;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private class RegisterModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public string AvatarUrl { get; set; } = string.Empty;
    }
}
