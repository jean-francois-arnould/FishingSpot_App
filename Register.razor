@page "/register"
@page "/FishingSpot_App/register"
@using FishingSpot.PWA.Services
@using FishingSpot.PWA.Models
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject NavigationManager Navigation

<PageTitle>Register</PageTitle>

<div class="container" style="max-width: 600px; margin-top: 50px;">
    <div class="card">
        <div class="card-body">
            <h3 class="card-title text-center mb-4">🎣 Créer un compte</h3>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @errorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success" role="alert">
                    @successMessage
                </div>
            }

            <EditForm Model="@registerModel" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <!-- Section Connexion -->
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">🔐 Informations de connexion</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="email" class="form-label">Email *</label>
                            <InputText id="email" class="form-control" @bind-Value="registerModel.Email" placeholder="votre@email.com" required />
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Mot de passe *</label>
                            <InputText id="password" type="password" class="form-control" @bind-Value="registerModel.Password" placeholder="••••••••" required />
                            <small class="form-text text-muted">Minimum 6 caractères</small>
                        </div>

                        <div class="mb-3">
                            <label for="confirmPassword" class="form-label">Confirmer le mot de passe *</label>
                            <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="registerModel.ConfirmPassword" placeholder="••••••••" required />
                        </div>
                    </div>
                </div>

                <!-- Section Profil -->
                <div class="card mb-3">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">👤 Informations personnelles</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="firstName" class="form-label">Prénom *</label>
                                <InputText id="firstName" class="form-control" @bind-Value="registerModel.FirstName" placeholder="Jean" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="lastName" class="form-label">Nom *</label>
                                <InputText id="lastName" class="form-control" @bind-Value="registerModel.LastName" placeholder="Dupont" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label for="city" class="form-label">Ville *</label>
                                <InputText id="city" class="form-control" @bind-Value="registerModel.City" placeholder="Paris" required />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label for="postalCode" class="form-label">Code Postal *</label>
                                <InputText id="postalCode" class="form-control" @bind-Value="registerModel.PostalCode" placeholder="75001" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="country" class="form-label">Pays</label>
                            <InputText id="country" class="form-control" @bind-Value="registerModel.Country" placeholder="France" />
                        </div>

                        <div class="mb-3">
                            <label for="phone" class="form-label">Téléphone</label>
                            <InputText id="phone" class="form-control" @bind-Value="registerModel.Phone" placeholder="+33 6 12 34 56 78" />
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-success w-100" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Créer mon compte
                </button>
            </EditForm>

            <hr class="my-4" />

            <div class="text-center">
                <p class="mb-0">Déjà un compte?</p>
                <a href="/login" class="btn btn-outline-primary mt-2">Se connecter</a>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/FishingSpot_App/catches");
        }
    }

    private async Task HandleRegister()
    {
        errorMessage = null;
        successMessage = null;

        // Validation des mots de passe
        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            errorMessage = "Les mots de passe ne correspondent pas.";
            return;
        }

        if (registerModel.Password.Length < 6)
        {
            errorMessage = "Le mot de passe doit contenir au moins 6 caractères.";
            return;
        }

        // Validation des champs obligatoires
        if (string.IsNullOrWhiteSpace(registerModel.FirstName))
        {
            errorMessage = "Le prénom est obligatoire.";
            return;
        }

        if (string.IsNullOrWhiteSpace(registerModel.LastName))
        {
            errorMessage = "Le nom est obligatoire.";
            return;
        }

        if (string.IsNullOrWhiteSpace(registerModel.City))
        {
            errorMessage = "La ville est obligatoire.";
            return;
        }

        if (string.IsNullOrWhiteSpace(registerModel.PostalCode))
        {
            errorMessage = "Le code postal est obligatoire.";
            return;
        }

        isLoading = true;

        try
        {
            // 1. Créer le compte utilisateur
            var (success, message) = await AuthService.SignUpAsync(registerModel.Email, registerModel.Password);

            if (success)
            {
                successMessage = "Compte créé avec succès ! Connexion en cours...";

                // 2. Se connecter automatiquement
                var (loginSuccess, loginMessage) = await AuthService.SignInAsync(registerModel.Email, registerModel.Password);

                if (loginSuccess)
                {
                    // 3. Créer le profil utilisateur
                    var profile = new UserProfile
                    {
                        FirstName = registerModel.FirstName,
                        LastName = registerModel.LastName,
                        City = registerModel.City,
                        PostalCode = registerModel.PostalCode,
                        Country = registerModel.Country,
                        Phone = registerModel.Phone
                    };

                    var profileCreated = await ProfileService.CreateOrUpdateProfileAsync(profile);

                    if (profileCreated)
                    {
                        successMessage = "✅ Compte et profil créés avec succès ! Redirection...";
                        await Task.Delay(1500);
                        Navigation.NavigateTo("/FishingSpot_App/catches");
                    }
                    else
                    {
                        errorMessage = "Compte créé mais erreur lors de la création du profil. Vous pouvez le compléter dans 'Mon Compte'.";
                        await Task.Delay(3000);
                        Navigation.NavigateTo("/FishingSpot_App/catches");
                    }
                }
                else
                {
                    successMessage = "Compte créé ! Veuillez vous connecter.";
                    await Task.Delay(2000);
                    Navigation.NavigateTo("/FishingSpot_App/login");
                }
            }
            else
            {
                errorMessage = message;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private class RegisterModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string City { get; set; } = string.Empty;
        public string PostalCode { get; set; } = string.Empty;
        public string Country { get; set; } = string.Empty;
        public string Phone { get; set; } = string.Empty;
    }
}
