@page "/montages/ajouter"
@using FishingSpot.PWA.Models
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject ISupabaseService SupabaseService
@inject IEquipmentService EquipmentService
@inject IAuthService AuthService
@inject IUserProfileService ProfileService
@inject NavigationManager Navigation

<PageTitle>Créer un Montage</PageTitle>

<div class="container-fluid">
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">🎣 FishingSpot</a>
            <div class="navbar-nav me-auto">
                <a class="nav-link" href="/catches">Mes Prises</a>
                <a class="nav-link active" href="/montages">Montages</a>
                <a class="nav-link" href="/materiel">Matériel</a>
                <a class="nav-link" href="/profile">Profil</a>
            </div>
            <div class="d-flex">
                <span class="navbar-text me-3">
                    👋 @(userProfile != null && !string.IsNullOrEmpty(userProfile.FirstName) 
                        ? $"{userProfile.FirstName} {userProfile.LastName}" 
                        : AuthService.CurrentUser?.Email)
                </span>
                <button class="btn btn-outline-danger btn-sm" @onclick="HandleLogout">
                    Déconnexion
                </button>
            </div>
        </div>
    </nav>

    <div class="container">
        <h3 class="mb-4">🎣 Créer un Montage</h3>

        @if (isLoadingEquipment)
        {
            <div class="text-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Chargement du matériel...</span>
                </div>
            </div>
        }
        else
        {
            <EditForm Model="@newSetup" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="description" class="form-label">Nom du montage</label>
                    <InputText id="description" class="form-control" @bind-Value="newSetup.Description" placeholder="Ex: Montage carnassier été" />
                    <small class="form-text text-muted">Donnez un nom descriptif à votre montage</small>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="rod" class="form-label">🎣 Canne</label>
                        <InputSelect id="rod" class="form-select" @bind-Value="selectedRodId">
                            <option value="">-- Aucune --</option>
                            @foreach (var rod in rods)
                            {
                                <option value="@rod.Id">@rod.Brand @rod.Model (@rod.Length)</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="col-md-6">
                        <label for="reel" class="form-label">🎡 Moulinet</label>
                        <InputSelect id="reel" class="form-select" @bind-Value="selectedReelId">
                            <option value="">-- Aucun --</option>
                            @foreach (var reel in reels)
                            {
                                <option value="@reel.Id">@reel.Brand @reel.Model</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="line" class="form-label">🧵 Fil</label>
                        <InputSelect id="line" class="form-select" @bind-Value="selectedLineId">
                            <option value="">-- Aucun --</option>
                            @foreach (var line in lines)
                    {
                        <option value="@line.Id">@line.Brand @line.Type @(!string.IsNullOrEmpty(line.Strength) ? $"({line.Strength})" : "")</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label for="lure" class="form-label">🪝 Leurre</label>
                <InputSelect id="lure" class="form-select" @bind-Value="selectedLureId">
                    <option value="">-- Aucun --</option>
                    @foreach (var lure in lures)
                    {
                        <option value="@lure.Id">@lure.Name @(!string.IsNullOrEmpty(lure.Type) ? $"({lure.Type})" : "")</option>
                    }
                </InputSelect>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label for="leader" class="form-label">⛓️ Bas de ligne</label>
                <InputSelect id="leader" class="form-select" @bind-Value="selectedLeaderId">
                    <option value="">-- Aucun --</option>
                    @foreach (var leader in leaders)
                    {
                        <option value="@leader.Id">@leader.Material @(!string.IsNullOrEmpty(leader.Strength) ? $"({leader.Strength})" : "")</option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-6">
                <label for="hook" class="form-label">🪝 Hameçon</label>
                <InputSelect id="hook" class="form-select" @bind-Value="selectedHookId">
                    <option value="">-- Aucun --</option>
                    @foreach (var hook in hooks)
                    {
                        <option value="@hook.Id">Taille @hook.Size @(!string.IsNullOrEmpty(hook.Type) ? $"({hook.Type})" : "")</option>
                    }
                </InputSelect>
            </div>
        </div>

        <div class="mb-3 form-check">
            <InputCheckbox id="isFavorite" class="form-check-input" @bind-Value="newSetup.IsFavorite" />
            <label class="form-check-label" for="isFavorite">
                ⭐ Marquer comme favori
            </label>
        </div>

        <div class="mb-3 form-check">
            <InputCheckbox id="isCurrent" class="form-check-input" @bind-Value="setAsCurrent" />
            <label class="form-check-label" for="isCurrent">
                ✅ Définir comme montage actuel
            </label>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(warningMessage))
        {
            <div class="alert alert-warning">@warningMessage</div>
        }

                    <div class="mt-3">
                        <button type="submit" class="btn btn-success" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            <i class="bi bi-check-circle"></i> Enregistrer
                        </button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancel">
                            <i class="bi bi-x-circle"></i> Annuler
                        </button>
                    </div>
                </EditForm>
                }
            </div>
        </div>

@code {
    private FishingSetup newSetup = new();
    private UserProfile? userProfile;
    private bool setAsCurrent = false;

    // Listes d'équipement
    private List<Rod> rods = new();
    private List<Reel> reels = new();
    private List<Line> lines = new();
    private List<Lure> lures = new();
    private List<Leader> leaders = new();
    private List<Hook> hooks = new();

    // IDs sélectionnés (en string pour InputSelect)
    private string selectedRodId = "";
    private string selectedReelId = "";
    private string selectedLineId = "";
    private string selectedLureId = "";
    private string selectedLeaderId = "";
    private string selectedHookId = "";

    private bool isLoadingEquipment = true;
    private bool isSubmitting = false;
    private string? errorMessage;
    private string? warningMessage;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        // Charger le profil et l'équipement en parallèle
        var profileTask = ProfileService.GetProfileAsync();
        var equipmentTask = LoadAllEquipment();

        await Task.WhenAll(profileTask, equipmentTask);

        userProfile = await profileTask;
    }

    private async Task LoadAllEquipment()
    {
        isLoadingEquipment = true;
        try
        {
            // Charger tout l'équipement en parallèle
            rods = await EquipmentService.GetAllRodsAsync();
            reels = await EquipmentService.GetAllReelsAsync();
            lines = await EquipmentService.GetAllLinesAsync();
            lures = await EquipmentService.GetAllLuresAsync();
            leaders = await EquipmentService.GetAllLeadersAsync();
            hooks = await EquipmentService.GetAllHooksAsync();

            // Vérifier si l'utilisateur a du matériel
            if (!rods.Any() && !reels.Any() && !lines.Any() && !lures.Any() && !leaders.Any() && !hooks.Any())
            {
                warningMessage = "Vous n'avez pas encore de matériel. Ajoutez d'abord du matériel dans la section Matériel.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement du matériel: {ex.Message}";
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isLoadingEquipment = false;
        }
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            // Convertir les IDs sélectionnés
            newSetup.RodId = !string.IsNullOrEmpty(selectedRodId) ? int.Parse(selectedRodId) : null;
            newSetup.ReelId = !string.IsNullOrEmpty(selectedReelId) ? int.Parse(selectedReelId) : null;
            newSetup.LineId = !string.IsNullOrEmpty(selectedLineId) ? int.Parse(selectedLineId) : null;
            newSetup.LureId = !string.IsNullOrEmpty(selectedLureId) ? int.Parse(selectedLureId) : null;
            newSetup.LeaderId = !string.IsNullOrEmpty(selectedLeaderId) ? int.Parse(selectedLeaderId) : null;
            newSetup.HookId = !string.IsNullOrEmpty(selectedHookId) ? int.Parse(selectedHookId) : null;

            // Vérifier qu'au moins un équipement est sélectionné
            if (!newSetup.RodId.HasValue && !newSetup.ReelId.HasValue && !newSetup.LineId.HasValue && 
                !newSetup.LureId.HasValue && !newSetup.LeaderId.HasValue && !newSetup.HookId.HasValue)
            {
                errorMessage = "Veuillez sélectionner au moins un élément d'équipement.";
                return;
            }

            // Créer le montage
            var createdSetupId = await SupabaseService.AddSetupAsync(newSetup);

            // Si "Définir comme actuel" est coché, mettre à jour
            if (setAsCurrent && createdSetupId > 0)
            {
                await SupabaseService.SetCurrentSetupAsync(createdSetupId);
            }

            Navigation.NavigateTo("/montages");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de la création du montage: {ex.Message}";
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/montages");
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/login");
    }
}
