@page "/materiel/hamecons/ajouter"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<h3 class="mb-4">🪝 Ajouter un Hameçon</h3>

<EditForm Model="@newHook" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="size" class="form-label">Taille *</label>
        <InputText id="size" class="form-control" @bind-Value="newHook.Size" required />
        <small class="form-text text-muted">Ex: 1/0, 2, 4, 6, 8, 10</small>
    </div>

    <div class="mb-3">
        <label for="type" class="form-label">Type</label>
        <InputText id="type" class="form-control" @bind-Value="newHook.Type" />
        <small class="form-text text-muted">Ex: J Hook, Circle, Treble, Octopus</small>
    </div>

    <div class="mb-3">
        <label for="brand" class="form-label">Marque</label>
        <InputText id="brand" class="form-control" @bind-Value="newHook.Brand" />
    </div>

    <div class="mb-3">
        <label for="notes" class="form-label">Notes</label>
        <InputTextArea id="notes" class="form-control" @bind-Value="newHook.Notes" rows="3" />
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="mt-3">
        <button type="submit" class="btn btn-success" disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            }
            <i class="bi bi-check-circle"></i> Enregistrer
        </button>
        <button type="button" class="btn btn-secondary" @onclick="Cancel">
            <i class="bi bi-x-circle"></i> Annuler
        </button>
    </div>
</EditForm>

@code {
    private Hook newHook = new();
    private bool isSubmitting = false;
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(newHook.Size))
        {
            errorMessage = "La taille est requise.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            await EquipmentService.AddHookAsync(newHook);
            Navigation.NavigateTo("/materiel/hamecons");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de l'ajout de l'hameçon: {ex.Message}";
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/materiel/hamecons");
    }
}
