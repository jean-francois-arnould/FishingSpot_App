@page "/materiel/fils"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<h3 class="mb-4">🧵 Mes Fils</h3>

@if (isLoading)
{
    <div class="text-center">
        <div class="spinner-border text-info" role="status">
            <span class="visually-hidden">Chargement...</span>
        </div>
    </div>
}
else if (lines == null || !lines.Any())
{
    <div class="alert alert-info">
        <p class="mb-0">Vous n'avez pas encore de fils enregistrés.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var line in lines)
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card h-100">
                    <div class="card-header bg-info text-white">
                        <h5 class="card-title mb-0">@line.Brand</h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text">
                            <strong>Type:</strong> @line.Type<br />
                            @if (!string.IsNullOrEmpty(line.Strength))
                            {
                                <span><strong>Résistance:</strong> @line.Strength<br /></span>
                            }
                            @if (!string.IsNullOrEmpty(line.Diameter))
                            {
                                <span><strong>Diamètre:</strong> @line.Diameter<br /></span>
                            }
                            @if (!string.IsNullOrEmpty(line.Color))
                            {
                                <span><strong>Couleur:</strong> @line.Color<br /></span>
                            }
                            @if (!string.IsNullOrEmpty(line.Notes))
                            {
                                <span><strong>Notes:</strong> @line.Notes</span>
                            }
                        </p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <button class="btn btn-sm btn-primary" @onclick="() => EditLine(line.Id)">
                            <i class="bi bi-pencil"></i> Modifier
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => ShowDeleteConfirmation(line)">
                            <i class="bi bi-trash"></i> Supprimer
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-3">
    <button class="btn btn-success" @onclick="AddLine">
        <i class="bi bi-plus-circle"></i> Ajouter un fil
    </button>
    <button class="btn btn-secondary" @onclick="GoBack">
        <i class="bi bi-arrow-left"></i> Retour
    </button>
</div>

@if (showDeleteModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmer la suppression</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Êtes-vous sûr de vouloir supprimer le fil <strong>@lineToDelete?.Brand @lineToDelete?.Type</strong> ?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Annuler</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Supprimer</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<Line> lines = new();
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private Line? lineToDelete = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadLines();
    }

    private async Task LoadLines()
    {
        isLoading = true;
        try
        {
            lines = await EquipmentService.GetAllLinesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des fils: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddLine()
    {
        Navigation.NavigateTo("/materiel/fils/ajouter");
    }

    private void EditLine(int id)
    {
        Navigation.NavigateTo($"/materiel/fils/modifier/{id}");
    }

    private void ShowDeleteConfirmation(Line line)
    {
        lineToDelete = line;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
        lineToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (lineToDelete != null)
        {
            try
            {
                await EquipmentService.DeleteLineAsync(lineToDelete.Id);
                await LoadLines();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erreur lors de la suppression: {ex.Message}");
            }
        }
        showDeleteModal = false;
        lineToDelete = null;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/materiel");
    }
}
