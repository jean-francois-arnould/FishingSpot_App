@page "/materiel/cannes/ajouter"
@page "/FishingSpot_App/materiel/cannes/ajouter"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IAuthService AuthService
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Ajouter une Canne</PageTitle>

<div class="container-fluid">
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">🎣 FishingSpot</a>
            <div class="navbar-nav me-auto">
                <a class="nav-link" href="/catches">Mes Prises</a>
                <a class="nav-link" href="/montages">Montages</a>
                <a class="nav-link active" href="/materiel">Matériel</a>
                <a class="nav-link" href="/profile">Profil</a>
            </div>
            <div class="d-flex">
                <span class="navbar-text me-3">
                    👋 @AuthService.CurrentUser?.Email
                </span>
                <button class="btn btn-outline-danger btn-sm" @onclick="HandleLogout">
                    Déconnexion
                </button>
            </div>
        </div>
    </nav>

    <div class="container" style="max-width: 800px;">
        <a href="/materiel/cannes" class="btn btn-outline-secondary btn-sm mb-3">
            ← Retour aux cannes
        </a>

        <h2>🎣 Ajouter une Canne</h2>
        <p class="text-muted">Enregistrez une nouvelle canne dans votre matériel</p>

        <hr class="my-4" />

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @errorMessage
            </div>
        }

        <EditForm Model="@newRod" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Informations principales</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="brand" class="form-label">Marque *</label>
                        <InputText id="brand" class="form-control" @bind-Value="newRod.Brand" 
                                   placeholder="Shimano, Daiwa, Abu Garcia..." required />
                        <ValidationMessage For="@(() => newRod.Brand)" />
                    </div>

                    <div class="mb-3">
                        <label for="model" class="form-label">Modèle *</label>
                        <InputText id="model" class="form-control" @bind-Value="newRod.Model" 
                                   placeholder="Ultegra, Procaster..." required />
                        <ValidationMessage For="@(() => newRod.Model)" />
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Caractéristiques</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="length" class="form-label">Longueur</label>
                        <InputText id="length" class="form-control" @bind-Value="newRod.Length" 
                                   placeholder="2.70m, 9ft..." />
                        <small class="text-muted">Exemple : 2.70m, 9ft, 270cm</small>
                    </div>

                    <div class="mb-3">
                        <label for="power" class="form-label">Puissance</label>
                        <InputText id="power" class="form-control" @bind-Value="newRod.Power" 
                                   placeholder="ML, M, MH, H..." />
                        <small class="text-muted">Light (L), Medium (M), Heavy (H), etc.</small>
                    </div>

                    <div class="mb-3">
                        <label for="action" class="form-label">Action</label>
                        <InputText id="action" class="form-control" @bind-Value="newRod.Action" 
                                   placeholder="Fast, Moderate, Slow..." />
                        <small class="text-muted">Fast, Moderate, Slow</small>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Notes</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="notes" class="form-label">Notes personnelles</label>
                        <InputTextArea id="notes" class="form-control" rows="4" @bind-Value="newRod.Notes" 
                                     placeholder="Utilisation préférée, état, historique..." />
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">
                    Annuler
                </button>
                <button type="submit" class="btn btn-primary btn-lg" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    ✅ Enregistrer
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private Rod newRod = new Rod();
    private string? errorMessage;
    private bool isSaving;

    protected override void OnInitialized()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login");
        }
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(newRod.Brand))
        {
            errorMessage = "La marque est obligatoire.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newRod.Model))
        {
            errorMessage = "Le modèle est obligatoire.";
            return;
        }

        isSaving = true;

        try
        {
            var rodId = await EquipmentService.AddRodAsync(newRod);

            if (rodId > 0)
            {
                Navigation.NavigateTo("/materiel/cannes");
            }
            else
            {
                errorMessage = "Erreur lors de l'enregistrement. Veuillez réessayer.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/materiel/cannes");
    }

    private async Task HandleLogout()
    {
        await AuthService.SignOutAsync();
        Navigation.NavigateTo("/");
    }
}
