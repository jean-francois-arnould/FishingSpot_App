@page "/materiel/hamecons/modifier/{HookId:int}"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<h3 class="mb-4">🪝 Modifier l'Hameçon</h3>

@if (isLoading)
{
    <div class="text-center">
        <div class="spinner-border text-danger" role="status">
            <span class="visually-hidden">Chargement...</span>
        </div>
    </div>
}
else if (hook == null)
{
    <div class="alert alert-danger">
        Hameçon non trouvé.
    </div>
}
else
{
    <EditForm Model="@hook" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="size" class="form-label">Taille *</label>
            <InputText id="size" class="form-control" @bind-Value="hook.Size" required />
            <small class="form-text text-muted">Ex: 1/0, 2, 4, 6, 8, 10</small>
        </div>

        <div class="mb-3">
            <label for="type" class="form-label">Type</label>
            <InputText id="type" class="form-control" @bind-Value="hook.Type" />
            <small class="form-text text-muted">Ex: J Hook, Circle, Treble, Octopus</small>
        </div>

        <div class="mb-3">
            <label for="brand" class="form-label">Marque</label>
            <InputText id="brand" class="form-control" @bind-Value="hook.Brand" />
        </div>

        <div class="mb-3">
            <label for="notes" class="form-label">Notes</label>
            <InputTextArea id="notes" class="form-control" @bind-Value="hook.Notes" rows="3" />
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <div class="mt-3">
            <button type="submit" class="btn btn-success" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                }
                <i class="bi bi-check-circle"></i> Enregistrer
            </button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">
                <i class="bi bi-x-circle"></i> Annuler
            </button>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public int HookId { get; set; }

    private Hook? hook;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var hooks = await EquipmentService.GetAllHooksAsync();
            hook = hooks.FirstOrDefault(h => h.Id == HookId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors du chargement: {ex.Message}";
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        if (hook == null || string.IsNullOrWhiteSpace(hook.Size))
        {
            errorMessage = "La taille est requise.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            await EquipmentService.UpdateHookAsync(hook);
            Navigation.NavigateTo("/materiel/hamecons");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur lors de la modification: {ex.Message}";
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/materiel/hamecons");
    }
}
