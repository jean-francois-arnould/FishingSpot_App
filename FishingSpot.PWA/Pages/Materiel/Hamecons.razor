@page "/materiel/hamecons"
@using FishingSpot.PWA.Models.Equipment
@using FishingSpot.PWA.Services
@inject IEquipmentService EquipmentService
@inject NavigationManager Navigation

<h3 class="mb-4">🪝 Mes Hameçons</h3>

@if (isLoading)
{
    <div class="text-center">
        <div class="spinner-border text-danger" role="status">
            <span class="visually-hidden">Chargement...</span>
        </div>
    </div>
}
else if (hooks == null || !hooks.Any())
{
    <div class="alert alert-danger">
        <p class="mb-0">Vous n'avez pas encore d'hameçons enregistrés.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var hook in hooks)
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card h-100">
                    <div class="card-header bg-danger text-white">
                        <h5 class="card-title mb-0">Taille @hook.Size</h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text">
                            @if (!string.IsNullOrEmpty(hook.Type))
                            {
                                <span><strong>Type:</strong> @hook.Type<br /></span>
                            }
                            @if (!string.IsNullOrEmpty(hook.Brand))
                            {
                                <span><strong>Marque:</strong> @hook.Brand<br /></span>
                            }
                            @if (!string.IsNullOrEmpty(hook.Notes))
                            {
                                <span><strong>Notes:</strong> @hook.Notes</span>
                            }
                        </p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <button class="btn btn-sm btn-primary" @onclick="() => EditHook(hook.Id)">
                            <i class="bi bi-pencil"></i> Modifier
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => ShowDeleteConfirmation(hook)">
                            <i class="bi bi-trash"></i> Supprimer
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-3">
    <button class="btn btn-success" @onclick="AddHook">
        <i class="bi bi-plus-circle"></i> Ajouter un hameçon
    </button>
    <button class="btn btn-secondary" @onclick="GoBack">
        <i class="bi bi-arrow-left"></i> Retour
    </button>
</div>

@if (showDeleteModal)
{
    <div class="modal fade show" style="display: block;" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirmer la suppression</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Êtes-vous sûr de vouloir supprimer l'hameçon <strong>Taille @hookToDelete?.Size</strong> ?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Annuler</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Supprimer</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<Hook> hooks = new();
    private bool isLoading = true;
    private bool showDeleteModal = false;
    private Hook? hookToDelete = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadHooks();
    }

    private async Task LoadHooks()
    {
        isLoading = true;
        try
        {
            hooks = await EquipmentService.GetAllHooksAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement des hameçons: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AddHook()
    {
        Navigation.NavigateTo("/materiel/hamecons/ajouter");
    }

    private void EditHook(int id)
    {
        Navigation.NavigateTo($"/materiel/hamecons/modifier/{id}");
    }

    private void ShowDeleteConfirmation(Hook hook)
    {
        hookToDelete = hook;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
        hookToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (hookToDelete != null)
        {
            try
            {
                await EquipmentService.DeleteHookAsync(hookToDelete.Id);
                await LoadHooks();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erreur lors de la suppression: {ex.Message}");
            }
        }
        showDeleteModal = false;
        hookToDelete = null;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/materiel");
    }
}
